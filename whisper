def build_bible_book_alias_lookup() -> tuple[dict[tuple[str, ...], str], tuple[int, ...]]:
    alias_lookup: dict[tuple[str, ...], str] = {}
    for canonical, aliases in BIBLE_BOOK_BASE_ALIASES.items():
        for alias in aliases:
            alias_lookup[alias] = canonical
    for book_info in BIBLE_NUMBERED_BOOK_ALIASES.values():
        base_aliases = book_info["aliases"]
        for number, prefixes in BIBLE_NUMBER_PREFIX_ALIASES.items():
            canonical = book_info.get(number)
            if not canonical:
                continue
            for prefix in prefixes:
                for base_alias in base_aliases:
                    alias_lookup[prefix + base_alias] = canonical
    alias_lengths = tuple(sorted({len(alias) for alias in alias_lookup}, reverse=True))
    return alias_lookup, alias_lengths


BIBLE_BOOK_ALIAS_LOOKUP, BIBLE_BOOK_ALIAS_LENGTHS = build_bible_book_alias_lookup()


def normalized_lookup_text(text: str) -> str:
    return " ".join(
        text.replace("’", "'").replace("‘", "'").replace("ʼ", "'").replace("–", "-").replace("—", "-").split()
    ).casefold()


def glossary_phrase_core_tokens(text: str) -> tuple[str, ...]:
    tokens: list[str] = []
    for raw_token in " ".join(text.strip().split()).split():
        match = BIBLE_REFERENCE_TOKEN_RE.match(raw_token)
        if not match:
            continue
        core = normalized_lookup_text(match.group(2))
        if core:
            tokens.append(core)
    return tuple(tokens)


def glossary_phrase_replacement_tokens(text: str) -> tuple[str, ...]:
    tokens: list[str] = []
    for raw_token in " ".join(text.strip().split()).split():
        match = BIBLE_REFERENCE_TOKEN_RE.match(raw_token)
        if not match:
            continue
        core = match.group(2)
        if core:
            tokens.append(core)
    return tuple(tokens)


def normalized_phrase_key(text: str) -> str:
    return " ".join(glossary_phrase_core_tokens(text))


def compile_glossary_phrase_mapping(
    phrase_mapping: dict[str, str] | tuple[tuple[str, str], ...],
) -> tuple[dict[tuple[str, ...], tuple[str, ...]], tuple[int, ...]]:
    replacements: dict[tuple[str, ...], tuple[str, ...]] = {}
    items = phrase_mapping.items() if isinstance(phrase_mapping, dict) else phrase_mapping
    for alias_phrase, replacement_phrase in items:
        alias_tokens = glossary_phrase_core_tokens(alias_phrase)
        replacement_tokens = glossary_phrase_replacement_tokens(replacement_phrase)
        if alias_tokens and replacement_tokens:
            replacements[alias_tokens] = replacement_tokens
    return replacements, tuple(sorted({len(alias) for alias in replacements}, reverse=True))


BUILT_IN_GLOSSARY_REPLACEMENTS, BUILT_IN_GLOSSARY_LENGTHS = compile_glossary_phrase_mapping(BUILT_IN_GLOSSARY_PHRASES)


