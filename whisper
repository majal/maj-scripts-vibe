def count_high_cps_cues(
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
    *,
    speech_intervals: list[tuple[float, float]] | None,
    style: SubtitleStyleProfile,
) -> tuple[int, float]:
    count = 0
    max_cps = 0.0
    for segment in segments:
        for start, end, line_groups in iter_segment_subtitle_cues(segment, speech_intervals=speech_intervals, style=style):
            text = " ".join(
                " ".join(subtitle_item_text(item) for item in line).strip()
                for line in line_groups
                if line
            ).strip()
            if not text:
                continue
            cps = len(text) / max(0.01, end - start)
            if cps > style.max_chars_per_second:
                count += 1
                max_cps = max(max_cps, cps)
    return count, max_cps


def render_path_list(paths: tuple[Path, ...], *, limit: int = 3) -> str:
    if not paths:
        return ""
    names = [path.name for path in paths[:limit]]
    if len(paths) > limit:
        names.append(f"+{len(paths) - limit} more")
    return ", ".join(names)


def print_postprocess_review(
    media_path: Path,
    *,
    glossary_sources: tuple[Path, ...],
    suppression_sources: tuple[Path, ...],
    speech_prune_stats: SpeechPruneStats,
    suppression_stats: SuppressionStats,
    spoken_phrase_candidates: int,
    text_only_outside_speech_segments: int,
    high_cps_count: int,
    high_cps_max: float,
    bible_reference_phrases_enabled: bool,
    style: SubtitleStyleProfile,
) -> None:
    notes: list[str] = []
    if glossary_sources:
        notes.append(f"Applied glossary files: {render_path_list(glossary_sources)}.")
    if suppression_sources:
        notes.append(f"Applied suppression files: {render_path_list(suppression_sources)}.")
    if speech_prune_stats.dropped_segments or speech_prune_stats.trimmed_segments:
        notes.append(
            "Speech-aware cleanup trimmed "
            f"{speech_prune_stats.trimmed_segments} segment(s), dropped {speech_prune_stats.dropped_segments} segment(s), "
            f"and removed {speech_prune_stats.dropped_words} edge word(s)."
        )
    suppressed_total = suppression_stats.leading_segments + suppression_stats.trailing_segments + suppression_stats.anywhere_segments
    if suppressed_total:
        notes.append(f"Suppression removed {suppressed_total} segment(s) from the transcript cleanup pass.")
    if not bible_reference_phrases_enabled and spoken_phrase_candidates:
        notes.append(
            f"Detected {spoken_phrase_candidates} spoken Bible-reference phrase(s) still in text; rerun with --bible-reference-phrases if you want them normalized."
        )
    if text_only_outside_speech_segments:
        notes.append(
            f"Left {text_only_outside_speech_segments} text-only segment(s) outside detected speech untouched because the backend did not provide word timings."
        )
    if high_cps_count:
        notes.append(
            f"{high_cps_count} subtitle cue(s) still exceed the {style.name} target of {style.max_chars_per_second:.1f} chars/sec; max observed was {high_cps_max:.1f}."
        )
    print(f"🔎 Postprocessing review: {media_path.name}", file=sys.stderr)
    if not notes:
        print("   Nothing suspicious stood out.", file=sys.stderr)
        return
    for note in notes:
        print(f"   - {note}", file=sys.stderr)


def speaker_label_token() -> str | None:
    return os.environ.get("HF_TOKEN") or os.environ.get("HUGGINGFACE_TOKEN")


def load_speaker_label_pipeline(cache_dir: Path):
    from pyannote.audio import Pipeline

    token = speaker_label_token()
    kwargs = {"cache_dir": str(cache_dir)}
    if token:
        kwargs["token"] = token
    try:
        return Pipeline.from_pretrained(SPEAKER_LABEL_MODEL_ID, **kwargs)
    except TypeError:
        kwargs.pop("token", None)
        if token:
            kwargs["use_auth_token"] = token
        return Pipeline.from_pretrained(SPEAKER_LABEL_MODEL_ID, **kwargs)


def iter_annotation_speaker_turns(annotation) -> list[SpeakerTurn]:
    turns: list[SpeakerTurn] = []
    if hasattr(annotation, "itertracks"):
        for item in annotation.itertracks(yield_label=True):
            if len(item) == 3:
                turn, _track, speaker = item
            elif len(item) == 2:
                turn, speaker = item
            else:
                continue
            turns.append(SpeakerTurn(float(turn.start), float(turn.end), str(speaker)))
        return turns
    for item in annotation:
        try:
            if len(item) == 3:
                turn, _track, speaker = item
            elif len(item) == 2:
                turn, speaker = item
            else:
                continue
            turns.append(SpeakerTurn(float(turn.start), float(turn.end), str(speaker)))
        except (TypeError, ValueError, AttributeError):
            continue
    return turns


def extract_speaker_turns(output) -> list[SpeakerTurn]:
    annotation = (
        getattr(output, "exclusive_speaker_diarization", None)
        or getattr(output, "speaker_diarization", None)
        or output
    )
    turns = iter_annotation_speaker_turns(annotation)
    return sorted((turn for turn in turns if turn.end > turn.start and turn.speaker), key=lambda turn: (turn.start, turn.end))


def speaker_overlap_seconds(segment_start: float, segment_end: float, turn: SpeakerTurn) -> float:
    return max(0.0, min(segment_end, turn.end) - max(segment_start, turn.start))


def speaker_for_segment(
    segment: dict[str, float | str | list[dict[str, float | str]]],
    turns: list[SpeakerTurn],
) -> str:
    if not turns:
        return ""
    segment_start = float(segment.get("start", 0.0))
    segment_end = float(segment.get("end", segment_start))
    best_speaker = ""
    best_overlap = 0.0
    for turn in turns:
        if turn.end <= segment_start:
            continue
        if turn.start >= segment_end:
            break
        overlap = speaker_overlap_seconds(segment_start, segment_end, turn)
        if overlap > best_overlap:
            best_overlap = overlap
            best_speaker = turn.speaker
    if best_speaker:
        return best_speaker
    midpoint = segment_start + max(0.0, segment_end - segment_start) / 2
    for turn in turns:
        if turn.start <= midpoint <= turn.end:
            return turn.speaker
    return ""


def apply_speaker_turns_to_segments(
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
    turns: list[SpeakerTurn],
) -> list[dict[str, float | str | list[dict[str, float | str]]]]:
    speaker_names: dict[str, str] = {}
    labeled: list[dict[str, float | str | list[dict[str, float | str]]]] = []
    for segment in segments:
        raw_speaker = speaker_for_segment(segment, turns)
        public_speaker = ""
        if raw_speaker:
            if raw_speaker not in speaker_names:
                speaker_names[raw_speaker] = f"Speaker {len(speaker_names) + 1}"
            public_speaker = speaker_names[raw_speaker]
        labeled.append({**segment, "speaker": public_speaker})
    return labeled


def run_speaker_labeling(
    media_path: Path,
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
    *,
    state_dir: Path,
    compact_status: bool,
    show_stage_messages: bool,
) -> list[dict[str, float | str | list[dict[str, float | str]]]]:
    scope, cache_dir = speaker_label_cache_choice(state_dir)
    if scope == "app":
        cache_dir.mkdir(parents=True, exist_ok=True)
    if show_stage_messages:
        message = "Labeling speakers" if compact_status else f"Labeling speakers in {media_path.name}"
        print(f"👥 {message}...", file=sys.stderr)
    try:
        pipeline = load_speaker_label_pipeline(cache_dir)
        output = pipeline(str(media_path))
    except Exception as exc:
        raise RuntimeError(
            "Speaker labeling failed. The pyannote model may need accepted Hugging Face terms "
            "and an HF_TOKEN/HUGGINGFACE_TOKEN environment variable."
        ) from exc
    turns = extract_speaker_turns(output)
    if not turns:
        warn("Speaker labeling finished, but no speaker turns were returned. Transcript text will stay unlabeled.")
        return segments
    return apply_speaker_turns_to_segments(segments, turns)


def normalize_faster_segments(segments_iter, report_progress):
    normalized = []
    for segment in segments_iter:
        words = []
        for word in getattr(segment, "words", []) or []:
            text = normalized_text(getattr(word, "word", ""))
            if text:
                words.append({"start": float(word.start), "end": float(word.end), "word": text})
        normalized.append({"start": float(segment.start), "end": float(segment.end), "text": normalized_text(getattr(segment, "text", "")), "words": words})
        report_progress(float(segment.end))
    return normalized


def normalize_mlx_segments(result: dict, report_progress):
    normalized = []
    for segment in result.get("segments", []) or []:
        words = []
        for word in segment.get("words", []) or []:
            text = normalized_text(word.get("word", ""))
            if text:
                words.append({"start": float(word["start"]), "end": float(word["end"]), "word": text})
        normalized.append({"start": float(segment["start"]), "end": float(segment["end"]), "text": normalized_text(segment.get("text", "")), "words": words})
        report_progress(float(segment["end"]))
    return normalized


def resolve_mlx_model_name(model_name: str) -> str:
    mapping = {
        "tiny": "mlx-community/whisper-tiny-mlx",
        "base": "mlx-community/whisper-base-mlx",
        "small": "mlx-community/whisper-small-mlx",
        "medium": "mlx-community/whisper-medium-mlx",
        "large": "mlx-community/whisper-large-v3-mlx",
        "large-v2": "mlx-community/whisper-large-v2-mlx",
        "large-v3": "mlx-community/whisper-large-v3-mlx",
        "distil-large-v3": "mlx-community/distil-whisper-large-v3",
    }
    return model_name if "/" in model_name else mapping.get(model_name, model_name)


def run_faster_whisper(media_path: Path, model: str, language: str, device: str, compute_type: str, report_progress):
    from faster_whisper import WhisperModel

    whisper_model = WhisperModel(model, device=device, compute_type=compute_type)
    segments_iter, info = whisper_model.transcribe(str(media_path), language=None if language == "auto" else language, vad_filter=True, word_timestamps=True)
    return normalize_faster_segments(segments_iter, report_progress), getattr(info, "language", None)


def run_mlx_whisper(media_path: Path, model: str, language: str, report_progress, *, word_timestamps: bool):
    import mlx_whisper

    result = mlx_whisper.transcribe(
        str(media_path),
        path_or_hf_repo=resolve_mlx_model_name(model),
        language=None if language == "auto" else language,
        word_timestamps=word_timestamps,
    )
    for segment in result.get("segments", []) or []:
        report_progress(float(segment["end"]))
    return result


def process_file(
    media_path: Path,
    env: dict[str, str],
    backend: str,
    *,
    file_index: int,
    total_files: int,
    inline_progress: bool,
    compact_status: bool,
    show_progress: bool = True,
    show_stage_messages: bool = True,
) -> str:
    started_at = time.time()
    progress_prefix = f" [{file_index}/{total_files}]" if total_files > 1 else ""
    planned_outputs = transcription_output_plan(media_path, env, backend)
    force = env.get("WHISPER_FORCE", "0") == "1"
    if not force and output_plan_complete(planned_outputs):
        if compact_status:
            print("⏭ Skipping existing output.", file=sys.stderr)
        else:
            print(f"⏭ Skipping existing output: {media_path.name}", file=sys.stderr)
        return "Skipped; expected output already exists"
    if not force and (output_plan_can_derive_transcript_from_subtitle(planned_outputs) or output_plan_resume_from_subtitle(planned_outputs)):
        subtitle_path = planned_outputs["subtitle_path"]
        transcript_source_path = planned_outputs.get("transcript_source_subtitle_path")
        text_path = planned_outputs.get("text_path")
        output_root = planned_outputs["output_root"]
        if not isinstance(output_root, Path):
            raise ValueError("Unable to reuse existing subtitles because the output plan is incomplete.")
        output_root.mkdir(parents=True, exist_ok=True)
        if isinstance(text_path, Path) and isinstance(transcript_source_path, Path) and transcript_source_path.exists() and not text_path.exists():
            write_transcript_from_subtitle(
                transcript_source_path,
                text_path,
                paragraphs=env.get("WHISPER_PARAGRAPHS", "0") == "1",
            )
            if show_stage_messages:
                if compact_status:
                    print("📝 Wrote transcript from existing subtitles.", file=sys.stderr)
                else:
                    print(f"📝 Wrote transcript from existing subtitles: {transcript_source_path.name}", file=sys.stderr)
        if not isinstance(subtitle_path, Path):
            return "Reused existing subtitles for transcript"
        if not subtitle_path.exists():
            raise ValueError("Unable to finish requested video outputs because the planned subtitle file is missing.")
        if compact_status:
            print("⏭ Reusing existing subtitles.", file=sys.stderr)
        else:
            print(f"⏭ Reusing existing subtitles for video output: {subtitle_path.name}", file=sys.stderr)
        apply_subtitle_outputs(
            media_path,
            subtitle_path,
            output_root,
            env,
            compact_status=compact_status,
            subtitle_language=resolve_subtitle_language(media_path, env["WHISPER_LANG"]),
            show_messages=show_stage_messages,
        )
        elapsed = time.time() - started_at
        return f"Resumed from existing subtitles in {format_elapsed_precise(elapsed)}"
    start_message = f"▶ Starting transcription{progress_prefix}: {media_path.name} [{backend}]"
    print(start_message, file=sys.stderr)
    wait_message = f"Waiting for {backend}" if compact_status else f"Waiting for {backend} on {media_path.name}"
    wait_spinner = Spinner(wait_message, enabled=show_stage_messages, delay_seconds=3.0)
    progress = EstimatedProgressReporter(
        media_path,
        backend,
        inline=inline_progress,
        show_media_name=not compact_status,
        enabled=show_progress,
    )
    spinner_state = {"stopped": False}
    mlx_word_timestamps = env.get("WHISPER_MLX_WORD_TIMESTAMPS", "auto")
    subtitle_style = resolve_subtitle_style_profile(env.get("WHISPER_SUBTITLE_STYLE", "balanced"))
    review_postprocessing = env.get("WHISPER_REVIEW_POSTPROCESSING", "0") == "1"
    glossary_replacements, glossary_lengths, glossary_sources = load_effective_glossary(
        media_path,
        load_env_paths(env, "WHISPER_GLOSSARY_FILES"),
    )
    suppression_rules, suppression_sources = load_effective_suppression_rules(
        media_path,
        load_env_paths(env, "WHISPER_SUPPRESSION_FILES"),
    )
    output_txt = should_write_text_output(env, backend)
    mlx_word_timestamps_enabled = mlx_word_timestamps != "off"
    if mlx_word_timestamps == "on":
        mlx_word_timestamps_enabled = True

    def stop_wait_spinner() -> None:
        if not spinner_state["stopped"]:
            wait_spinner.stop()
            spinner_state["stopped"] = True

    def report_with_spinner(current_end: float) -> None:
        stop_wait_spinner()
        progress.report(current_end)

    wait_spinner.start()
    detected_language: str | None = None
    if backend == "mlx":
        try:
            mlx_result = run_mlx_whisper(
                media_path,
                env["WHISPER_MODEL"],
                env["WHISPER_LANG"],
                report_with_spinner,
                word_timestamps=mlx_word_timestamps_enabled,
            )
            detected_language = mlx_result.get("language")
        finally:
            stop_wait_spinner()
    else:
        device = env["WHISPER_DEVICE"] if backend == env["WHISPER_BACKEND"] else env["WHISPER_FALLBACK_DEVICE"]
        compute = env["WHISPER_COMPUTE_TYPE"] if backend == env["WHISPER_BACKEND"] else env["WHISPER_FALLBACK_COMPUTE_TYPE"]
        try:
            segments, detected_language = run_faster_whisper(
                media_path, env["WHISPER_MODEL"], env["WHISPER_LANG"], device, compute, report_with_spinner
            )
        finally:
            stop_wait_spinner()
    progress.finish()
    progress.before_stage_message()
    output_root = output_root_for_media(media_path, env)
    output_root.mkdir(parents=True, exist_ok=True)
    if backend == "mlx":
        segments = normalize_mlx_segments(mlx_result, lambda _current_end: None)
    bible_reference_normalization_enabled = env.get("WHISPER_BIBLE_REFERENCE_NORMALIZATION", "1") == "1"
    bible_reference_phrase_normalization_enabled = (
        bible_reference_normalization_enabled
        and env.get("WHISPER_BIBLE_REFERENCE_PHRASES", "0") == "1"
    )
    segments = postprocess_segments(
        segments,
        normalize_bible_references=bible_reference_normalization_enabled,
        normalize_bible_reference_phrases=bible_reference_phrase_normalization_enabled,
        glossary_replacements=glossary_replacements,
        glossary_lengths=glossary_lengths,
    )
    subtitle_language = resolve_subtitle_language(media_path, env["WHISPER_LANG"], detected_language)
    speech_trim_enabled = env.get("WHISPER_SPEECH_TRIM", "1") == "1"
    speech_intervals: list[tuple[float, float]] | None = None
    if speech_trim_enabled:
        speech_trim_message = "Analyzing speech onset" if compact_status else f"Analyzing speech onset on {media_path.name}"
        speech_trim_spinner = Spinner(speech_trim_message, enabled=show_stage_messages, delay_seconds=1.2)
        speech_trim_spinner.start()
        try:
            speech_intervals = detect_speech_intervals(media_path)
        finally:
            speech_trim_spinner.stop()
    segments, speech_prune_stats = prune_segments_to_speech(segments, speech_intervals if speech_trim_enabled else None)
    segments, suppression_stats = apply_suppression_rules_to_segments(segments, suppression_rules)
    if env.get("WHISPER_SPEAKER_LABELS", "0") == "1":
        segments = run_speaker_labeling(
            media_path,
            segments,
            state_dir=Path(env.get("WHISPER_STATE_DIR", "")) if env.get("WHISPER_STATE_DIR") else default_state_dir(detect_os()),
            compact_status=compact_status,
            show_stage_messages=show_stage_messages,
        )
    spoken_phrase_candidates = (
        count_spoken_bible_reference_phrase_candidates(segments)
        if review_postprocessing and not bible_reference_phrase_normalization_enabled
        else 0
    )
    text_only_outside_speech_segments = (
        count_text_only_outside_speech_segments(segments, speech_intervals)
        if review_postprocessing and speech_intervals
        else 0
    )
    high_cps_count = 0
    high_cps_max = 0.0
    if review_postprocessing and not output_txt:
        high_cps_count, high_cps_max = count_high_cps_cues(
            segments,
            speech_intervals=speech_intervals,
            style=subtitle_style,
        )
    if should_write_transcript(env, backend):
        write_transcript_output(
            media_path,
            output_root,
            segments,
            backend,
            speech_trim_enabled=speech_trim_enabled,
            suppression_sources=suppression_sources,
            compact_status=compact_status,
            show_stage_messages=show_stage_messages,
            paragraphs=env.get("WHISPER_PARAGRAPHS", "0") == "1",
            speaker_labels=env.get("WHISPER_SPEAKER_LABELS", "0") == "1",
            mlx_result=mlx_result if backend == "mlx" else None,
        )
    if not output_txt:
        subtitle_path = output_root / f"{media_path.stem}.{'ass' if env['WHISPER_ASS'] == '1' else 'srt'}"
        if env["WHISPER_ASS"] == "1":
            write_ass(
                subtitle_path,
                segments,
                env["WHISPER_FONT"],
                env["WHISPER_KARAOKE"] == "1",
                speech_intervals=speech_intervals,
                style=subtitle_style,
            )
        else:
            write_srt(subtitle_path, segments, speech_intervals=speech_intervals, style=subtitle_style)
        apply_subtitle_outputs(
            media_path,
            subtitle_path,
            output_root,
            env,
            compact_status=compact_status,
            subtitle_language=subtitle_language,
            show_messages=show_stage_messages,
        )
    if review_postprocessing:
        print_postprocess_review(
            media_path,
            glossary_sources=glossary_sources,
            suppression_sources=suppression_sources,
            speech_prune_stats=speech_prune_stats,
            suppression_stats=suppression_stats,
            spoken_phrase_candidates=spoken_phrase_candidates,
            text_only_outside_speech_segments=text_only_outside_speech_segments,
            high_cps_count=high_cps_count,
            high_cps_max=high_cps_max,
            bible_reference_phrases_enabled=bible_reference_phrase_normalization_enabled,
            style=subtitle_style,
        )
    elapsed = time.time() - started_at
    return f"Done in {format_elapsed_precise(elapsed)}"


def process_existing_subtitle_file(media_path: Path, env: dict[str, str], *, compact_status: bool) -> str:
    started_at = time.time()
    if media_path.suffix.lower() not in VIDEO_EXTENSIONS:
        raise ValueError(f"--embed-file only supports video files: {media_path.name}")
    print(f"▶ Embedding subtitles: {media_path.name}", file=sys.stderr)
    output_root = Path(env["WHISPER_OUTDIR"]).expanduser() if env["WHISPER_OUTDIR"] else media_path.parent
    output_root.mkdir(parents=True, exist_ok=True)
    subtitle_path = resolve_embed_subtitle_path(media_path, env["WHISPER_EMBED_FILE"])
    planned_outputs = embed_file_output_plan(media_path, env, subtitle_path=subtitle_path)
    if env.get("WHISPER_FORCE", "0") != "1" and output_plan_complete(planned_outputs):
        if compact_status:
            print("⏭ Skipping existing embedded output.", file=sys.stderr)
        else:
            print(f"⏭ Skipping existing embedded output: {media_path.name}", file=sys.stderr)
        return "Skipped; expected output already exists"
    if compact_status:
        print("📝 Using existing subtitle file.", file=sys.stderr)
    else:
        print(f"📝 Using existing subtitle file: {subtitle_path.name}", file=sys.stderr)
    apply_subtitle_outputs(
        media_path,
        subtitle_path,
        output_root,
        env,
        compact_status=compact_status,
        subtitle_language=resolve_subtitle_language(media_path, env["WHISPER_LANG"]),
    )
    elapsed = time.time() - started_at
    return f"Done in {format_elapsed_precise(elapsed)}"


def summarize_backend_error(backend: str, exc: Exception, env: dict[str, str]) -> None:
    message = str(exc)
    print(f"❌ Backend '{backend}' ran into a problem: {message}", file=sys.stderr)
    if backend == "mlx" and ("401" in message or "Repository Not Found" in message or "Invalid username or password" in message):
        print("💡 MLX couldn't download the model from Hugging Face. If you have a bad HF_TOKEN set, unset it and try again.", file=sys.stderr)
    if backend == "faster-whisper" and env.get("WHISPER_DEVICE") == "cuda":
        print("💡 If CUDA is unavailable on this machine, try again with --device=cpu.", file=sys.stderr)


def format_elapsed_summary(seconds: float) -> str:
    total_seconds = max(0, int(round(seconds)))
    hours, remainder = divmod(total_seconds, 3600)
    minutes, secs = divmod(remainder, 60)
    if hours:
        return f"{hours}h {minutes}m {secs}s"
    if minutes:
        return f"{minutes}m {secs}s"
    return f"{secs}s"


def format_elapsed_precise(seconds: float) -> str:
    total_seconds = max(0.0, seconds)
    hours = int(total_seconds // 3600)
    remainder = total_seconds - (hours * 3600)
    minutes = int(remainder // 60)
    secs = remainder - (minutes * 60)
    if secs >= 59.95:
        secs = 0.0
        minutes += 1
    if minutes >= 60:
        minutes = 0
        hours += 1
    if hours:
        return f"{hours}h {minutes}m {secs:.1f}s"
    if minutes:
        return f"{minutes}m {secs:.1f}s"
    return f"{secs:.1f}s"


def process_files(files: list[Path], env: dict[str, str], backend: str, jobs: int) -> None:
    inline_progress = jobs == 1 and sys.stderr.isatty()
    compact_status = jobs == 1
    if jobs > 1:
        with ThreadPoolExecutor(max_workers=jobs) as executor:
            futures = {
                executor.submit(
                    process_file,
                    media_path,
                    env,
                    backend,
                    file_index=index,
                    total_files=len(files),
                    inline_progress=False,
                    compact_status=False,
                    show_progress=False,
                    show_stage_messages=False,
                ): media_path
                for index, media_path in enumerate(files, start=1)
            }
            for future in as_completed(futures):
                media_path = futures[future]
                try:
                    result = future.result()
                except Exception as exc:
                    print(f"❌ Failed: {media_path.name}: {exc}", file=sys.stderr)
                    raise
                print(f"✅ {media_path.name} | {result}", file=sys.stderr)
        return
    for index, media_path in enumerate(files, start=1):
        print(file=sys.stderr)
        print(
            f"✅ {process_file(
                media_path,
                env,
                backend,
                file_index=index,
                total_files=len(files),
                inline_progress=inline_progress,
                compact_status=compact_status,
            )}"
        )


def process_embed_files(files: list[Path], env: dict[str, str], jobs: int) -> None:
    if env["WHISPER_EMBED_FILE"] and len(files) != 1:
        raise ValueError("--embed-file=/path/to/file requires exactly one video target.")
    compact_status = jobs == 1
    if jobs > 1:
        with ThreadPoolExecutor(max_workers=jobs) as executor:
            futures = [executor.submit(process_existing_subtitle_file, media_path, env, compact_status=False) for media_path in files]
            for future in as_completed(futures):
                print(f"✅ {future.result()}")
        return
    for media_path in files:
        print(file=sys.stderr)
        print(f"✅ {process_existing_subtitle_file(media_path, env, compact_status=compact_status)}")


def run_embed_file_mode(targets: list[Path], env: dict[str, str], *, recursive: bool, jobs: int) -> int:
    started_at = time.time()
    files = discover_target_files(targets, recursive)
    files = [path for path in files if path.suffix.lower() in VIDEO_EXTENSIONS]
    if not files:
        print("❌ No supported video files found for --embed-file.", file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 1
    print(f"📦 Using existing subtitle files. Processing {len(files)} file(s).", file=sys.stderr)
    try:
        process_embed_files(files, env, jobs)
        if jobs == 1:
            print(file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 0
    except Exception as exc:
        print(f"❌ Embed mode ran into a problem: {exc}", file=sys.stderr)
        if jobs == 1:
            print(file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 1


def can_finish_without_transcription(files: list[Path], env: dict[str, str], backend: str) -> bool:
    if not files or env.get("WHISPER_FORCE", "0") == "1":
        return False
    plans = [transcription_output_plan(media_path, env, backend) for media_path in files]
    return all(
        output_plan_complete(plan)
        or output_plan_resume_from_subtitle(plan)
        or output_plan_can_derive_transcript_from_subtitle(plan)
        for plan in plans
    )


def install_backend_into_managed_runtime(backend: str) -> None:
    label = "MLX Whisper packages" if backend == "mlx" else "faster-whisper packages"
    install_packages(Path(sys.executable), f"Installing {label}", *backend_packages(backend))


def managed_main() -> int:
    started_at = time.time()
    env = os.environ
    targets = load_env_targets(env)
    if env["WHISPER_EMBED_FILE_MODE"] == "1":
        return run_embed_file_mode(targets, env, recursive=env["WHISPER_RECURSIVE"] == "1", jobs=int(env["WHISPER_JOBS"]))
    files = discover_target_files(targets, env["WHISPER_RECURSIVE"] == "1")
    if not files:
        print("❌ No supported media files found.", file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 1
    backend = env["WHISPER_BACKEND"]
    fallback = env["WHISPER_FALLBACK_BACKEND"]
    auto_backend = env.get("WHISPER_AUTO_BACKEND") == "1"
    jobs = int(env["WHISPER_JOBS"])
    if backend == "mlx" and jobs > 1:
        print("⚠ MLX runs sequentially for now; ignoring --jobs > 1.", file=sys.stderr)
        jobs = 1
    print(f"🚀 Loading backend '{backend}' for model '{env['WHISPER_MODEL']}'", file=sys.stderr)
    print(f"🧠 Backend ready: {backend}. Processing {len(files)} file(s).", file=sys.stderr)
    try:
        process_files(files, env, backend, jobs)
        if jobs == 1:
            print(file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 0
    except Exception as primary_exc:
        summarize_backend_error(backend, primary_exc, env)
        if not auto_backend or fallback == "none":
            if jobs == 1:
                print(file=sys.stderr)
            print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
            return 1
        print(f"⚠ Auto mode will try one more time with fallback backend '{fallback}'.", file=sys.stderr)
        try:
            if not runtime_has_backend(Path(sys.executable), fallback):
                print(f"📦 Getting fallback backend '{fallback}' ready before retrying.", file=sys.stderr)
                install_backend_into_managed_runtime(fallback)
            print(f"🚀 Loading fallback backend '{fallback}'", file=sys.stderr)
            process_files(files, env, fallback, jobs)
            if backend == "mlx" and prompt_remove_failed_backend("mlx"):
                uninstall_packages(Path(sys.executable), "mlx-whisper")
                success("Removed MLX Python packages from the managed runtime.")
            if jobs == 1:
                print(file=sys.stderr)
            print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
            return 0
        except Exception as fallback_exc:
            print(f"❌ Fallback backend '{fallback}' ran into a problem too: {fallback_exc}", file=sys.stderr)
            if jobs == 1:
                print(file=sys.stderr)
            print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
            return 1


def maybe_remove_runtime(plan: RuntimePlan, *, assume_yes: bool) -> None:
