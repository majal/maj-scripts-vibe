def split_sentences(text: str) -> list[str]:
    return [part for part in re.split(r"(?<=[.!?])\s+", text) if part]


def split_lines(text: str) -> list[str]:
    words = text.split()
    if len(words) <= 8:
        return [text]
    midpoint = len(words) // 2
    return [" ".join(words[:midpoint]), " ".join(words[midpoint:])]


def format_srt_time(value: float) -> str:
    hours = int(value // 3600)
    minutes = int((value % 3600) // 60)
    seconds = int(value % 60)
    milliseconds = int(round((value % 1) * 1000))
    if milliseconds == 1000:
        milliseconds = 0
        seconds += 1
    return f"{hours:02}:{minutes:02}:{seconds:02},{milliseconds:03}"


def format_ass_time(value: float) -> str:
    hours = int(value // 3600)
    minutes = int((value % 3600) // 60)
    seconds = int(value % 60)
    centiseconds = int(round((value % 1) * 100))
    if centiseconds == 100:
        centiseconds = 0
        seconds += 1
    return f"{hours:d}:{minutes:02}:{seconds:02}.{centiseconds:02}"


def normalized_text(text: str) -> str:
    return " ".join(text.strip().split())


def discover_files(target: Path, recursive: bool) -> list[Path]:
    if target.is_file():
        return [target]
    if not target.is_dir():
        return []
    iterator = target.rglob("*") if recursive else target.iterdir()
    return sorted(path for path in iterator if path.is_file() and path.suffix.lower() in MEDIA_EXTENSIONS)


def probe_duration_seconds(media_path: Path) -> float | None:
    try:
        proc = subprocess.run(
            ["ffprobe", "-v", "error", "-show_entries", "format=duration", "-of", "default=noprint_wrappers=1:nokey=1", str(media_path)],
            check=True,
            capture_output=True,
            text=True,
        )
        value = proc.stdout.strip()
        duration = float(value) if value else None
        return duration if duration and duration > 0 else None
    except Exception:
        return None


def probe_subtitle_stream_count(media_path: Path) -> int:
    try:
        proc = subprocess.run(
            ["ffprobe", "-v", "error", "-select_streams", "s", "-show_entries", "stream=index", "-of", "csv=p=0", str(media_path)],
            check=True,
            capture_output=True,
            text=True,
        )
        return sum(1 for line in proc.stdout.splitlines() if line.strip())
    except Exception:
        return 0


def probe_audio_stream_language(media_path: Path) -> str | None:
    try:
        proc = subprocess.run(
            ["ffprobe", "-v", "error", "-select_streams", "a", "-show_entries", "stream_tags=language", "-of", "csv=p=0", str(media_path)],
            check=True,
            capture_output=True,
            text=True,
        )
        for line in proc.stdout.splitlines():
            language = line.strip().lower()
            if language and language != "und":
                return language
    except Exception:
        return None
    return None


def subtitle_track_metadata(language: str) -> tuple[str, str]:
    token = (language or "").strip().lower().replace("_", "-")
    if not token or token == "auto":
        return "und", "Subtitles"
    base = token.split("-", 1)[0]
    canonical = LANGUAGE_ALIASES.get(token) or LANGUAGE_ALIASES.get(base)
    if not canonical:
        canonical = token if token in LANGUAGE_LABELS else base
    if canonical in LANGUAGE_LABELS:
        iso3, title = LANGUAGE_LABELS[canonical]
        return iso3, title
    for code, (iso3, title) in LANGUAGE_LABELS.items():
        if token == iso3 or base == iso3 or token == title.lower():
            return iso3, title
    pretty = language.strip()
    return "und", pretty[:1].upper() + pretty[1:] if pretty else "Subtitles"


def resolve_subtitle_language(media_path: Path, requested_language: str, detected_language: str | None = None) -> str:
    if requested_language != "auto":
        return requested_language
    if detected_language:
        return detected_language
    return probe_audio_stream_language(media_path) or "auto"


class EstimatedProgressReporter:
    def __init__(self, media_path: Path, backend: str, *, inline: bool, show_media_name: bool) -> None:
        self.media_path = media_path
        self.backend = backend
        self.inline = inline and sys.stderr.isatty()
        self.show_media_name = show_media_name
        self.duration = probe_duration_seconds(media_path)
        self.last_percent = -1
        self.last_reported_at = 0.0
        self.eta_started_at: float | None = None
        self.eta_started_media_end: float | None = None
        self.unknown_duration_noted = False
        self.inline_rendered = False
        self.last_render_width = 0
        if self.duration is None:
            self.note_unknown_duration()
        else:
            suffix = f" for {media_path.name}" if self.show_media_name else ""
            print(f"⏱ Media length: {format_elapsed_summary(self.duration)}{suffix}", file=sys.stderr)

    def clear_inline(self) -> None:
        if not self.inline_rendered:
            return
        print(f"\r{' ' * self.last_render_width}\r", end="", file=sys.stderr, flush=True)
        self.inline_rendered = False
        self.last_render_width = 0

    def note_unknown_duration(self) -> None:
        if self.unknown_duration_noted:
            return
        self.clear_inline()
        self.unknown_duration_noted = True
        suffix = f" for {self.media_path.name}" if self.show_media_name else ""
        print(f"⏱ Media length unavailable{suffix}; estimated % progress and ETA unavailable.", file=sys.stderr)

    def estimate_eta_seconds(self, current_end: float, now: float) -> float | None:
        if self.duration is None:
            return None
        if self.eta_started_at is None or self.eta_started_media_end is None:
            self.eta_started_at = now
            self.eta_started_media_end = current_end
            return None
        elapsed = now - self.eta_started_at
        processed_media = max(0.0, current_end - self.eta_started_media_end)
        min_media_for_eta = min(60.0, max(15.0, self.duration * 0.03))
        if elapsed < 5.0 or processed_media < min_media_for_eta:
            return None
        rate = processed_media / elapsed
        if rate <= 0:
            return None
        remaining_media = max(0.0, self.duration - current_end)
        return remaining_media / rate

    def report(self, current_end: float) -> None:
        if self.duration is None:
            return
        now = time.monotonic()
        percent = int(min(100, max(0, round((current_end / self.duration) * 100))))
        if percent <= self.last_percent:
            return
        if percent < 100 and now - self.last_reported_at < 1.0:
            return
        self.last_percent = percent
        self.last_reported_at = now
        if self.show_media_name:
            message = f"⏳ {self.media_path.name} [{self.backend}] ~{percent}%"
        else:
            message = f"⏳ ~{percent}%"
        eta_seconds = self.estimate_eta_seconds(current_end, now)
        if eta_seconds is not None and percent < 100:
            message += f" | ETA {format_elapsed_summary(eta_seconds)}"
        if self.inline:
            self.last_render_width = terminal_display_width(message)
            self.inline_rendered = True
            print(f"\r{message}", end="", file=sys.stderr, flush=True)
        else:
            print(message, file=sys.stderr)

    def finish(self) -> None:
        if self.duration is None:
            return
        if self.last_percent < 100:
            self.last_percent = 100
            if self.show_media_name:
                message = f"⏳ {self.media_path.name} [{self.backend}] ~100%"
            else:
                message = "⏳ ~100%"
            if self.inline:
                self.last_render_width = terminal_display_width(message)
                self.inline_rendered = True
                print(f"\r{message}", end="", file=sys.stderr, flush=True)
            else:
                print(message, file=sys.stderr)

    def before_stage_message(self) -> None:
        if not self.inline_rendered:
            return
        if self.inline:
            print(file=sys.stderr, flush=True)
        else:
            self.clear_inline()
        self.inline_rendered = False
        self.last_render_width = 0


def subtitle_filter_arg(path: Path) -> str:
    escaped = str(path.resolve()).replace("\\", "\\\\").replace(":", "\\:").replace(",", "\\,").replace("'", "\\'")
    return f"ass={escaped}" if path.suffix.lower() == ".ass" else f"subtitles={escaped}"


def burn_subtitles(video_path: Path, subtitle_path: Path, output_path: Path, *, video_codec: str) -> None:
    command = ["ffmpeg", "-y", "-i", str(video_path), "-vf", subtitle_filter_arg(subtitle_path)]
    if video_codec != "auto":
        command.extend(["-c:v", video_codec])
    command.extend(["-c:a", "copy", str(output_path)])
    result = run_command_with_spinner(
        command,
        description=f"Burning subtitles into {video_path.name}",
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    if result.returncode != 0:
        raise subprocess.CalledProcessError(result.returncode, result.args)


def embedded_subtitle_plan(video_path: Path, subtitle_path: Path, output_root: Path) -> tuple[Path, str]:
    video_suffix = video_path.suffix.lower()
    subtitle_suffix = subtitle_path.suffix.lower()
    subtitle_codec = "ass" if subtitle_suffix == ".ass" else "srt"
    output_suffix = ".mkv"
    if video_suffix in {".mp4", ".mov"} and subtitle_codec == "srt":
        output_suffix = video_path.suffix
        subtitle_codec = "mov_text"
    elif video_suffix == ".mkv":
        output_suffix = video_path.suffix
    output_path = output_root / f"{video_path.stem}_embedded{output_suffix}"
    return output_path, subtitle_codec


def embed_subtitles(video_path: Path, subtitle_path: Path, output_path: Path, *, subtitle_codec: str, subtitle_language: str) -> None:
    subtitle_stream_index = probe_subtitle_stream_count(video_path)
    track_language, track_title = subtitle_track_metadata(subtitle_language)
    result = run_command_with_spinner(
        [
            "ffmpeg",
            "-y",
            "-i",
            str(video_path),
            "-i",
            str(subtitle_path),
            "-map",
            "0",
            "-map",
            "1",
            "-c",
            "copy",
            "-c:s",
            subtitle_codec,
            f"-metadata:s:s:{subtitle_stream_index}",
            f"language={track_language}",
            f"-metadata:s:s:{subtitle_stream_index}",
            f"title={track_title}",
            f"-metadata:s:s:{subtitle_stream_index}",
            f"handler_name={track_title}",
            str(output_path),
        ],
        description=f"Embedding subtitles into {video_path.name}",
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    if result.returncode != 0:
        raise subprocess.CalledProcessError(result.returncode, result.args)


def embed_subtitles_in_place(video_path: Path, subtitle_path: Path, *, subtitle_codec: str, subtitle_language: str) -> None:
    temp_handle = tempfile.NamedTemporaryFile(
        prefix=f".{video_path.stem}.embedtmp-",
        suffix=video_path.suffix,
        dir=video_path.parent,
        delete=False,
    )
    temp_path = Path(temp_handle.name)
    temp_handle.close()
    try:
        embed_subtitles(video_path, subtitle_path, temp_path, subtitle_codec=subtitle_codec, subtitle_language=subtitle_language)
        os.replace(temp_path, video_path)
    finally:
        if temp_path.exists():
            temp_path.unlink()


def resolve_embed_subtitle_path(media_path: Path, embed_file_value: str) -> Path:
    if embed_file_value:
        candidate = Path(embed_file_value).expanduser().resolve()
        if not candidate.exists() or not candidate.is_file():
            raise FileNotFoundError(f"Subtitle file not found: {candidate}")
        if candidate.suffix.lower() not in {".srt", ".ass"}:
            raise ValueError(f"Subtitle file must be .srt or .ass: {candidate}")
        return candidate
    candidates = [media_path.with_suffix(ext) for ext in (".srt", ".ass") if media_path.with_suffix(ext).exists()]
    if not candidates:
        raise FileNotFoundError(f"No matching .srt or .ass found for {media_path.name}")
    if len(candidates) > 1:
        names = ", ".join(path.name for path in candidates)
        raise ValueError(f"Found multiple matching subtitle files for {media_path.name}: {names}. Use --embed-file=/path/to/file.")
    return candidates[0]


def apply_subtitle_outputs(
    media_path: Path,
    subtitle_path: Path,
    output_root: Path,
    env: dict[str, str],
    *,
    compact_status: bool,
    subtitle_language: str,
) -> None:
    embed_requested = env["WHISPER_EMBED"] == "1"
    in_place = env["WHISPER_IN_PLACE"] == "1"
    if embed_requested and media_path.suffix.lower() in VIDEO_EXTENSIONS:
        embedded_path, subtitle_codec = embedded_subtitle_plan(media_path, subtitle_path, output_root)
        if in_place:
            if embedded_path.suffix.lower() != media_path.suffix.lower():
                raise ValueError(
                    f"--in-place is not available for {media_path.suffix} with {subtitle_path.suffix} subtitles; use MKV/SRT or omit --in-place."
                )
            embed_subtitles_in_place(media_path, subtitle_path, subtitle_codec=subtitle_codec, subtitle_language=subtitle_language)
            if compact_status:
                print("📦 Embedded subtitle track in place.", file=sys.stderr)
            else:
                print(f"📦 Embedded subtitle track in place: {media_path.name}", file=sys.stderr)
        else:
            embed_subtitles(media_path, subtitle_path, embedded_path, subtitle_codec=subtitle_codec, subtitle_language=subtitle_language)
            if compact_status:
                print("📦 Embedded subtitle track.", file=sys.stderr)
            else:
                print(f"📦 Embedded subtitle track: {media_path.name}", file=sys.stderr)
    if env["WHISPER_BURN"] == "1" and media_path.suffix.lower() in VIDEO_EXTENSIONS:
        burn_subtitles(
            media_path,
            subtitle_path,
            output_root / f"{media_path.stem}_subbed.mp4",
            video_codec=env["WHISPER_BURN_VCODEC"],
        )
        if compact_status:
            print("🎞 Wrote burned-in video.", file=sys.stderr)
        else:
            print(f"🎞 Wrote burned-in video: {media_path.name}", file=sys.stderr)


def write_ass(path: Path, segments, font_name: str, karaoke: bool) -> None:
    with path.open("w", encoding="utf-8") as handle:
        handle.write("[Script Info]\nScriptType: v4.00+\nPlayResX: 1920\nPlayResY: 1080\n\n")
        handle.write("[V4+ Styles]\n")
        handle.write("Format: Name,Fontname,Fontsize,PrimaryColour,SecondaryColour,OutlineColour,BackColour,Bold,Italic,Underline,StrikeOut,ScaleX,ScaleY,Spacing,Angle,BorderStyle,Outline,Shadow,Alignment,MarginL,MarginR,MarginV,Encoding\n")
        handle.write(f"Style: Default,{font_name},30,&H00FFFFFF,&H0000FFFF,&H00101010,&H64000000,0,0,0,0,100,100,0,0,1,2,0,2,40,40,40,1\n\n")
        handle.write("[Events]\nFormat: Layer,Start,End,Style,Name,MarginL,MarginR,MarginV,Effect,Text\n")
        for segment in segments:
            words = segment.get("words")
            if not words:
                text = normalized_text(segment.get("text", ""))
                if text:
                    handle.write(f"Dialogue: 0,{format_ass_time(segment['start'])},{format_ass_time(segment['end'])},Default,,0,0,0,,{text}\n")
                continue
            chunks = []
            for word in words:
                word_text = normalized_text(word["word"])
                if not word_text:
                    continue
                if karaoke:
                    duration = max(1, int(round((word["end"] - word["start"]) * 100)))
                    chunks.append(f"{{\\k{duration}}}{word_text}")
                else:
                    chunks.append(word_text)
            if chunks:
                handle.write(f"Dialogue: 0,{format_ass_time(words[0]['start'])},{format_ass_time(words[-1]['end'])},Default,,0,0,0,,{' '.join(chunks)}\n")


def write_srt(path: Path, segments) -> None:
    index = 1
    with path.open("w", encoding="utf-8") as handle:
        for segment in segments:
            text = normalized_text(segment.get("text", ""))
            if not text:
                continue
            sentences = split_sentences(text) or [text]
            duration = max((segment["end"] - segment["start"]) / max(len(sentences), 1), 0.01)
            for offset, sentence in enumerate(sentences):
                start = segment["start"] + offset * duration
                end = min(segment["end"], start + duration)
                handle.write(f"{index}\n{format_srt_time(start)} --> {format_srt_time(end)}\n")
                for line in split_lines(sentence):
                    handle.write(f"{line}\n")
                handle.write("\n")
                index += 1


def write_txt(path: Path, text: str) -> None:
    with path.open("w", encoding="utf-8") as handle:
        handle.write(text.rstrip())
        handle.write("\n")


def normalize_faster_segments(segments_iter, report_progress):
    normalized = []
    for segment in segments_iter:
        words = []
        for word in getattr(segment, "words", []) or []:
            text = normalized_text(getattr(word, "word", ""))
            if text:
                words.append({"start": float(word.start), "end": float(word.end), "word": text})
        normalized.append({"start": float(segment.start), "end": float(segment.end), "text": normalized_text(getattr(segment, "text", "")), "words": words})
        report_progress(float(segment.end))
    return normalized


def normalize_mlx_segments(result: dict, report_progress):
    normalized = []
    for segment in result.get("segments", []) or []:
        words = []
        for word in segment.get("words", []) or []:
            text = normalized_text(word.get("word", ""))
            if text:
                words.append({"start": float(word["start"]), "end": float(word["end"]), "word": text})
        normalized.append({"start": float(segment["start"]), "end": float(segment["end"]), "text": normalized_text(segment.get("text", "")), "words": words})
        report_progress(float(segment["end"]))
    return normalized


def resolve_mlx_model_name(model_name: str) -> str:
    mapping = {
        "tiny": "mlx-community/whisper-tiny-mlx",
        "base": "mlx-community/whisper-base-mlx",
        "small": "mlx-community/whisper-small-mlx",
        "medium": "mlx-community/whisper-medium-mlx",
        "large": "mlx-community/whisper-large-v3-mlx",
        "large-v2": "mlx-community/whisper-large-v2-mlx",
        "large-v3": "mlx-community/whisper-large-v3-mlx",
        "distil-large-v3": "mlx-community/distil-whisper-large-v3",
    }
    return model_name if "/" in model_name else mapping.get(model_name, model_name)


def run_faster_whisper(media_path: Path, model: str, language: str, device: str, compute_type: str, report_progress):
    from faster_whisper import WhisperModel

    whisper_model = WhisperModel(model, device=device, compute_type=compute_type)
    segments_iter, info = whisper_model.transcribe(str(media_path), language=None if language == "auto" else language, vad_filter=True, word_timestamps=True)
    return normalize_faster_segments(segments_iter, report_progress), getattr(info, "language", None)


def run_mlx_whisper(media_path: Path, model: str, language: str, report_progress, *, word_timestamps: bool):
    import mlx_whisper

    result = mlx_whisper.transcribe(
        str(media_path),
        path_or_hf_repo=resolve_mlx_model_name(model),
        language=None if language == "auto" else language,
        word_timestamps=word_timestamps,
    )
    for segment in result.get("segments", []) or []:
        report_progress(float(segment["end"]))
    return result


def process_file(media_path: Path, env: dict[str, str], backend: str, *, inline_progress: bool, compact_status: bool) -> str:
    started_at = time.time()
    print(f"▶ Starting transcription: {media_path.name} [{backend}]", file=sys.stderr)
    wait_message = f"Waiting for {backend}" if compact_status else f"Waiting for {backend} on {media_path.name}"
    wait_spinner = Spinner(wait_message, enabled=True, delay_seconds=3.0)
    progress = EstimatedProgressReporter(media_path, backend, inline=inline_progress, show_media_name=not compact_status)
    spinner_state = {"stopped": False}
    mlx_word_timestamps = env.get("WHISPER_MLX_WORD_TIMESTAMPS", "auto")
    mlx_output_format = env.get("WHISPER_MLX_OUTPUT_FORMAT", "auto")
    output_txt = (
        backend == "mlx"
        and mlx_output_format == "text"
        and env["WHISPER_ASS"] != "1"
        and env["WHISPER_BURN"] != "1"
        and env["WHISPER_EMBED"] != "1"
    )
    mlx_word_timestamps_enabled = mlx_word_timestamps != "off"
    if mlx_word_timestamps == "on":
        mlx_word_timestamps_enabled = True

    def stop_wait_spinner() -> None:
        if not spinner_state["stopped"]:
            wait_spinner.stop()
            spinner_state["stopped"] = True

    def report_with_spinner(current_end: float) -> None:
        stop_wait_spinner()
        progress.report(current_end)

    wait_spinner.start()
    detected_language: str | None = None
    if backend == "mlx":
        try:
            mlx_result = run_mlx_whisper(
                media_path,
                env["WHISPER_MODEL"],
                env["WHISPER_LANG"],
                report_with_spinner,
                word_timestamps=mlx_word_timestamps_enabled,
            )
            detected_language = mlx_result.get("language")
        finally:
            stop_wait_spinner()
    else:
        device = env["WHISPER_DEVICE"] if backend == env["WHISPER_BACKEND"] else env["WHISPER_FALLBACK_DEVICE"]
        compute = env["WHISPER_COMPUTE_TYPE"] if backend == env["WHISPER_BACKEND"] else env["WHISPER_FALLBACK_COMPUTE_TYPE"]
        try:
            segments, detected_language = run_faster_whisper(
                media_path, env["WHISPER_MODEL"], env["WHISPER_LANG"], device, compute, report_with_spinner
            )
        finally:
            stop_wait_spinner()
    progress.finish()
    progress.before_stage_message()
    output_root = Path(env["WHISPER_OUTDIR"]).expanduser() if env["WHISPER_OUTDIR"] else media_path.parent
    output_root.mkdir(parents=True, exist_ok=True)
    if backend == "mlx":
        segments = normalize_mlx_segments(mlx_result, lambda _current_end: None)
    subtitle_language = resolve_subtitle_language(media_path, env["WHISPER_LANG"], detected_language)
    if output_txt:
        text_path = output_root / f"{media_path.stem}.txt"
        write_txt(text_path, mlx_result.get("text", ""))
        print("📝 Wrote text output." if compact_status else f"📝 Wrote text output: {media_path.name}", file=sys.stderr)
    else:
        subtitle_path = output_root / f"{media_path.stem}.{'ass' if env['WHISPER_ASS'] == '1' else 'srt'}"
        if env["WHISPER_ASS"] == "1":
            write_ass(subtitle_path, segments, env["WHISPER_FONT"], env["WHISPER_KARAOKE"] == "1")
        else:
            write_srt(subtitle_path, segments)
        print("📝 Wrote subtitles." if compact_status else f"📝 Wrote subtitles: {media_path.name}", file=sys.stderr)
        apply_subtitle_outputs(
            media_path,
            subtitle_path,
            output_root,
            env,
            compact_status=compact_status,
            subtitle_language=subtitle_language,
        )
    elapsed = time.time() - started_at
    return f"{media_path.name} [{backend}] ({elapsed:.1f}s)"


def process_existing_subtitle_file(media_path: Path, env: dict[str, str], *, compact_status: bool) -> str:
    started_at = time.time()
    if media_path.suffix.lower() not in VIDEO_EXTENSIONS:
        raise ValueError(f"--embed-file only supports video files: {media_path.name}")
    print(f"▶ Embedding subtitles: {media_path.name}", file=sys.stderr)
    output_root = Path(env["WHISPER_OUTDIR"]).expanduser() if env["WHISPER_OUTDIR"] else media_path.parent
    output_root.mkdir(parents=True, exist_ok=True)
    subtitle_path = resolve_embed_subtitle_path(media_path, env["WHISPER_EMBED_FILE"])
    if compact_status:
        print("📝 Using existing subtitle file.", file=sys.stderr)
    else:
        print(f"📝 Using existing subtitle file: {subtitle_path.name}", file=sys.stderr)
    apply_subtitle_outputs(
        media_path,
        subtitle_path,
        output_root,
        env,
        compact_status=compact_status,
        subtitle_language=resolve_subtitle_language(media_path, env["WHISPER_LANG"]),
    )
    elapsed = time.time() - started_at
    return f"{media_path.name} [embed] ({elapsed:.1f}s)"


def summarize_backend_error(backend: str, exc: Exception, env: dict[str, str]) -> None:
    message = str(exc)
    print(f"❌ Backend '{backend}' ran into a problem: {message}", file=sys.stderr)
    if backend == "mlx" and ("401" in message or "Repository Not Found" in message or "Invalid username or password" in message):
        print("💡 MLX couldn't download the model from Hugging Face. If you have a bad HF_TOKEN set, unset it and try again.", file=sys.stderr)
    if backend == "faster-whisper" and env.get("WHISPER_DEVICE") == "cuda":
        print("💡 If CUDA is unavailable on this machine, try again with --device=cpu.", file=sys.stderr)


def format_elapsed_summary(seconds: float) -> str:
    total_seconds = max(0, int(round(seconds)))
    hours, remainder = divmod(total_seconds, 3600)
    minutes, secs = divmod(remainder, 60)
    if hours:
        return f"{hours}h {minutes}m {secs}s"
    if minutes:
        return f"{minutes}m {secs}s"
    return f"{secs}s"


def file_progress_bar(total: int):
    try:
        return importlib.import_module("tqdm").tqdm(total=total, desc="📦 Files")
    except ModuleNotFoundError:
        warn("Files progress bar support is unavailable in this Python; continuing without it.")
        return None


def process_files(files: list[Path], env: dict[str, str], backend: str, jobs: int) -> None:
    use_progress_bar = len(files) > 1 and sys.stderr.isatty()
    inline_progress = len(files) == 1 and jobs == 1 and not use_progress_bar
    compact_status = jobs == 1
    progress = file_progress_bar(len(files)) if use_progress_bar else None
    try:
        if jobs > 1:
            with ThreadPoolExecutor(max_workers=jobs) as executor:
                futures = [executor.submit(process_file, media_path, env, backend, inline_progress=False, compact_status=False) for media_path in files]
                for future in as_completed(futures):
                    print(f"✅ {future.result()}")
                    if progress:
                        progress.update(1)
        else:
            for media_path in files:
                print(file=sys.stderr)
                print(f"✅ {process_file(media_path, env, backend, inline_progress=inline_progress, compact_status=compact_status)}")
                if progress:
                    progress.update(1)
    finally:
        if progress:
            progress.close()


def process_embed_files(files: list[Path], env: dict[str, str], jobs: int) -> None:
    if env["WHISPER_EMBED_FILE"] and len(files) != 1:
        raise ValueError("--embed-file=/path/to/file requires exactly one video target.")
    use_progress_bar = len(files) > 1 and sys.stderr.isatty()
    compact_status = jobs == 1
    progress = file_progress_bar(len(files)) if use_progress_bar else None
    try:
        if jobs > 1:
            with ThreadPoolExecutor(max_workers=jobs) as executor:
                futures = [executor.submit(process_existing_subtitle_file, media_path, env, compact_status=False) for media_path in files]
                for future in as_completed(futures):
                    print(f"✅ {future.result()}")
                    if progress:
                        progress.update(1)
        else:
            for media_path in files:
                print(file=sys.stderr)
                print(f"✅ {process_existing_subtitle_file(media_path, env, compact_status=compact_status)}")
                if progress:
                    progress.update(1)
    finally:
        if progress:
            progress.close()


def run_embed_file_mode(target: Path, env: dict[str, str], *, recursive: bool, jobs: int) -> int:
    started_at = time.time()
    files = discover_files(target, recursive)
    files = [path for path in files if path.suffix.lower() in VIDEO_EXTENSIONS]
    if not files:
        print("❌ No supported video files found for --embed-file.", file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 1
    print(f"📦 Using existing subtitle files. Processing {len(files)} file(s).", file=sys.stderr)
    try:
        process_embed_files(files, env, jobs)
        if jobs == 1:
            print(file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 0
    except Exception as exc:
        print(f"❌ Embed mode ran into a problem: {exc}", file=sys.stderr)
        if jobs == 1:
            print(file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 1


def install_backend_into_managed_runtime(backend: str) -> None:
    label = "MLX Whisper packages" if backend == "mlx" else "faster-whisper packages"
    install_packages(Path(sys.executable), f"Installing {label}", *backend_packages(backend))


def managed_main() -> int:
    started_at = time.time()
    env = os.environ
    target = Path(env["WHISPER_TARGET"]).expanduser()
    if env["WHISPER_EMBED_FILE_MODE"] == "1":
        return run_embed_file_mode(target, env, recursive=env["WHISPER_RECURSIVE"] == "1", jobs=int(env["WHISPER_JOBS"]))
    files = discover_files(target, env["WHISPER_RECURSIVE"] == "1")
    if not files:
        print("❌ No supported media files found.", file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 1
    backend = env["WHISPER_BACKEND"]
    fallback = env["WHISPER_FALLBACK_BACKEND"]
    auto_backend = env.get("WHISPER_AUTO_BACKEND") == "1"
    jobs = int(env["WHISPER_JOBS"])
    if backend == "mlx" and jobs > 1:
        print("⚠ MLX runs sequentially for now; ignoring --jobs > 1.", file=sys.stderr)
        jobs = 1
    print(f"🚀 Loading backend '{backend}' for model '{env['WHISPER_MODEL']}'", file=sys.stderr)
    print(f"🧠 Backend ready: {backend}. Processing {len(files)} file(s).", file=sys.stderr)
    try:
        process_files(files, env, backend, jobs)
        if jobs == 1:
            print(file=sys.stderr)
        print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
        return 0
    except Exception as primary_exc:
        summarize_backend_error(backend, primary_exc, env)
        if not auto_backend or fallback == "none":
            if jobs == 1:
                print(file=sys.stderr)
            print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
            return 1
        print(f"⚠ Auto mode will try one more time with fallback backend '{fallback}'.", file=sys.stderr)
        try:
            if not runtime_has_backend(Path(sys.executable), fallback):
                print(f"📦 Getting fallback backend '{fallback}' ready before retrying.", file=sys.stderr)
                install_backend_into_managed_runtime(fallback)
            print(f"🚀 Loading fallback backend '{fallback}'", file=sys.stderr)
            process_files(files, env, fallback, jobs)
            if backend == "mlx" and prompt_remove_failed_backend("mlx"):
                uninstall_packages(Path(sys.executable), "mlx-whisper")
                success("Removed MLX Python packages from the managed runtime.")
            if jobs == 1:
                print(file=sys.stderr)
            print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
            return 0
        except Exception as fallback_exc:
            print(f"❌ Fallback backend '{fallback}' ran into a problem too: {fallback_exc}", file=sys.stderr)
            if jobs == 1:
                print(file=sys.stderr)
            print(f"🕒 Total time: {format_elapsed_summary(time.time() - started_at)}", file=sys.stderr)
            return 1


def maybe_remove_runtime(plan: RuntimePlan, *, assume_yes: bool) -> None:
    if not confirm(f"Remove the managed runtime in {plan.state_dir}?", assume_yes=assume_yes):
        die("Clean canceled. Everything is still in place.")
    shutil.rmtree(plan.state_dir)
    success(f"Removed managed runtime: {plan.state_dir}")


