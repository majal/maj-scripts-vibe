def discover_planned_files(args: argparse.Namespace) -> list[Path]:
    files = discover_target_files([Path(target).expanduser() for target in args.targets], args.recursive)
    if args.embed_file is not None and not getattr(args, "transcript_only", False):
        files = [path for path in files if path.suffix.lower() in VIDEO_EXTENSIONS]
    return files


def build_dry_run_payload(args: argparse.Namespace, plan: RuntimePlan) -> dict[str, object]:
    env = build_runtime_processing_env(args, plan)
    files = discover_planned_files(args)
    force = getattr(args, "force", False)
    effective_speaker_labels = args.speaker_labels and not (args.embed_file is not None and not args.transcript_only)
    effective_transcript = (args.transcript or effective_speaker_labels) and not (args.embed_file is not None and not args.transcript_only)
    file_entries: list[dict[str, object]] = []
    for media_path in files:
        try:
            if args.embed_file is not None and not args.transcript_only:
                entry = output_plan_to_jsonable(embed_file_output_plan(media_path, env), force=force)
            else:
                planned = transcription_output_plan(media_path, env, plan.selected_backend)
                glossary_sources, suppression_sources = effective_source_paths_for_plan(media_path, env)
                planned["glossary_sources"] = glossary_sources
                planned["suppression_sources"] = suppression_sources
                entry = output_plan_to_jsonable(planned, force=force)
        except Exception as exc:
            entry = {
                "media_path": str(media_path),
                "mode": "embed-file" if args.embed_file is not None and not args.transcript_only else "transcribe",
                "error": str(exc),
                "status": "cannot plan this file until the error is fixed",
            }
        file_entries.append(entry)
    return {
        "schema_version": 1,
        "mode": "plan",
        "config": {
            "global_path": str(GLOBAL_CONFIG_PATH),
            "project_filename": PROJECT_CONFIG_FILENAME,
            "sources": [str(path) for path in getattr(args, "_config_sources", ())],
        },
        "selection": {
            "backend": plan.selected_backend,
            "fallback_backend": plan.fallback_backend,
            "device": plan.selected_device,
            "compute_type": plan.selected_compute,
            "model": plan.selected_model,
            "model_reason": plan.model_reason,
            "runtime_selection": plan.runtime_selection_source,
        },
        "inputs": {
            "targets": list(args.targets or []),
            "recursive": args.recursive,
            "files_discovered": len(files),
        },
        "defaults": {
            "lang": args.lang,
            "jobs": args.jobs,
            "outdir": args.outdir,
            "subtitle_style": args.subtitle_style,
            "ass": args.ass,
            "karaoke": args.karaoke,
            "transcript": effective_transcript,
            "transcript_only": args.transcript_only,
            "paragraphs": args.paragraphs,
            "speaker_labels": effective_speaker_labels,
            "speech_trim": args.speech_trim,
            "glossary_files": list(args.glossary or []),
            "suppression_files": list(args.suppress_phrases or []),
        },
        "actions": {
            "embed": bool((args.embed or args.embed_file is not None) and not args.transcript_only),
            "embed_file": args.embed_file is not None and not args.transcript_only,
            "in_place": args.in_place and not args.transcript_only,
            "burn": args.burn and not args.transcript_only,
            "transcript": effective_transcript,
            "transcript_only": args.transcript_only,
            "speaker_labels": effective_speaker_labels,
            "force": force,
        },
        "speaker_labels": {
            "requested": effective_speaker_labels,
            "installed": runtime_has_speaker_labels(plan.venv_python),
            "packages": list(SPEAKER_LABEL_PACKAGES),
            "package_size_estimate": SPEAKER_LABEL_PACKAGE_SIZE_ESTIMATE,
            "model_size_estimate": SPEAKER_LABEL_MODEL_SIZE_ESTIMATE,
