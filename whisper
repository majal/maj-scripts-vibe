def runtime_python(venv_dir: Path, os_name: str) -> Path:
    if os_name == "windows":
        return venv_dir / "Scripts" / "python.exe"
    return venv_dir / "bin" / "python"


def site_packages_dir(venv_dir: Path, os_name: str, python_bin: Path) -> Path:
    version = python_major_minor(python_version(python_bin))
    if os_name == "windows":
        return venv_dir / "Lib" / "site-packages"
    return venv_dir / "lib" / f"python{version}" / "site-packages"


def runtime_has_module(python_bin: Path, module: str) -> bool:
    if not python_bin.exists():
        return False
    return subprocess.run(
        [str(python_bin), "-c", f"import importlib; importlib.import_module('{module}')"],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    ).returncode == 0


def runtime_has_backend(python_bin: Path, backend: str) -> bool:
    return runtime_has_module(python_bin, BACKEND_MODULES[backend])


def runtime_has_speaker_labels(python_bin: Path) -> bool:
    return runtime_has_module(python_bin, SPEAKER_LABEL_MODULE)


def installed_backends(python_bin: Path) -> tuple[str, ...]:
    found = [backend for backend in ("mlx", "faster-whisper") if runtime_has_backend(python_bin, backend)]
    return tuple(found)


def installed_packages(python_bin: Path) -> tuple[str, ...]:
    if not python_bin.exists():
        return ("runtime-not-built",)
    found: list[str] = []
    if runtime_has_module(python_bin, "webrtcvad"):
        found.append("webrtcvad")
    for backend in ("mlx", "faster-whisper"):
        if runtime_has_backend(python_bin, backend):
            found.append("mlx-whisper" if backend == "mlx" else "faster-whisper")
    if runtime_has_speaker_labels(python_bin):
        found.append("speaker-labels")
    return tuple(found) if found else ("venv-created-no-backends",)


def backend_packages(backend: str) -> tuple[str, ...]:
    return BACKEND_PACKAGES[backend]


def speaker_label_packages() -> tuple[str, ...]:
    return SPEAKER_LABEL_PACKAGES


def install_packages(python_bin: Path, description: str, *packages: str) -> None:
    if not packages:
        return
    info(description)
    result = run_command_with_spinner(
        [str(python_bin), "-m", "pip", "install", "--disable-pip-version-check", "--quiet", "--upgrade", *packages],
        description=description,
    )
    if result.returncode != 0:
        raise RuntimeError(f"Failed during: {description}")


def uninstall_packages(python_bin: Path, *packages: str) -> None:
    if not packages:
        return
    subprocess.run(
        [str(python_bin), "-m", "pip", "uninstall", "-y", *packages],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def ensure_venv(plan: RuntimePlan) -> None:
    plan.state_dir.mkdir(parents=True, exist_ok=True)
    if not plan.venv_python.exists():
        info(f"Creating isolated runtime in {plan.state_dir}")
        result = run_command_with_spinner(
            [str(plan.runtime_builder_python), "-m", "venv", str(plan.venv_dir)],
            description=f"Creating isolated runtime with Python {plan.runtime_builder_version}",
        )
        if result.returncode != 0:
            raise RuntimeError(f"Failed creating virtualenv with {plan.runtime_builder_python}")


def ensure_runtime(
    plan: RuntimePlan,
    *,
    update: bool,
    selected_backend_required: bool,
    speaker_labels_required: bool = False,
) -> RuntimePlan:
    ensure_venv(plan)
    missing_shared_runtime = not runtime_has_module(plan.venv_python, "webrtcvad")
    if update or missing_shared_runtime:
        install_packages(plan.venv_python, "Preparing pip in the local runtime", *PIP_BOOTSTRAP_PACKAGES)
        install_packages(plan.venv_python, "Installing shared Python packages", *SHARED_RUNTIME_PACKAGES)
    current_backends = set(installed_backends(plan.venv_python))
    backends_to_install = set()
    if update:
        backends_to_install |= current_backends
    if selected_backend_required and plan.selected_backend not in current_backends:
        backends_to_install.add(plan.selected_backend)
    for backend in ("mlx", "faster-whisper"):
        if backend in backends_to_install:
            label = "MLX Whisper packages" if backend == "mlx" else "faster-whisper packages"
            install_packages(plan.venv_python, f"Installing {label}", *backend_packages(backend))
    if speaker_labels_required and (update or not runtime_has_speaker_labels(plan.venv_python)):
        install_packages(
            plan.venv_python,
            "Installing optional speaker-label packages",
            *speaker_label_packages(),
        )
    if plan.selected_backend == "mlx" and plan.stable_mlx_python:
        if not runtime_has_backend(plan.venv_python, "mlx"):
            if plan.runtime_selection_source != "explicit":
                clear_mlx_runtime_selection(plan.base_state_dir)
            raise RuntimeError(
                f"MLX runtime validation failed for Python {plan.runtime_builder_version} at {plan.runtime_builder_python}"
            )
        save_mlx_runtime_selection(plan.base_state_dir, plan.runtime_builder_python, plan.runtime_builder_version)
    return rebuild_plan(plan)


def packages_to_install_now(
    plan: RuntimePlan,
    *,
    update: bool,
    selected_backend_required: bool,
    speaker_labels_required: bool = False,
) -> tuple[str, ...]:
    packages: list[str] = []
    if update or "webrtcvad" not in plan.installed_packages:
        packages.extend(["pip", "setuptools", "wheel", "webrtcvad"])
    if selected_backend_required and plan.selected_backend not in plan.installed_backends:
        packages.extend(["mlx-whisper" if plan.selected_backend == "mlx" else "faster-whisper"])
    if speaker_labels_required and (update or "speaker-labels" not in plan.installed_packages):
        packages.append("speaker-labels")
    return tuple(dict.fromkeys(packages))


def packages_for_possible_fallback(plan: RuntimePlan) -> tuple[str, ...]:
    if plan.fallback_backend == "none" or plan.fallback_backend in plan.installed_backends:
        return ()
    return ("mlx-whisper" if plan.fallback_backend == "mlx" else "faster-whisper",)


