def say(message: str, *, err: bool = False) -> None:
    print(message, file=sys.stderr if err else sys.stdout, flush=True)


def info(message: str) -> None:
    say(f"{CYAN}ℹ{RESET} {message}")


def success(message: str) -> None:
    say(f"{GREEN}✅{RESET} {message}")


def warn(message: str) -> None:
    say(f"{YELLOW}⚠{RESET} {message}", err=True)


def warn_once(key: str, message: str) -> None:
    if key in RUNTIME_WARNINGS_SHOWN:
        return
    RUNTIME_WARNINGS_SHOWN.add(key)
    warn(message)


def error(message: str) -> None:
    say(f"{RED}❌{RESET} {message}", err=True)


def die(message: str, code: int = 1) -> "None":
    error(message)
    raise SystemExit(code)


def run_quiet(command: list[str]) -> str | None:
    try:
        return subprocess.check_output(command, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception:
        return None


class Spinner:
    def __init__(self, message: str, *, enabled: bool, delay_seconds: float = 0.0) -> None:
        self.message = message
        self.enabled = enabled and sys.stderr.isatty()
        self.delay_seconds = delay_seconds
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None
        self._last_render_width = 0

    def start(self) -> None:
        if not self.enabled:
            return

        def spin() -> None:
            frames = ["|", "/", "-", "\\"]
            index = 0
            if self._stop.wait(self.delay_seconds):
                return
            while not self._stop.wait(0.1):
                frame = frames[index % len(frames)]
                rendered = f"{frame} {self.message}"
                self._last_render_width = terminal_display_width(rendered)
                print(f"\r{CYAN}{frame}{RESET} {self.message}", end="", file=sys.stderr, flush=True)
                index += 1
            print(f"\r{' ' * self._last_render_width}\r", end="", file=sys.stderr, flush=True)

        self._thread = threading.Thread(target=spin, daemon=True)
        self._thread.start()

    def stop(self) -> None:
        if not self.enabled:
            return
        self._stop.set()
        if self._thread:
            self._thread.join()


def run_command_with_spinner(
    command: list[str],
    *,
    description: str,
    stdout=None,
    stderr=None,
    quiet_success: bool = True,
    spinner_delay_seconds: float = 3.0,
) -> subprocess.CompletedProcess:
    spinner = Spinner(description, enabled=True, delay_seconds=spinner_delay_seconds)
    spinner.start()
    try:
        return subprocess.run(command, stdout=stdout, stderr=stderr, check=False, text=isinstance(stdout, int) or stdout == subprocess.PIPE)
    finally:
        spinner.stop()
        if not quiet_success and sys.stderr.isatty():
            info(description)


def detect_os() -> str:
    if sys.platform == "darwin":
        return "macos"
    if sys.platform.startswith("linux"):
        return "linux"
    if sys.platform.startswith("win"):
        return "windows"
    return "unknown"


def detect_arch() -> str:
    machine = (platform.machine() or "").strip().lower()
    aliases = {
        "x86_64": "x86_64",
        "amd64": "x86_64",
        "x64": "x86_64",
        "arm64": "arm64",
        "aarch64": "arm64",
    }
    return aliases.get(machine, machine or "unknown")


def detect_wsl(os_name: str) -> bool:
    if os_name != "linux":
        return False
    try:
        version_text = Path("/proc/version").read_text(encoding="utf-8", errors="ignore").lower()
    except Exception:
        return False
    return "microsoft" in version_text or "wsl" in version_text


def detect_pkg_manager() -> str:
    for candidate in ("brew", "apt-get", "dnf", "yum", "pacman", "zypper", "apk"):
        if shutil.which(candidate):
            return candidate
    return "unknown"


def detect_nvidia() -> bool:
    return shutil.which("nvidia-smi") is not None


def detect_total_memory_bytes(os_name: str) -> tuple[int | None, tuple[str, ...]]:
    notes: list[str] = []
    try:
        if os_name == "macos":
            value = run_quiet(["sysctl", "-n", "hw.memsize"])
            if value:
                return int(value), ()
            if hasattr(os, "sysconf"):
                pages = os.sysconf("SC_PHYS_PAGES")
                page_size = os.sysconf("SC_PAGE_SIZE")
                if isinstance(pages, int) and isinstance(page_size, int) and pages > 0 and page_size > 0:
                    return int(pages * page_size), ("macOS RAM estimated via sysconf",)
            notes.append("macOS RAM probe unavailable")
        elif os_name == "linux":
            for line in Path("/proc/meminfo").read_text(encoding="utf-8", errors="ignore").splitlines():
                if line.startswith("MemTotal:"):
                    parts = line.split()
                    return int(parts[1]) * 1024, ()
            if hasattr(os, "sysconf"):
                pages = os.sysconf("SC_PHYS_PAGES")
                page_size = os.sysconf("SC_PAGE_SIZE")
                if isinstance(pages, int) and isinstance(page_size, int) and pages > 0 and page_size > 0:
                    return int(pages * page_size), ("Linux RAM estimated via sysconf",)
            notes.append("Linux RAM probe unavailable")
        elif os_name == "windows":
            import ctypes

            class MemoryStatusEx(ctypes.Structure):
                _fields_ = [
                    ("dwLength", ctypes.c_ulong),
                    ("dwMemoryLoad", ctypes.c_ulong),
                    ("ullTotalPhys", ctypes.c_ulonglong),
                    ("ullAvailPhys", ctypes.c_ulonglong),
                    ("ullTotalPageFile", ctypes.c_ulonglong),
                    ("ullAvailPageFile", ctypes.c_ulonglong),
                    ("ullTotalVirtual", ctypes.c_ulonglong),
                    ("ullAvailVirtual", ctypes.c_ulonglong),
                    ("ullAvailExtendedVirtual", ctypes.c_ulonglong),
                ]

            status = MemoryStatusEx()
            status.dwLength = ctypes.sizeof(MemoryStatusEx)
            if ctypes.windll.kernel32.GlobalMemoryStatusEx(ctypes.byref(status)):
                return int(status.ullTotalPhys), ()
            notes.append("Windows RAM probe unavailable")
    except Exception:
        notes.append("memory probe failed")
    return None, tuple(notes)


def detect_linux_physical_cores() -> int | None:
    try:
        physical_pairs: set[tuple[str, str]] = set()
        current_physical_id: str | None = None
        current_core_id: str | None = None
        for raw_line in Path("/proc/cpuinfo").read_text(encoding="utf-8", errors="ignore").splitlines():
            if not raw_line.strip():
                if current_physical_id is not None and current_core_id is not None:
                    physical_pairs.add((current_physical_id, current_core_id))
                current_physical_id = None
                current_core_id = None
                continue
            key, _, value = raw_line.partition(":")
            key = key.strip()
            value = value.strip()
            if key == "physical id":
                current_physical_id = value
            elif key == "core id":
                current_core_id = value
        if current_physical_id is not None and current_core_id is not None:
            physical_pairs.add((current_physical_id, current_core_id))
        return len(physical_pairs) or None
    except Exception:
        return None


def detect_cpu_counts(os_name: str) -> tuple[int | None, int | None, tuple[str, ...]]:
    notes: list[str] = []
    logical = os.cpu_count()
    physical = None
    try:
        if os_name == "macos":
            phys = run_quiet(["sysctl", "-n", "hw.physicalcpu"])
            log = run_quiet(["sysctl", "-n", "hw.logicalcpu"])
            physical = int(phys) if phys else None
            logical = int(log) if log else logical
            if physical is None:
                notes.append("macOS physical CPU probe unavailable")
        elif os_name == "linux":
            physical = detect_linux_physical_cores()
            if physical is None:
                notes.append("Linux physical CPU probe unavailable")
        elif os_name == "windows":
            notes.append("Windows physical CPU probe unavailable")
    except Exception:
        notes.append("CPU probe failed")
    return physical, logical, tuple(notes)


def hardware_profile(os_name: str, arch_name: str) -> HardwareProfile:
    memory_bytes, memory_notes = detect_total_memory_bytes(os_name)
    physical_cpu, logical_cpu, cpu_notes = detect_cpu_counts(os_name)
    notes = list(memory_notes + cpu_notes)
    high_confidence = memory_bytes is not None and logical_cpu is not None and (physical_cpu is not None or os_name == "windows")
    return HardwareProfile(
        os_name=os_name,
        arch_name=arch_name,
        wsl=detect_wsl(os_name),
        nvidia=detect_nvidia(),
        memory_bytes=memory_bytes,
        memory_gb=round(memory_bytes / (1024**3), 1) if memory_bytes else None,
        physical_cpu=physical_cpu,
        logical_cpu=logical_cpu,
        confidence="high" if high_confidence else "partial",
        notes=tuple(dict.fromkeys(notes)),
    )


def default_state_dir(os_name: str) -> Path:
    if os.environ.get("WHISPER_HOME"):
        return Path(os.environ["WHISPER_HOME"]).expanduser()
    if os_name == "macos":
        return Path.home() / "Library" / "Application Support" / APP_NAME
    if os_name == "windows":
        return Path(os.environ.get("APPDATA", str(Path.home() / "AppData" / "Roaming"))) / APP_NAME
    if os.environ.get("XDG_DATA_HOME"):
        return Path(os.environ["XDG_DATA_HOME"]).expanduser() / APP_NAME
    return Path.home() / ".local" / "share" / APP_NAME


def python_version(python_bin: Path) -> str:
    return subprocess.check_output(
        [str(python_bin), "-c", "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}')"],
        text=True,
    ).strip()


def python_major_minor(version: str) -> str:
    return ".".join(version.split(".")[:2])


def validate_python_path(python_value: str) -> Path:
    candidate = Path(python_value).expanduser()
    if not candidate.is_absolute():
        resolved = shutil.which(python_value)
        if not resolved:
            die(f"Unable to find requested Python interpreter: {python_value}")
        candidate = Path(resolved)
    candidate = candidate.resolve()
    if not candidate.exists() or not os.access(candidate, os.X_OK):
        die(f"Requested Python interpreter is not executable: {candidate}")
    return candidate


def mlx_runtime_selection_cache_path(base_state_dir: Path) -> Path:
    return base_state_dir / MLX_RUNTIME_SELECTION_FILE


def load_mlx_runtime_selection(base_state_dir: Path) -> dict[str, str] | None:
    cache_path = mlx_runtime_selection_cache_path(base_state_dir)
    if not cache_path.exists():
        return None
    try:
        data = json.loads(cache_path.read_text(encoding="utf-8"))
    except Exception:
        return None
    python_path = data.get("python_path")
    python_version_value = data.get("python_version")
    if not python_path or not python_version_value:
        return None
    candidate = Path(python_path).expanduser()
    if not candidate.exists():
        return None
    try:
        if python_version(candidate.resolve()) != python_version_value:
            return None
    except Exception:
        return None
    return {"python_path": str(candidate.resolve()), "python_version": python_version_value}


def save_mlx_runtime_selection(base_state_dir: Path, python_bin: Path, version: str) -> None:
    cache_path = mlx_runtime_selection_cache_path(base_state_dir)
    cache_path.parent.mkdir(parents=True, exist_ok=True)
    cache_path.write_text(
        json.dumps({"python_path": str(python_bin.resolve()), "python_version": version}, indent=2) + "\n",
        encoding="utf-8",
    )


def clear_mlx_runtime_selection(base_state_dir: Path) -> None:
    cache_path = mlx_runtime_selection_cache_path(base_state_dir)
    try:
        cache_path.unlink()
    except FileNotFoundError:
        pass


def discover_mlx_python_candidates(launcher_python: Path) -> list[Path]:
    candidates: list[Path] = []
    seen: set[Path] = set()
    for version in MLX_PREFERRED_PYTHONS:
        resolved = shutil.which(f"python{version}")
        if resolved:
            path = Path(resolved).resolve()
            if path not in seen:
                seen.add(path)
                candidates.append(path)
    launcher_resolved = launcher_python.resolve()
    if launcher_resolved not in seen:
        candidates.append(launcher_resolved)
    return candidates


def probe_mlx_python_candidate(python_bin: Path) -> bool:
    try:
        with tempfile.TemporaryDirectory(prefix="whisper-mlx-probe-") as tmp_dir:
            venv_dir = Path(tmp_dir) / "venv"
            if subprocess.run([str(python_bin), "-m", "venv", str(venv_dir)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode != 0:
                return False
            probe_python = runtime_python(venv_dir, detect_os())
            commands = [
                [str(probe_python), "-m", "pip", "install", "--disable-pip-version-check", "--quiet", "--upgrade", *PIP_BOOTSTRAP_PACKAGES],
                [str(probe_python), "-m", "pip", "install", "--disable-pip-version-check", "--quiet", "--upgrade", *backend_packages("mlx")],
                [str(probe_python), "-c", "import mlx_whisper"],
            ]
            for command in commands:
                if subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode != 0:
                    return False
            return True
    except Exception:
        return False


def choose_runtime_builder_python(
    args: argparse.Namespace,
    os_name: str,
    arch_name: str,
    selected_backend: str,
    pkg_manager: str,
    base_state_dir: Path,
) -> tuple[Path, str, bool, str]:
    explicit_python = args.python or os.environ.get("WHISPER_RUNTIME_PYTHON", "")
    if explicit_python:
        builder_python = validate_python_path(explicit_python)
        return builder_python, python_version(builder_python), selected_backend == "mlx" and is_apple_silicon(os_name, arch_name), "explicit"
    stable_policy_active = selected_backend == "mlx" and is_apple_silicon(os_name, arch_name)
    if not stable_policy_active:
        launcher_python = Path(sys.executable).resolve()
        return launcher_python, python_version(launcher_python), False, "launcher"
    cached = None if args.update else load_mlx_runtime_selection(base_state_dir)
    if cached:
        cached_python = Path(cached["python_path"]).resolve()
        return cached_python, cached["python_version"], True, "cached"
    launcher_python = Path(sys.executable).resolve()
    candidates = discover_mlx_python_candidates(launcher_python)
    should_probe = not args.doctor and bool(args.targets or args.setup_only or args.update or args.stable_mlx_python)
    if should_probe:
        for candidate in candidates:
            if probe_mlx_python_candidate(candidate):
                version = python_version(candidate)
                save_mlx_runtime_selection(base_state_dir, candidate, version)
                return candidate, version, True, "probed"
    if candidates:
        preferred_python = candidates[0]
        return preferred_python, python_version(preferred_python), True, "preferred"
    help_suffix = "brew install python@3.12" if pkg_manager == "brew" else "install Python 3.12 or Python 3.13"
    die(
        "No suitable MLX runtime Python could be found. "
        f"Install one and rerun. Suggested command: {help_suffix}"
    )


def runtime_state_dir(
    base_state_dir: Path, *, selected_backend: str, stable_mlx_python: bool, runtime_builder_version: str
) -> Path:
    if not stable_mlx_python or selected_backend != "mlx":
        return base_state_dir
    major_minor = python_major_minor(runtime_builder_version)
    preferred = base_state_dir.parent / f"{base_state_dir.name}-mlx-py{major_minor}"
    legacy = base_state_dir.parent / f"{base_state_dir.name}-mlx-stable-py{major_minor}"
    if not preferred.exists() and legacy.exists():
        return legacy
    return preferred


def is_apple_silicon(os_name: str, arch_name: str) -> bool:
    return os_name == "macos" and arch_name == "arm64"


def normalize_backend_name(name: str) -> str:
    if name == "faster_whisper":
        return "faster-whisper"
    if name not in {"auto", "mlx", "faster-whisper"}:
        die("--backend must be auto, mlx, or faster-whisper")
    return name


def backend_supported_on_host(backend: str, os_name: str, arch_name: str) -> bool:
    if backend == "mlx":
        return is_apple_silicon(os_name, arch_name)
    return backend == "faster-whisper"


def choose_default_backend(profile: HardwareProfile) -> str:
    if is_apple_silicon(profile.os_name, profile.arch_name):
        return "mlx"
    return "faster-whisper"


def choose_fallback_backend(primary: str, profile: HardwareProfile, auto_backend: bool) -> str:
    if auto_backend and primary == "mlx" and is_apple_silicon(profile.os_name, profile.arch_name):
        return "faster-whisper"
    return "none"


def choose_default_device(backend: str, profile: HardwareProfile) -> str:
    if backend == "mlx":
        return "apple"
    if profile.os_name in {"linux", "windows"} and profile.nvidia:
        return "cuda"
    return "cpu"


def choose_default_compute_type(backend: str, device: str) -> str:
    if backend == "mlx":
        return "mlx"
    return "int8_float16" if device == "cuda" else "int8"


def choose_default_model(backend: str, device: str, profile: HardwareProfile) -> tuple[str, str]:
    memory_gb = profile.memory_gb
    logical_cpu = profile.logical_cpu
    if backend == "mlx":
        if memory_gb is None:
            return "small", "Apple Silicon MLX defaulted conservatively because RAM was not readable."
        if memory_gb < 8:
            return "base", "Apple Silicon lower-memory tier; defaulting to base."
        if memory_gb < 16:
            return "small", "Apple Silicon mid-memory tier; defaulting to small."
        return "medium", "Apple Silicon higher-memory tier; defaulting to medium."
    if device == "cuda":
        if profile.confidence != "high":
            return "small", "NVIDIA CUDA detected, but hardware details were partial; defaulting to small."
        if memory_gb and memory_gb >= 16 and logical_cpu and logical_cpu >= 8:
            return "medium", "CUDA available on stronger hardware; defaulting to medium."
        return "small", "CUDA available; defaulting to small for balanced speed and accuracy."
    if memory_gb is None or logical_cpu is None:
        return "base", "Hardware detection was partial; defaulting conservatively to base."
    if memory_gb >= 16 and logical_cpu >= 8:
        return "small", "CPU path on stronger hardware; defaulting to small."
    return "base", "CPU path on modest hardware; defaulting to base."


def print_install_help(os_name: str, pkg_mgr: str) -> None:
    say("")
    say(f"{BOLD}A couple of system tools are still missing. Install them, then run {Path(sys.argv[0]).name} again.{RESET}")
    commands = {
        ("macos", "brew"): "brew install python ffmpeg",
        ("windows", "unknown"): "winget install Python.Python.3.14 Gyan.FFmpeg",
        ("linux", "apt-get"): "sudo apt-get update && sudo apt-get install -y python3 python3-venv ffmpeg",
        ("linux", "dnf"): "sudo dnf install -y python3 python3-pip python3-virtualenv ffmpeg",
        ("linux", "yum"): "sudo yum install -y python3 python3-pip ffmpeg",
        ("linux", "pacman"): "sudo pacman -S --needed python ffmpeg",
        ("linux", "zypper"): "sudo zypper install -y python311 python311-virtualenv ffmpeg",
        ("linux", "apk"): "sudo apk add python3 py3-pip ffmpeg",
    }
