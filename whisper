    raise SystemExit(code)


def run_quiet(command: list[str]) -> str | None:
    try:
        return subprocess.check_output(command, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception:
        return None


class Spinner:
    def __init__(self, message: str, *, enabled: bool, delay_seconds: float = 0.0) -> None:
        self.message = message
        self.enabled = enabled and sys.stderr.isatty()
        self.delay_seconds = delay_seconds
        self._stop = threading.Event()
        self._thread: threading.Thread | None = None
        self._last_render_width = 0

    def start(self) -> None:
        if not self.enabled:
            return

        def spin() -> None:
            frames = ["|", "/", "-", "\\"]
            index = 0
            if self._stop.wait(self.delay_seconds):
                return
            while not self._stop.wait(0.1):
                frame = frames[index % len(frames)]
                rendered = f"{frame} {self.message}"
                self._last_render_width = terminal_display_width(rendered)
                print(f"\r{CYAN}{frame}{RESET} {self.message}", end="", file=sys.stderr, flush=True)
                index += 1
            print(f"\r{' ' * self._last_render_width}\r", end="", file=sys.stderr, flush=True)

        self._thread = threading.Thread(target=spin, daemon=True)
        self._thread.start()

    def stop(self) -> None:
        if not self.enabled:
            return
        self._stop.set()
        if self._thread:
            self._thread.join()


def run_command_with_spinner(
    command: list[str],
    *,
    description: str,
    stdout=None,
    stderr=None,
    quiet_success: bool = True,
    spinner_delay_seconds: float = 3.0,
) -> subprocess.CompletedProcess:
    spinner = Spinner(description, enabled=True, delay_seconds=spinner_delay_seconds)
    spinner.start()
    try:
        return subprocess.run(command, stdout=stdout, stderr=stderr, check=False, text=isinstance(stdout, int) or stdout == subprocess.PIPE)
    finally:
        spinner.stop()
        if not quiet_success and sys.stderr.isatty():
            info(description)


def detect_os() -> str:
    if sys.platform == "darwin":
        return "macos"
    if sys.platform.startswith("linux"):
        return "linux"
    if sys.platform.startswith("win"):
        return "windows"
    return "unknown"


def detect_arch() -> str:
    machine = (platform.machine() or "").strip().lower()
    aliases = {
        "x86_64": "x86_64",
        "amd64": "x86_64",
        "x64": "x86_64",
        "arm64": "arm64",
        "aarch64": "arm64",
    }
    return aliases.get(machine, machine or "unknown")


def detect_wsl(os_name: str) -> bool:
    if os_name != "linux":
        return False
    try:
        version_text = Path("/proc/version").read_text(encoding="utf-8", errors="ignore").lower()
    except Exception:
        return False
    return "microsoft" in version_text or "wsl" in version_text


def detect_pkg_manager() -> str:
    for candidate in ("brew", "apt-get", "dnf", "yum", "pacman", "zypper", "apk"):
        if shutil.which(candidate):
            return candidate
    return "unknown"


def detect_nvidia() -> bool:
    return shutil.which("nvidia-smi") is not None


def detect_total_memory_bytes(os_name: str) -> tuple[int | None, tuple[str, ...]]:
    notes: list[str] = []
    try:
        if os_name == "macos":
            value = run_quiet(["sysctl", "-n", "hw.memsize"])
            if value:
                return int(value), ()
            if hasattr(os, "sysconf"):
                pages = os.sysconf("SC_PHYS_PAGES")
                page_size = os.sysconf("SC_PAGE_SIZE")
                if isinstance(pages, int) and isinstance(page_size, int) and pages > 0 and page_size > 0:
                    return int(pages * page_size), ("macOS RAM estimated via sysconf",)
            notes.append("macOS RAM probe unavailable")
        elif os_name == "linux":
            for line in Path("/proc/meminfo").read_text(encoding="utf-8", errors="ignore").splitlines():
                if line.startswith("MemTotal:"):
                    parts = line.split()
                    return int(parts[1]) * 1024, ()
            if hasattr(os, "sysconf"):
                pages = os.sysconf("SC_PHYS_PAGES")
                page_size = os.sysconf("SC_PAGE_SIZE")
                if isinstance(pages, int) and isinstance(page_size, int) and pages > 0 and page_size > 0:
                    return int(pages * page_size), ("Linux RAM estimated via sysconf",)
            notes.append("Linux RAM probe unavailable")
        elif os_name == "windows":
            import ctypes

            class MemoryStatusEx(ctypes.Structure):
                _fields_ = [
                    ("dwLength", ctypes.c_ulong),
                    ("dwMemoryLoad", ctypes.c_ulong),
                    ("ullTotalPhys", ctypes.c_ulonglong),
                    ("ullAvailPhys", ctypes.c_ulonglong),
                    ("ullTotalPageFile", ctypes.c_ulonglong),
                    ("ullAvailPageFile", ctypes.c_ulonglong),
                    ("ullTotalVirtual", ctypes.c_ulonglong),
                    ("ullAvailVirtual", ctypes.c_ulonglong),
                    ("ullAvailExtendedVirtual", ctypes.c_ulonglong),
                ]

            status = MemoryStatusEx()
            status.dwLength = ctypes.sizeof(MemoryStatusEx)
            if ctypes.windll.kernel32.GlobalMemoryStatusEx(ctypes.byref(status)):
                return int(status.ullTotalPhys), ()
            notes.append("Windows RAM probe unavailable")
    except Exception:
        notes.append("memory probe failed")
    return None, tuple(notes)


def detect_linux_physical_cores() -> int | None:
    try:
        physical_pairs: set[tuple[str, str]] = set()
        current_physical_id: str | None = None
        current_core_id: str | None = None
        for raw_line in Path("/proc/cpuinfo").read_text(encoding="utf-8", errors="ignore").splitlines():
            if not raw_line.strip():
                if current_physical_id is not None and current_core_id is not None:
                    physical_pairs.add((current_physical_id, current_core_id))
                current_physical_id = None
                current_core_id = None
                continue
            key, _, value = raw_line.partition(":")
            key = key.strip()
            value = value.strip()
            if key == "physical id":
                current_physical_id = value
            elif key == "core id":
                current_core_id = value
        if current_physical_id is not None and current_core_id is not None:
            physical_pairs.add((current_physical_id, current_core_id))
        return len(physical_pairs) or None
    except Exception:
        return None


def detect_cpu_counts(os_name: str) -> tuple[int | None, int | None, tuple[str, ...]]:
    notes: list[str] = []
    logical = os.cpu_count()
    physical = None
    try:
        if os_name == "macos":
            phys = run_quiet(["sysctl", "-n", "hw.physicalcpu"])
            log = run_quiet(["sysctl", "-n", "hw.logicalcpu"])
            physical = int(phys) if phys else None
            logical = int(log) if log else logical
            if physical is None:
                notes.append("macOS physical CPU probe unavailable")
        elif os_name == "linux":
            physical = detect_linux_physical_cores()
            if physical is None:
                notes.append("Linux physical CPU probe unavailable")
        elif os_name == "windows":
            notes.append("Windows physical CPU probe unavailable")
    except Exception:
        notes.append("CPU probe failed")
    return physical, logical, tuple(notes)


def hardware_profile(os_name: str, arch_name: str) -> HardwareProfile:
    memory_bytes, memory_notes = detect_total_memory_bytes(os_name)
    physical_cpu, logical_cpu, cpu_notes = detect_cpu_counts(os_name)
    notes = list(memory_notes + cpu_notes)
    high_confidence = memory_bytes is not None and logical_cpu is not None and (physical_cpu is not None or os_name == "windows")
    return HardwareProfile(
        os_name=os_name,
        arch_name=arch_name,
        wsl=detect_wsl(os_name),
        nvidia=detect_nvidia(),
        memory_bytes=memory_bytes,
        memory_gb=round(memory_bytes / (1024**3), 1) if memory_bytes else None,
        physical_cpu=physical_cpu,
        logical_cpu=logical_cpu,
        confidence="high" if high_confidence else "partial",
        notes=tuple(dict.fromkeys(notes)),
    )


def default_state_dir(os_name: str) -> Path:
    if os.environ.get("WHISPER_HOME"):
        return Path(os.environ["WHISPER_HOME"]).expanduser()
    if os_name == "macos":
        return Path.home() / "Library" / "Application Support" / APP_NAME
    if os_name == "windows":
        return Path(os.environ.get("APPDATA", str(Path.home() / "AppData" / "Roaming"))) / APP_NAME
    if os.environ.get("XDG_DATA_HOME"):
        return Path(os.environ["XDG_DATA_HOME"]).expanduser() / APP_NAME
    return Path.home() / ".local" / "share" / APP_NAME


def directory_size(path: Path) -> int:
    if not path.exists():
        return 0
    total = 0
    for item in path.rglob("*"):
        try:
            if item.is_file() or item.is_symlink():
                total += item.stat().st_size
        except OSError:
            continue
    return total


def format_bytes(size: int) -> str:
    value = float(size)
    for unit in ("B", "KB", "MB", "GB", "TB"):
        if value < 1024 or unit == "TB":
            return f"{value:.1f} {unit}" if unit != "B" else f"{int(value)} B"
        value /= 1024
    return f"{value:.1f} TB"


