def python_version(python_bin: Path) -> str:
    return subprocess.check_output(
        [str(python_bin), "-c", "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}')"],
        text=True,
    ).strip()


def python_major_minor(version: str) -> str:
    return ".".join(version.split(".")[:2])


def validate_python_path(python_value: str) -> Path:
    candidate = Path(python_value).expanduser()
    if not candidate.is_absolute():
        resolved = shutil.which(python_value)
        if not resolved:
            die(f"Unable to find requested Python interpreter: {python_value}")
        candidate = Path(resolved)
    candidate = candidate.resolve()
    if not candidate.exists() or not os.access(candidate, os.X_OK):
        die(f"Requested Python interpreter is not executable: {candidate}")
    return candidate


def mlx_runtime_selection_cache_path(base_state_dir: Path) -> Path:
    return base_state_dir / MLX_RUNTIME_SELECTION_FILE


def load_mlx_runtime_selection(base_state_dir: Path) -> dict[str, str] | None:
    cache_path = mlx_runtime_selection_cache_path(base_state_dir)
    if not cache_path.exists():
        return None
    try:
        data = json.loads(cache_path.read_text(encoding="utf-8"))
    except Exception:
        return None
    python_path = data.get("python_path")
    python_version_value = data.get("python_version")
    if not python_path or not python_version_value:
        return None
    candidate = Path(python_path).expanduser()
    if not candidate.exists():
        return None
    try:
        if python_version(candidate.resolve()) != python_version_value:
            return None
    except Exception:
        return None
    return {"python_path": str(candidate.resolve()), "python_version": python_version_value}


def save_mlx_runtime_selection(base_state_dir: Path, python_bin: Path, version: str) -> None:
    cache_path = mlx_runtime_selection_cache_path(base_state_dir)
    cache_path.parent.mkdir(parents=True, exist_ok=True)
    cache_path.write_text(
        json.dumps({"python_path": str(python_bin.resolve()), "python_version": version}, indent=2) + "\n",
        encoding="utf-8",
    )


def clear_mlx_runtime_selection(base_state_dir: Path) -> None:
    cache_path = mlx_runtime_selection_cache_path(base_state_dir)
    try:
        cache_path.unlink()
    except FileNotFoundError:
        pass


def discover_mlx_python_candidates(launcher_python: Path) -> list[Path]:
    candidates: list[Path] = []
    seen: set[Path] = set()
    for version in MLX_PREFERRED_PYTHONS:
        resolved = shutil.which(f"python{version}")
        if resolved:
            path = Path(resolved).resolve()
            if path not in seen:
                seen.add(path)
                candidates.append(path)
    launcher_resolved = launcher_python.resolve()
    if launcher_resolved not in seen:
        candidates.append(launcher_resolved)
    return candidates


def probe_mlx_python_candidate(python_bin: Path) -> bool:
    try:
        with tempfile.TemporaryDirectory(prefix="whisper-mlx-probe-") as tmp_dir:
            venv_dir = Path(tmp_dir) / "venv"
            if subprocess.run([str(python_bin), "-m", "venv", str(venv_dir)], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode != 0:
                return False
            probe_python = runtime_python(venv_dir, detect_os())
            commands = [
                [str(probe_python), "-m", "pip", "install", "--disable-pip-version-check", "--quiet", "--upgrade", *PIP_BOOTSTRAP_PACKAGES],
                [str(probe_python), "-m", "pip", "install", "--disable-pip-version-check", "--quiet", "--upgrade", *backend_packages("mlx")],
                [str(probe_python), "-c", "import mlx_whisper"],
            ]
            for command in commands:
                if subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False).returncode != 0:
                    return False
            return True
    except Exception:
        return False


def choose_runtime_builder_python(
    args: argparse.Namespace,
    os_name: str,
    arch_name: str,
    selected_backend: str,
    pkg_manager: str,
    base_state_dir: Path,
) -> tuple[Path, str, bool, str]:
    explicit_python = args.python or os.environ.get("WHISPER_RUNTIME_PYTHON", "")
    if explicit_python:
        builder_python = validate_python_path(explicit_python)
        return builder_python, python_version(builder_python), selected_backend == "mlx" and is_apple_silicon(os_name, arch_name), "explicit"
    stable_policy_active = selected_backend == "mlx" and is_apple_silicon(os_name, arch_name)
    if not stable_policy_active:
        launcher_python = Path(sys.executable).resolve()
        return launcher_python, python_version(launcher_python), False, "launcher"
    cached = None if args.update else load_mlx_runtime_selection(base_state_dir)
    if cached:
        cached_python = Path(cached["python_path"]).resolve()
        return cached_python, cached["python_version"], True, "cached"
    launcher_python = Path(sys.executable).resolve()
    candidates = discover_mlx_python_candidates(launcher_python)
    should_probe = not args.doctor and not getattr(args, "dry_run", False) and bool(args.targets or args.setup_only or args.update or args.stable_mlx_python)
    if should_probe:
        for candidate in candidates:
            if probe_mlx_python_candidate(candidate):
                version = python_version(candidate)
                save_mlx_runtime_selection(base_state_dir, candidate, version)
                return candidate, version, True, "probed"
    if candidates:
        preferred_python = candidates[0]
        return preferred_python, python_version(preferred_python), True, "preferred"
    help_suffix = "brew install python@3.12" if pkg_manager == "brew" else "install Python 3.12 or Python 3.13"
    die(
        "No suitable MLX runtime Python could be found. "
        f"Install one and rerun. Suggested command: {help_suffix}"
    )


def runtime_state_dir(
    base_state_dir: Path, *, selected_backend: str, stable_mlx_python: bool, runtime_builder_version: str
) -> Path:
    if not stable_mlx_python or selected_backend != "mlx":
        return base_state_dir
    major_minor = python_major_minor(runtime_builder_version)
    preferred = base_state_dir.parent / f"{base_state_dir.name}-mlx-py{major_minor}"
    legacy = base_state_dir.parent / f"{base_state_dir.name}-mlx-stable-py{major_minor}"
    if not preferred.exists() and legacy.exists():
        return legacy
    return preferred


def is_apple_silicon(os_name: str, arch_name: str) -> bool:
    return os_name == "macos" and arch_name == "arm64"


def normalize_backend_name(name: str) -> str:
    if name == "faster_whisper":
        return "faster-whisper"
    if name not in {"auto", "mlx", "faster-whisper"}:
        die("--backend must be auto, mlx, or faster-whisper")
    return name


def backend_supported_on_host(backend: str, os_name: str, arch_name: str) -> bool:
    if backend == "mlx":
        return is_apple_silicon(os_name, arch_name)
    return backend == "faster-whisper"


def choose_default_backend(profile: HardwareProfile) -> str:
    if is_apple_silicon(profile.os_name, profile.arch_name):
        return "mlx"
    return "faster-whisper"


def choose_fallback_backend(primary: str, profile: HardwareProfile, auto_backend: bool) -> str:
    if auto_backend and primary == "mlx" and is_apple_silicon(profile.os_name, profile.arch_name):
        return "faster-whisper"
    return "none"


def choose_default_device(backend: str, profile: HardwareProfile) -> str:
    if backend == "mlx":
        return "apple"
    if profile.os_name in {"linux", "windows"} and profile.nvidia:
        return "cuda"
    return "cpu"


def choose_default_compute_type(backend: str, device: str) -> str:
    if backend == "mlx":
        return "mlx"
    return "int8_float16" if device == "cuda" else "int8"


def choose_default_model(backend: str, device: str, profile: HardwareProfile) -> tuple[str, str]:
    memory_gb = profile.memory_gb
    logical_cpu = profile.logical_cpu
    if backend == "mlx":
        if memory_gb is None:
            return "small", "Apple Silicon MLX defaulted conservatively because RAM was not readable."
        if memory_gb < 8:
            return "base", "Apple Silicon lower-memory tier; defaulting to base."
        if memory_gb < 16:
            return "small", "Apple Silicon mid-memory tier; defaulting to small."
        return "medium", "Apple Silicon higher-memory tier; defaulting to medium."
    if device == "cuda":
        if profile.confidence != "high":
            return "small", "NVIDIA CUDA detected, but hardware details were partial; defaulting to small."
        if memory_gb and memory_gb >= 16 and logical_cpu and logical_cpu >= 8:
            return "medium", "CUDA available on stronger hardware; defaulting to medium."
        return "small", "CUDA available; defaulting to small for balanced speed and accuracy."
    if memory_gb is None or logical_cpu is None:
        return "base", "Hardware detection was partial; defaulting conservatively to base."
    if memory_gb >= 16 and logical_cpu >= 8:
        return "small", "CPU path on stronger hardware; defaulting to small."
    return "base", "CPU path on modest hardware; defaulting to base."


