    "subtitle_style": set(SUBTITLE_STYLE_PRESETS),
}


def normalize_config_key(key: str) -> str:
    return key.strip().replace("-", "_")


def coerce_config_value(key: str, value: object, path: Path) -> object:
    expected_type = CONFIG_VALUE_TYPES[key]
    if expected_type is bool:
        if not isinstance(value, bool):
            raise ValueError(f"{key} must be true or false")
        return value
    if expected_type is int:
        if isinstance(value, bool) or not isinstance(value, int):
            raise ValueError(f"{key} must be an integer")
        if key == "jobs" and value < 1:
            raise ValueError("jobs must be at least 1")
        return value
    if expected_type is str:
        if not isinstance(value, str):
            raise ValueError(f"{key} must be a string")
        if key in CONFIG_CHOICES and value not in CONFIG_CHOICES[key]:
            choices = ", ".join(sorted(CONFIG_CHOICES[key]))
            raise ValueError(f"{key} must be one of: {choices}")
        return value
    if expected_type is list:
        if isinstance(value, str):
            return [value]
        if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
            raise ValueError(f"{key} must be a string or list of strings")
        return list(value)
    raise ValueError(f"{key} has an unsupported config type in {path}")


def load_whisper_config(path: Path) -> dict[str, object]:
    if tomllib is None:
        raise ValueError("TOML config requires Python 3.11 or newer")
    try:
        payload = tomllib.loads(path.read_text(encoding="utf-8"))
    except Exception as exc:
        raise ValueError(str(exc)) from exc
    if not isinstance(payload, dict):
        raise ValueError("config must be a TOML table")
    raw_settings: dict[str, object] = {}
    for key, value in payload.items():
        if key == "defaults":
            continue
        normalized_key = normalize_config_key(key)
        if isinstance(value, dict):
            raise ValueError(f"unknown config section [{key}]")
        raw_settings[normalized_key] = value
    defaults = payload.get("defaults")
    if defaults is not None:
        if not isinstance(defaults, dict):
            raise ValueError("[defaults] must be a TOML table")
        for key, value in defaults.items():
            raw_settings[normalize_config_key(key)] = value
    unknown_keys = [key for key in raw_settings if key not in CONFIG_VALUE_TYPES]
    if unknown_keys:
        names = ", ".join(sorted(unknown_keys))
        raise ValueError(f"unknown config key(s): {names}")
    return {key: coerce_config_value(key, value, path) for key, value in raw_settings.items()}


def config_search_base_for_target(target: str) -> Path:
    path = Path(target).expanduser()
    if path.exists():
        return path if path.is_dir() else path.parent
    return path.parent if path.suffix else path


def find_project_config_from_base(base: Path) -> Path | None:
    search_base = base.expanduser()
    if not search_base.is_absolute():
        search_base = Path.cwd() / search_base
    try:
        search_base = search_base.resolve()
    except OSError:
        search_base = search_base.absolute()
    for directory in (search_base, *search_base.parents):
        candidate = directory / PROJECT_CONFIG_FILENAME
        if candidate.is_file():
            return candidate
    return None


def discover_project_config_path(targets: list[str]) -> Path | None:
    bases = [config_search_base_for_target(target) for target in targets] or [Path.cwd()]
    discovered: list[Path] = []
    for base in bases:
        config_path = find_project_config_from_base(base)
        if config_path and config_path not in discovered:
            discovered.append(config_path)
    if not discovered and targets:
        fallback = find_project_config_from_base(Path.cwd())
        if fallback:
            discovered.append(fallback)
    if len(discovered) > 1:
        ignored = ", ".join(str(path) for path in discovered[1:])
        warn(f"Multiple project whisper configs found; using {discovered[0]} and ignoring {ignored}.")
    return discovered[0] if discovered else None


def whisper_config_sources(targets: list[str]) -> tuple[Path, ...]:
    sources: list[Path] = []
    if GLOBAL_CONFIG_PATH.is_file():
        sources.append(GLOBAL_CONFIG_PATH)
    project_config = discover_project_config_path(targets)
    if project_config and project_config not in sources:
        sources.append(project_config)
    return tuple(sources)


def merge_config_sources(paths: tuple[Path, ...]) -> dict[str, object]:
    merged: dict[str, object] = {}
    for path in paths:
        try:
            settings = load_whisper_config(path)
        except Exception as exc:
            die(f"Invalid whisper config {path}: {exc}")
        for key, value in settings.items():
            if key == "glossary":
                merged["glossary"] = list(value)
            elif key == "extra_glossary":
                merged["glossary"] = [*list(merged.get("glossary", [])), *list(value)]
            elif key == "suppress_phrases":
                merged["suppress_phrases"] = list(value)
            elif key == "extra_suppress_phrases":
                merged["suppress_phrases"] = [*list(merged.get("suppress_phrases", [])), *list(value)]
            else:
                merged[key] = value
    return merged


def cli_provided_dests(parser: argparse.ArgumentParser, argv: list[str]) -> set[str]:
    option_dests: dict[str, str] = {}
    for action in parser._actions:
        if not action.dest or action.dest == argparse.SUPPRESS:
            continue
        for option in action.option_strings:
            option_dests[option] = action.dest
    provided: set[str] = set()
    for token in argv:
        if token == "--":
            break
        if token.startswith("--"):
            option = token.split("=", 1)[0]
            dest = option_dests.get(option)
            if dest:
                provided.add(dest)
            continue
        if token.startswith("-") and token != "-":
            if token in option_dests:
                provided.add(option_dests[token])
                continue
            short_option = token[:2]
            if short_option in option_dests:
                provided.add(option_dests[short_option])
    return provided


def parse_args_with_config(parser: argparse.ArgumentParser, argv: list[str] | None = None) -> argparse.Namespace:
    arg_list = list(sys.argv[1:] if argv is None else argv)
    args = parser.parse_args(arg_list)
    args._config_sources = ()
    if args.help:
        return args
    config_sources = whisper_config_sources(list(args.targets or []))
    config_values = merge_config_sources(config_sources)
    provided_dests = cli_provided_dests(parser, arg_list)
    for dest, value in config_values.items():
        if dest not in provided_dests:
            setattr(args, dest, value)
    args._config_sources = config_sources
    return args


