def ensure_system_prereqs(args: argparse.Namespace, os_name: str, pkg_mgr: str) -> None:
    if os_name == "unknown":
        die(f"unsupported OS: {sys.platform}")
    embed_requested = args.embed or args.embed_file is not None
    if args.embed and args.embed_file is not None:
        warn("--embed is ignored when --embed-file is set.")
    transcript_only = getattr(args, "transcript_only", False)
    if transcript_only:
        ignored_flags = [
            flag
            for enabled, flag in (
                (args.ass, "--ass"),
                (args.karaoke, "--karaoke"),
                (args.embed or args.embed_file is not None, "--embed/--embed-file"),
                (args.in_place, "--in-place"),
                (args.burn, "--burn"),
            )
            if enabled
        ]
        if ignored_flags:
            warn(f"{', '.join(ignored_flags)} ignored because --transcript-only does not write subtitles or video outputs.")
    effective_embed_requested = embed_requested and not transcript_only
    effective_burn_requested = args.burn and not transcript_only
    if getattr(args, "transcript", False) and args.embed_file is not None and not transcript_only:
        warn("--transcript is ignored with --embed-file because that mode does not transcribe.")
    if getattr(args, "speaker_labels", False) and args.embed_file is not None and not transcript_only:
        warn("--speaker-labels is ignored with --embed-file because that mode does not transcribe.")
    if not shutil.which("ffmpeg") and (effective_burn_requested or effective_embed_requested):
        if not getattr(args, "dry_run", False):
            print_install_help(os_name, pkg_mgr)
            required_flags = " and ".join(
                flag
                for enabled, flag in (
                    (effective_burn_requested, "--burn"),
                    (effective_embed_requested, "--embed/--embed-file"),
                )
                if enabled
            )
            die(f"ffmpeg is required for {required_flags}.")
    if args.backend == "faster-whisper":
        mlx_flags_used = (
            args.mlx_word_timestamps != "auto" or args.mlx_output_format != "auto" or args.mlx_model_default != "wrapper"
        )
        if mlx_flags_used:
            warn("MLX comparison flags are ignored when --backend=faster-whisper.")
    if args.in_place and not embed_requested:
        warn("--in-place is ignored unless --embed or --embed-file is set.")
    if args.burn_vcodec != "auto" and not args.burn:
        warn("--burn-vcodec is ignored unless --burn is set.")


def build_runtime_plan(args: argparse.Namespace) -> RuntimePlan:
    os_name = detect_os()
    arch_name = detect_arch()
    pkg_manager = detect_pkg_manager()
    ensure_system_prereqs(args, os_name, pkg_manager)
    profile = hardware_profile(os_name, arch_name)
    launcher_python = Path(sys.executable).resolve()
    base_state_dir = Path(args.state_dir).expanduser() if args.state_dir else default_state_dir(os_name)
    backend_requested = normalize_backend_name(args.backend)
    auto_backend = backend_requested == "auto"
    selected_backend = choose_default_backend(profile) if auto_backend else backend_requested
    if not backend_supported_on_host(selected_backend, os_name, arch_name):
        die(f"backend '{selected_backend}' is not supported on {os_name}/{arch_name}")
    runtime_builder_python, runtime_builder_version, stable_mlx_python, runtime_selection_source = choose_runtime_builder_python(
        args, os_name, arch_name, selected_backend, pkg_manager, base_state_dir
    )
    state_dir = runtime_state_dir(
        base_state_dir,
        selected_backend=selected_backend,
        stable_mlx_python=stable_mlx_python,
        runtime_builder_version=runtime_builder_version,
    )
    venv_dir = state_dir / "venv"
    venv_python = runtime_python(venv_dir, os_name)
    packages_dir = site_packages_dir(venv_dir, os_name, runtime_builder_python)
    selected_device = choose_default_device(selected_backend, profile) if args.device == "auto" else args.device
    selected_compute = choose_default_compute_type(selected_backend, selected_device) if args.compute_type == "auto" else args.compute_type
    recommended_model, model_reason = choose_default_model(selected_backend, selected_device, profile)
    selected_model = args.model or recommended_model
    if args.mlx_model_default == "official" and selected_backend == "mlx" and not args.model:
        selected_model = "tiny"
        model_reason = "MLX diagnostic mode; using official-style tiny default because --model was omitted."
    if args.model:
        model_reason = f"Explicit --model override: {args.model}"
    fallback_backend = choose_fallback_backend(selected_backend, profile, auto_backend)
    fallback_device = choose_default_device(fallback_backend, profile) if fallback_backend != "none" else "none"
    fallback_compute = choose_default_compute_type(fallback_backend, fallback_device) if fallback_backend != "none" else "none"
    installed_pkg_tuple = installed_packages(venv_python)
    installed_backend_tuple = installed_backends(venv_python)
    return RuntimePlan(
        script_path=Path(__file__).resolve(),
        os_name=os_name,
        arch_name=arch_name,
        pkg_manager=pkg_manager,
        launcher_python=launcher_python,
        base_state_dir=base_state_dir,
        state_dir=state_dir,
        venv_dir=venv_dir,
        venv_python=venv_python,
        runtime_builder_python=runtime_builder_python,
        runtime_builder_version=runtime_builder_version,
        runtime_selection_source=runtime_selection_source,
        packages_dir=packages_dir,
        backend_requested=backend_requested,
        auto_backend=auto_backend,
        selected_backend=selected_backend,
        selected_device=selected_device,
        selected_compute=selected_compute,
        selected_model=selected_model,
        model_reason=model_reason,
        fallback_backend=fallback_backend,
        fallback_device=fallback_device,
        fallback_compute=fallback_compute,
        stable_mlx_python=stable_mlx_python,
        profile=profile,
        installed_packages=installed_pkg_tuple,
        installed_backends=installed_backend_tuple,
    )


