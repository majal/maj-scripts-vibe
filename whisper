            "WHISPER_STATE_DIR": str(plan.state_dir),
            "WHISPER_AUTO_BACKEND": "1" if plan.auto_backend else "0",
            "WHISPER_STABLE_MLX_PYTHON": "1" if plan.stable_mlx_python else "0",
            "WHISPER_MLX_WORD_TIMESTAMPS": args.mlx_word_timestamps,
            "WHISPER_MLX_OUTPUT_FORMAT": args.mlx_output_format,
            "WHISPER_MLX_MODEL_DEFAULT": args.mlx_model_default,
            "WHISPER_RUNTIME_SELECTION_SOURCE": plan.runtime_selection_source,
            "HF_HUB_DISABLE_PROGRESS_BARS": "1",
        }
    )
    return env


def launch_managed_runtime(args: argparse.Namespace, plan: RuntimePlan) -> int:
    env = os.environ.copy()
    env.update(build_runtime_processing_env(args, plan))
    if args.embed_file is not None and not args.transcript_only:
        info(f"OS: {plan.os_name} | arch: {plan.arch_name} | mode: embed-file")
    else:
        info(f"OS: {plan.os_name} | arch: {plan.arch_name} | backend: {plan.selected_backend} | model: {plan.selected_model}")
    info(f"Launcher Python: {plan.launcher_python}")
    info(f"Runtime builder: {plan.runtime_builder_python} ({plan.runtime_builder_version})")
    info(f"Runtime selection: {plan.runtime_selection_source}")
    if args.embed_file is None or args.transcript_only:
        info(f"Fallback backend: {plan.fallback_backend} | device: {plan.fallback_device}")
    info(f"Using runtime: {plan.state_dir}")
    say("", err=True)
    result = subprocess.run([str(plan.venv_python), str(plan.script_path)], env=env, check=False)
    return result.returncode


def outer_main() -> int:
    parser = build_parser()
    args = parse_args_with_config(parser)
    if args.help:
        print_help()
        return 0
    if args.json_output and not (args.doctor or args.dry_run):
        die("--json is only supported with --doctor or --plan/--dry-run")
    if args.jobs < 1:
        die("--jobs must be at least 1")
    runtime_management_requested = (
        args.doctor
        or args.clean
        or args.clean_speaker_labels
        or args.reinstall
        or args.setup_only
        or args.update
    )
    if args.embed_file is not None and not args.transcript_only and not runtime_management_requested and not args.dry_run:
        if not args.targets:
            print_help()
            return 1
        ensure_system_prereqs(args, detect_os(), detect_pkg_manager())
        return run_embed_file_mode(
            [Path(target).expanduser() for target in args.targets],
            build_processing_env(args),
            recursive=args.recursive,
            jobs=args.jobs,
        )
    plan = build_runtime_plan(args)
    if args.doctor:
        if args.json_output:
            print_doctor_json(plan, args)
        else:
            print_doctor(plan, args)
        return 0
    if args.dry_run:
        if args.json_output:
            print_dry_run_json(args, plan)
        else:
            print_dry_run(args, plan)
        return 0
    if args.clean:
        if not plan.state_dir.exists():
            success(f"Nothing to clean. State dir does not exist: {plan.state_dir}")
            return 0
        maybe_remove_runtime(plan, assume_yes=args.yes)
        return 0
    if args.clean_speaker_labels:
        clean_speaker_labels(plan, assume_yes=args.yes)
        return 0
    if args.reinstall and plan.venv_dir.exists():
        if not confirm(f"Remove and rebuild the runtime in {plan.state_dir}?", assume_yes=args.yes):
            die("reinstall cancelled")
        shutil.rmtree(plan.venv_dir)
        success("Removed old runtime.")
        plan = build_runtime_plan(args)
    if args.targets and (args.embed_file is None or args.transcript_only) and not (args.setup_only or args.update or args.reinstall):
        env = build_runtime_processing_env(args, plan)
        files = discover_planned_files(args)
        if can_finish_without_transcription(files, env, plan.selected_backend):
            print("♻ Existing transcript/subtitle outputs are enough; no transcription backend needed.", file=sys.stderr)
            process_files(files, env, plan.selected_backend, args.jobs)
            return 0
    selected_backend_required = bool((args.targets and (args.embed_file is None or args.transcript_only)) or args.setup_only or args.update or not plan.venv_python.exists())
    speaker_labels_required = bool(
        args.speaker_labels
        and ((args.targets and (args.embed_file is None or args.transcript_only)) or args.setup_only or args.update)
    )
    speaker_label_install_needed = speaker_labels_required and (args.update or "speaker-labels" not in plan.installed_packages)
    install_needed = (
        not plan.venv_python.exists()
        or "webrtcvad" not in plan.installed_packages
        or (selected_backend_required and plan.selected_backend not in plan.installed_backends)
        or speaker_label_install_needed
        or args.update
    )
    install_now = packages_to_install_now(
        plan,
        update=args.update,
        selected_backend_required=selected_backend_required,
        speaker_labels_required=speaker_labels_required,
    )
    install_later = packages_for_possible_fallback(plan)
    if install_needed and not os.environ.get(MANAGED_ENV_FLAG):
        print_install_summary(plan, install_now, install_later)
        say("")
        say("You can accept the defaults, modify flags and rerun, or exit without changes.")
        say("Helpful commands:")
        say(f"  {MAGENTA}{Path(sys.argv[0]).name} --doctor{RESET}")
        say(f"  {MAGENTA}{Path(sys.argv[0]).name} --setup-only{RESET}")
        say("")
        if speaker_label_install_needed:
            print_speaker_label_install_warning(plan)
            if not confirm("Install optional speaker-label dependencies now?", assume_yes=args.yes):
                say("")
                say("No changes made. Speaker labels are still available later with --speaker-labels.")
                return 0
            action = "yes"
        else:
            action = prompt_install_action(args.yes)
        if action == "modify":
            print_modify_examples()
            return 0
        if action == "exit":
            say("")
            say("No changes made. You're all set to come back to this later.")
            return 0
    if install_needed:
        plan = ensure_runtime(
            plan,
            update=args.update,
            selected_backend_required=selected_backend_required,
            speaker_labels_required=speaker_labels_required,
        )
    if args.setup_only:
        success(f"Runtime is ready in {plan.state_dir}")
        success(f"Backend plan: primary={plan.selected_backend}, fallback={plan.fallback_backend}")
        return 0
    if args.update and not args.targets:
        success(f"Runtime updated in {plan.state_dir}")
        success(f"Installed packages: {', '.join(plan.installed_packages)}")
        return 0
    if not args.targets:
        if install_needed:
            success(f"Runtime is ready in {plan.state_dir}")
            success(f"Installed packages: {', '.join(plan.installed_packages)}")
            say("")
            say(
                f"You're ready to go. Run {MAGENTA}{Path(sys.argv[0]).name} /path/to/file.mp4{RESET} "
                f"or {MAGENTA}{Path(sys.argv[0]).name} *.mp4{RESET} to start transcribing."
            )
            say(f"On Windows, you can also run {MAGENTA}py {Path(sys.argv[0]).name} /path/to/file.mp4{RESET}.")
            return 0
        print_help()
        return 1
    return launch_managed_runtime(args, plan)


if __name__ == "__main__":
    if os.environ.get(MANAGED_ENV_FLAG) == "1":
        raise SystemExit(managed_main())
    raise SystemExit(outer_main())
