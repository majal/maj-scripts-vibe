def build_bible_book_alias_lookup() -> tuple[dict[tuple[str, ...], str], tuple[int, ...]]:
    alias_lookup: dict[tuple[str, ...], str] = {}
    for canonical, aliases in BIBLE_BOOK_BASE_ALIASES.items():
        for alias in aliases:
            alias_lookup[alias] = canonical
    for book_info in BIBLE_NUMBERED_BOOK_ALIASES.values():
        base_aliases = book_info["aliases"]
        for number, prefixes in BIBLE_NUMBER_PREFIX_ALIASES.items():
            canonical = book_info.get(number)
            if not canonical:
                continue
            for prefix in prefixes:
                for base_alias in base_aliases:
                    alias_lookup[prefix + base_alias] = canonical
    alias_lengths = tuple(sorted({len(alias) for alias in alias_lookup}, reverse=True))
    return alias_lookup, alias_lengths


