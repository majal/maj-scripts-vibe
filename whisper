def subtitle_item_text(item: str | dict[str, float | str]) -> str:
    if isinstance(item, str):
        return item
    return normalized_text(str(item.get("word", "")))


def subtitle_boundary_token(text: str) -> str:
    return text.strip().lstrip("\"'“‘([{<").rstrip("\"'”’)]}>")


def subtitle_token_starts_upper(text: str) -> bool:
    for char in text:
        if char.isalpha():
            return char.isupper()
    return False


def subtitle_is_initial(token: str) -> bool:
    return SUBTITLE_INITIAL_RE.fullmatch(token) is not None


def subtitle_is_initialism(token: str) -> bool:
    return SUBTITLE_INITIALISM_RE.fullmatch(token) is not None


def subtitle_is_protected_abbreviation(token: str) -> bool:
    lowered = token.lower()
    return (
        lowered in SUBTITLE_PROTECTED_ABBREVIATIONS
        or subtitle_is_initial(token)
        or subtitle_is_initialism(token)
    )


def subtitle_boundary_gap(left_item: str | dict[str, float | str], right_item: str | dict[str, float | str]) -> float | None:
    if not isinstance(left_item, dict) or not isinstance(right_item, dict):
        return None
    return max(0.0, float(right_item["start"]) - float(left_item["end"]))


def subtitle_boundary_locked(left_item: str | dict[str, float | str], right_item: str | dict[str, float | str]) -> bool:
    left_token = subtitle_boundary_token(subtitle_item_text(left_item))
    right_token = subtitle_boundary_token(subtitle_item_text(right_item))
    if not left_token or not right_token:
        return False
    lowered = left_token.lower()
    if lowered in SUBTITLE_HONORIFIC_ABBREVIATIONS and subtitle_token_starts_upper(right_token):
        return True
    if subtitle_is_initial(left_token) and subtitle_token_starts_upper(right_token):
        return True
    return False


def subtitle_boundary_score_adjustment(left_item: str | dict[str, float | str], right_item: str | dict[str, float | str]) -> int:
    left_token = subtitle_boundary_token(subtitle_item_text(left_item))
    right_token = subtitle_boundary_token(subtitle_item_text(right_item))
    if not left_token or not right_token:
        return 0
    gap = subtitle_boundary_gap(left_item, right_item)
    protected_abbreviation = subtitle_is_protected_abbreviation(left_token)
    adjustment = 0
    if gap is not None:
        if gap >= SUBTITLE_STRONG_PAUSE_SECONDS:
            adjustment -= 8
        elif gap >= SUBTITLE_MEDIUM_PAUSE_SECONDS:
            adjustment -= 4
        elif gap <= SUBTITLE_TIGHT_JOIN_SECONDS:
            adjustment += 3
    if left_token.endswith((".", "!", "?")):
        if protected_abbreviation:
            adjustment += 4
        else:
            adjustment -= 6
    elif left_token.endswith((",", ";", ":")):
        adjustment -= 3
    if protected_abbreviation and gap is not None and gap < SUBTITLE_MEDIUM_PAUSE_SECONDS:
        adjustment += 3
    if subtitle_is_initialism(left_token) and gap is None:
        adjustment += 2
    return adjustment


def iter_speech_trim_frames(media_path: Path):
    if not shutil.which("ffmpeg"):
        warn_once(
            "speech-trim-missing-ffmpeg",
            "ffmpeg is not available, so default speech-onset subtitle trimming is being skipped. Install ffmpeg or use --no-speech-trim to silence this warning.",
        )
        return
    frame_size = SUBTITLE_SPEECH_TRIM_SAMPLE_RATE * 2 * SUBTITLE_SPEECH_TRIM_FRAME_MS // 1000
    command = [
        "ffmpeg",
        "-v",
        "error",
        "-i",
        str(media_path),
        "-vn",
        "-ac",
        "1",
        "-ar",
        str(SUBTITLE_SPEECH_TRIM_SAMPLE_RATE),
        "-af",
        "highpass=f=120,lowpass=f=3800",
        "-f",
        "s16le",
        "-",
    ]
    process = subprocess.Popen(command, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
    if process.stdout is None:
        process.kill()
        process.wait()
        return
    timestamp = 0.0
    try:
        while True:
            frame = process.stdout.read(frame_size)
            if len(frame) < frame_size:
                break
            yield timestamp, frame
            timestamp += SUBTITLE_SPEECH_TRIM_FRAME_MS / 1000.0
    finally:
        if process.stdout:
            process.stdout.close()
        returncode = process.wait()
        if returncode != 0:
            raise RuntimeError(f"ffmpeg audio analysis failed for {media_path.name}")


def merge_speech_intervals(intervals: list[tuple[float, float]]) -> list[tuple[float, float]]:
    merged: list[tuple[float, float]] = []
    for start, end in intervals:
        if end - start < SUBTITLE_SPEECH_TRIM_MIN_SEGMENT_SECONDS:
            continue
        if not merged:
            merged.append((start, end))
            continue
        prev_start, prev_end = merged[-1]
        if start - prev_end <= SUBTITLE_SPEECH_TRIM_MERGE_GAP_SECONDS:
            merged[-1] = (prev_start, max(prev_end, end))
        else:
            merged.append((start, end))
    return merged


def detect_speech_intervals(media_path: Path) -> list[tuple[float, float]] | None:
    try:
        import webrtcvad
    except ModuleNotFoundError:
        warn_once(
            "speech-trim-missing-webrtcvad",
            "Speech-onset trimming support is unavailable in this runtime, so subtitle timing is falling back to backend timestamps.",
        )
        return None
    try:
        vad = webrtcvad.Vad(3)
        padding_frames = max(1, SUBTITLE_SPEECH_TRIM_PADDING_MS // SUBTITLE_SPEECH_TRIM_FRAME_MS)
        ring_buffer: deque[tuple[float, bool]] = deque(maxlen=padding_frames)
        speech_intervals: list[tuple[float, float]] = []
        triggered = False
        segment_start = 0.0
        last_frame_time = 0.0
        frame_duration = SUBTITLE_SPEECH_TRIM_FRAME_MS / 1000.0
        for timestamp, frame in iter_speech_trim_frames(media_path):
            is_speech = vad.is_speech(frame, SUBTITLE_SPEECH_TRIM_SAMPLE_RATE)
            last_frame_time = timestamp
            if not triggered:
                ring_buffer.append((timestamp, is_speech))
                voiced_frames = sum(1 for _frame_time, voiced in ring_buffer if voiced)
                if len(ring_buffer) == padding_frames and voiced_frames >= max(1, int(padding_frames * SUBTITLE_SPEECH_TRIM_TRIGGER_RATIO)):
                    triggered = True
                    segment_start = ring_buffer[0][0]
                    ring_buffer.clear()
            else:
                ring_buffer.append((timestamp, is_speech))
                unvoiced_frames = sum(1 for _frame_time, voiced in ring_buffer if not voiced)
                if len(ring_buffer) == padding_frames and unvoiced_frames >= max(1, int(padding_frames * SUBTITLE_SPEECH_TRIM_TRIGGER_RATIO)):
                    speech_intervals.append((segment_start, ring_buffer[0][0] + frame_duration))
                    triggered = False
                    ring_buffer.clear()
        if triggered:
            speech_intervals.append((segment_start, last_frame_time + frame_duration))
        return merge_speech_intervals(speech_intervals)
    except RuntimeError as exc:
        warn_once("speech-trim-analysis-failed", str(exc))
        return None
    except Exception as exc:
        warn_once(
            "speech-trim-unexpected-error",
            f"Speech-onset trimming hit an unexpected problem ({exc}); continuing with backend timings.",
        )
        return None


def trim_cue_start_to_speech(start: float, end: float, speech_intervals: list[tuple[float, float]] | None) -> float:
    if not speech_intervals:
        return start
    for speech_start, speech_end in speech_intervals:
        if speech_end <= start:
            continue
        if speech_start <= start < speech_end:
            return start
        if speech_start < end:
            adjusted_start = max(start, speech_start - SUBTITLE_SPEECH_TRIM_PREROLL_SECONDS)
            return min(adjusted_start, max(start, end - 0.01))
        break
    return start


def trim_cue_end_to_speech(start: float, end: float, speech_intervals: list[tuple[float, float]] | None) -> float:
    if not speech_intervals:
        return end
    overlap_end: float | None = None
    for speech_start, speech_end in speech_intervals:
        if speech_end <= start:
            continue
        if speech_start >= end:
            break
        overlap_end = speech_end
    if overlap_end is None:
        return end
    adjusted_end = min(end, overlap_end + SUBTITLE_SPEECH_TRIM_POSTROLL_SECONDS)
    return max(start + 0.01, adjusted_end)


def subtitle_items_width(items: list[str] | list[dict[str, float | str]]) -> int:
    if not items:
        return 0
    return sum(terminal_display_width(subtitle_item_text(item)) for item in items) + max(len(items) - 1, 0)


def subtitle_items_text(items: list[str] | list[dict[str, float | str]]) -> str:
    return " ".join(subtitle_item_text(item) for item in items).strip()


def subtitle_items_text_length(items: list[str] | list[dict[str, float | str]]) -> int:
    return len(subtitle_items_text(items))


def subtitle_cue_duration(cue: SubtitleCue) -> float:
    return max(0.01, cue.end - cue.start)


def subtitle_cue_chars_per_second(cue: SubtitleCue) -> float:
    return subtitle_items_text_length(cue.items) / subtitle_cue_duration(cue)


def subtitle_cue_apply_speech_trim(
    cue: SubtitleCue, speech_intervals: list[tuple[float, float]] | None = None
) -> SubtitleCue:
    cue.start = trim_cue_start_to_speech(cue.start, cue.end, speech_intervals)
    cue.end = trim_cue_end_to_speech(cue.start, cue.end, speech_intervals)
    cue.end = max(cue.end, cue.start + 0.01)
    return cue


def choose_subtitle_cue_split_index(items: list[str] | list[dict[str, float | str]]) -> int | None:
    if len(items) < 2:
        return None
    best_split: int | None = None
    best_score: tuple[int, int] | None = None
    for index in range(1, len(items)):
        left = items[:index]
        right = items[index:]
        if subtitle_boundary_locked(left[-1], right[0]):
            continue
        score = (
            abs(subtitle_items_text_length(left) - subtitle_items_text_length(right))
            + subtitle_boundary_score_adjustment(left[-1], right[0]),
            max(subtitle_items_text_length(left), subtitle_items_text_length(right)),
        )
        if best_score is None or score < best_score:
            best_score = score
            best_split = index
    return best_split


def split_subtitle_cue(cue: SubtitleCue, split_index: int) -> tuple[SubtitleCue, SubtitleCue] | None:
    left_items = cue.items[:split_index]
    right_items = cue.items[split_index:]
    if not left_items or not right_items:
        return None
    if isinstance(left_items[0], dict) and isinstance(right_items[0], dict):
        left_start = float(left_items[0]["start"])
        left_end = max(float(left_items[-1]["end"]), left_start + 0.01)
        right_start = float(right_items[0]["start"])
        right_end = max(float(right_items[-1]["end"]), right_start + 0.01)
        return SubtitleCue(left_start, left_end, left_items), SubtitleCue(right_start, right_end, right_items)
    total_length = max(1, subtitle_items_text_length(cue.items))
    left_ratio = subtitle_items_text_length(left_items) / total_length
    split_time = cue.start + (cue.end - cue.start) * left_ratio
    split_time = min(max(split_time, cue.start + 0.01), cue.end - 0.01)
    return (
        SubtitleCue(cue.start, split_time, left_items),
        SubtitleCue(split_time, cue.end, right_items),
    )


def split_dense_subtitle_cue(
    cue: SubtitleCue,
    *,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
) -> list[SubtitleCue]:
    minimum_split_duration = style.min_cue_duration * 0.6
    if (
        len(cue.items) < 2
        or subtitle_cue_chars_per_second(cue) <= style.max_chars_per_second
        or subtitle_cue_duration(cue) < style.min_cue_duration * 1.5
    ):
        return [cue]
    split_index = choose_subtitle_cue_split_index(cue.items)
    if split_index is None:
        return [cue]
    split_result = split_subtitle_cue(cue, split_index)
    if split_result is None:
        return [cue]
    left, right = split_result
    if subtitle_cue_duration(left) < minimum_split_duration or subtitle_cue_duration(right) < minimum_split_duration:
        return [cue]
    return [*split_dense_subtitle_cue(left, style=style), *split_dense_subtitle_cue(right, style=style)]


def can_merge_subtitle_cues(
    left: SubtitleCue,
    right: SubtitleCue,
    *,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
) -> bool:
    gap = max(0.0, right.start - left.end)
    if gap > style.max_merge_gap:
        return False
    merged = SubtitleCue(left.start, right.end, [*left.items, *right.items])
    if len(chunk_subtitle_items(merged.items, style=style)) != 1:
        return False
    if subtitle_cue_duration(merged) > style.max_merged_cue_duration:
        return False
    return subtitle_cue_chars_per_second(merged) <= style.max_chars_per_second


def merge_short_subtitle_cues(
    cues: list[SubtitleCue],
    *,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
) -> list[SubtitleCue]:
    if len(cues) < 2:
        return cues
    merged: list[SubtitleCue] = []
    index = 0
    while index < len(cues):
        current = cues[index]
        while index + 1 < len(cues):
            next_cue = cues[index + 1]
            if (
                subtitle_cue_duration(current) >= style.min_cue_duration
                and subtitle_cue_duration(next_cue) >= style.min_cue_duration
            ):
                break
            if not can_merge_subtitle_cues(current, next_cue, style=style):
                break
            current = SubtitleCue(current.start, next_cue.end, [*current.items, *next_cue.items])
            index += 1
        merged.append(current)
        index += 1
    return merged


def stretch_short_subtitle_cues(
    cues: list[SubtitleCue],
    segment_end: float,
    *,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
) -> list[SubtitleCue]:
    if not cues:
        return cues
    for index, cue in enumerate(cues):
        minimum_end = cue.start + style.min_cue_duration
        if cue.end >= minimum_end:
            continue
        next_start = cues[index + 1].start if index + 1 < len(cues) else segment_end
        max_end = min(segment_end, next_start - style.min_cue_gap)
        if max_end > cue.end:
            cue.end = min(max_end, minimum_end)
        cue.end = max(cue.end, cue.start + 0.01)
    return cues


def subtitle_cue_line_groups(
    cue: SubtitleCue,
    *,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
) -> list[list[str] | list[dict[str, float | str]]]:
    line_groups, _fits = subtitle_line_groups(cue.items, style=style)
    return line_groups


def subtitle_line_groups(
    items: list[str] | list[dict[str, float | str]],
    *,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
    max_line_width: int | None = None,
) -> tuple[list[list[str] | list[dict[str, float | str]]], bool]:
    line_width = style.max_line_width if max_line_width is None else max_line_width
    if not items:
        return [], True
    if len(items) == 1 or subtitle_items_width(items) <= line_width:
        return [items], True
    best_split: int | None = None
    best_score: tuple[int, int] | None = None
    for index in range(1, len(items)):
        left = items[:index]
        right = items[index:]
        left_width = subtitle_items_width(left)
        right_width = subtitle_items_width(right)
        if left_width > line_width or right_width > line_width:
            continue
        if subtitle_boundary_locked(left[-1], right[0]):
            continue
        score = (
            abs(left_width - right_width) + subtitle_boundary_score_adjustment(left[-1], right[0]),
            max(left_width, right_width),
        )
        if best_score is None or score < best_score:
            best_score = score
            best_split = index
    if best_split is None:
        return [items], False
    return [items[:best_split], items[best_split:]], True


def subtitle_should_force_chunk_split(
    current: list[str] | list[dict[str, float | str]], next_item: str | dict[str, float | str]
) -> bool:
    if not current:
        return False
    left_item = current[-1]
    if subtitle_boundary_locked(left_item, next_item):
        return False
    left_token = subtitle_boundary_token(subtitle_item_text(left_item))
    gap = subtitle_boundary_gap(left_item, next_item)
    current_length = subtitle_items_text_length(current)
    if left_token.endswith((".", "!", "?")) and not subtitle_is_protected_abbreviation(left_token):
        return current_length >= 8
    if gap is not None and gap >= SUBTITLE_STRONG_PAUSE_SECONDS:
        return current_length >= 10
    if gap is not None and gap >= SUBTITLE_MEDIUM_PAUSE_SECONDS and left_token.endswith((",", ";", ":")):
        return current_length >= 18
    return False


def chunk_subtitle_items(
    items: list[str] | list[dict[str, float | str]],
    *,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
    max_line_width: int | None = None,
) -> list[list[str] | list[dict[str, float | str]]]:
    line_width = style.max_line_width if max_line_width is None else max_line_width
    chunks: list[list[str] | list[dict[str, float | str]]] = []
    current: list[str] | list[dict[str, float | str]] = []
    for item in items:
        if current and subtitle_should_force_chunk_split(current, item):
            chunks.append(current)
            current = [item]
            continue
        candidate = [*current, item]
        _line_groups, fits = subtitle_line_groups(candidate, style=style, max_line_width=line_width)
        if current and not fits:
            next_chunk = [item]
            while current and subtitle_boundary_locked(current[-1], next_chunk[0]):
                next_chunk.insert(0, current.pop())
            if current:
                chunks.append(current)
            current = next_chunk
            continue
        current = candidate
    if current:
        chunks.append(current)
    return chunks


def iter_segment_subtitle_cues(
    segment: dict[str, float | str | list[dict[str, float | str]]],
    speech_intervals: list[tuple[float, float]] | None = None,
    *,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
) -> list[tuple[float, float, list[list[str] | list[dict[str, float | str]]]]]:
    words = [
        {"start": float(word["start"]), "end": float(word["end"]), "word": subtitle_item_text(word)}
        for word in segment.get("words", []) or []
        if subtitle_item_text(word)
    ]
    cue_objects: list[SubtitleCue] = []
    if words:
        for chunk in chunk_subtitle_items(words, style=style):
            start = float(chunk[0]["start"])
            end = max(float(chunk[-1]["end"]), start + 0.01)
            cue_objects.extend(split_dense_subtitle_cue(SubtitleCue(start, end, chunk), style=style))
    else:
        text = normalized_text(str(segment.get("text", "")))
        if not text:
            return []
        text_words = [word for word in text.split() if word]
        chunks = chunk_subtitle_items(text_words, style=style)
        duration = max((float(segment["end"]) - float(segment["start"])) / max(len(chunks), 1), 0.01)
        for offset, chunk in enumerate(chunks):
            start = float(segment["start"]) + offset * duration
            raw_end = float(segment["end"]) if offset == len(chunks) - 1 else min(float(segment["end"]), start + duration)
            end = max(raw_end, start + 0.01)
            cue_objects.extend(split_dense_subtitle_cue(SubtitleCue(start, end, chunk), style=style))
    for cue in cue_objects:
        subtitle_cue_apply_speech_trim(cue, speech_intervals)
    cue_objects = merge_short_subtitle_cues(cue_objects, style=style)
    cue_objects = stretch_short_subtitle_cues(cue_objects, float(segment["end"]), style=style)
    cues: list[tuple[float, float, list[list[str] | list[dict[str, float | str]]]]] = []
    for cue in cue_objects:
        line_groups = subtitle_cue_line_groups(cue, style=style)
        cues.append((cue.start, cue.end, line_groups))
    return cues


def format_srt_time(value: float) -> str:
    hours = int(value // 3600)
    minutes = int((value % 3600) // 60)
    seconds = int(value % 60)
    milliseconds = int(round((value % 1) * 1000))
    if milliseconds == 1000:
        milliseconds = 0
        seconds += 1
    return f"{hours:02}:{minutes:02}:{seconds:02},{milliseconds:03}"


def format_ass_time(value: float) -> str:
    hours = int(value // 3600)
    minutes = int((value % 3600) // 60)
    seconds = int(value % 60)
    centiseconds = int(round((value % 1) * 100))
    if centiseconds == 100:
        centiseconds = 0
        seconds += 1
    return f"{hours:d}:{minutes:02}:{seconds:02}.{centiseconds:02}"


def normalized_text(text: str) -> str:
    return " ".join(text.strip().split())


def normalized_token_core(token: BibleToken) -> str:
    return token.core.lower()


def repeated_word_key(token: BibleToken) -> str:
    return token.core.lower()


def can_collapse_repeated_word(left: BibleToken, right: BibleToken) -> bool:
    if left.start is None or left.end is None or right.start is None or right.end is None:
        return False
    left_key = repeated_word_key(left)
    right_key = repeated_word_key(right)
    if not left_key or left_key != right_key:
        return False
    if left_key in SUBTITLE_REPEATABLE_FILLER_WORDS:
        return False
    if not SUBTITLE_REPEATABLE_WORD_RE.fullmatch(left_key):
        return False
    if left.trailing or right.leading:
        return False
    gap = max(0.0, right.start - left.end)
    return gap <= SUBTITLE_TIGHT_JOIN_SECONDS and (right.end - left.start) <= 0.9


def collapse_repeated_word_tokens(tokens: list[BibleToken]) -> list[BibleToken]:
    collapsed: list[BibleToken] = []
    for token in tokens:
        if collapsed and can_collapse_repeated_word(collapsed[-1], token):
            previous = collapsed[-1]
            previous.end = max(previous.end or previous.start or 0.0, token.end or token.start or 0.0)
            if token.trailing:
                previous.trailing = token.trailing
            continue
        collapsed.append(token)
    return collapsed


def split_bible_token(text: str) -> BibleToken:
    match = BIBLE_REFERENCE_TOKEN_RE.match(text)
    if not match:
        return BibleToken("", text, "")
    leading, core, trailing = match.groups()
    return BibleToken(leading, core, trailing)


def bible_alias_token(token: BibleToken) -> str:
    return re.sub(r"[.]+$", "", token.core.lower())


def build_bible_tokens_from_words(words: list[dict[str, float | str]]) -> list[BibleToken]:
    tokens: list[BibleToken] = []
    for word in words:
        token = split_bible_token(normalized_text(str(word.get("word", ""))))
        token.start = float(word["start"])
        token.end = float(word["end"])
        tokens.append(token)
    return tokens


def build_bible_tokens_from_text(text: str) -> list[BibleToken]:
    return [split_bible_token(word) for word in normalized_text(text).split() if word]


def bible_tokens_to_words(tokens: list[BibleToken]) -> list[dict[str, float | str]]:
    words: list[dict[str, float | str]] = []
    for token in tokens:
        if token.start is None or token.end is None:
            continue
        words.append({"start": token.start, "end": token.end, "word": token.text})
    return words


def bible_tokens_to_text(tokens: list[BibleToken]) -> str:
    return " ".join(token.text for token in tokens if token.text)


def glossary_token_core(token: BibleToken) -> str:
    return normalized_lookup_text(token.core)


def discover_project_config_files(media_path: Path, filenames: tuple[str, ...]) -> tuple[Path, ...]:
    directory = media_path.resolve().parent
    discovered: list[Path] = []
    seen: set[Path] = set()
    for ancestor in reversed((directory, *directory.parents)):
        for filename in filenames:
            candidate = (ancestor / filename).resolve()
            if candidate in seen or not candidate.is_file():
                continue
            discovered.append(candidate)
            seen.add(candidate)
    return tuple(discovered)


def parse_text_mapping_lines(text: str, path: Path) -> tuple[tuple[str, str], ...]:
    items: list[tuple[str, str]] = []
    for line_number, raw_line in enumerate(text.splitlines(), start=1):
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        separator = "=>" if "=>" in line else "=" if "=" in line else None
        if separator is None:
            raise ValueError(f"{path.name}:{line_number} should use 'source => replacement' or 'source = replacement'")
        source, replacement = (part.strip() for part in line.split(separator, 1))
        if not source or not replacement:
            raise ValueError(f"{path.name}:{line_number} needs both a source and replacement phrase")
        items.append((source, replacement))
    return tuple(items)


def _suppression_values_from_json(value: object, label: str, path: Path) -> tuple[str, ...]:
    if value is None:
        return ()
    if isinstance(value, str):
        normalized = normalized_text(value)
        return (normalized,) if normalized else ()
    if isinstance(value, list) and all(isinstance(item, str) for item in value):
        return tuple(normalized for normalized in (normalized_text(item) for item in value) if normalized)
    raise ValueError(f"{path.name} key '{label}' should be a string or list of strings")


@lru_cache(maxsize=None)
def load_glossary_replacement_items(path: Path) -> tuple[tuple[tuple[str, ...], tuple[str, ...]], ...]:
    if path.suffix.lower() == ".json":
        payload = json.loads(path.read_text(encoding="utf-8"))
        if isinstance(payload, dict):
            if all(isinstance(key, str) and isinstance(value, str) for key, value in payload.items()):
                raw_items = tuple(payload.items())
            else:
                nested: object = None
                for key in ("replace", "terms", "glossary"):
                    if key in payload:
                        nested = payload[key]
                        break
                if not isinstance(nested, dict) or not all(isinstance(key, str) and isinstance(value, str) for key, value in nested.items()):
                    raise ValueError(f"{path.name} should be a JSON object of string replacements")
                raw_items = tuple(nested.items())
        else:
            raise ValueError(f"{path.name} should be a JSON object of string replacements")
    else:
        raw_items = parse_text_mapping_lines(path.read_text(encoding="utf-8"), path)
    replacements, _lengths = compile_glossary_phrase_mapping(raw_items)
    return tuple(replacements.items())


@lru_cache(maxsize=None)
def load_suppression_rules(path: Path) -> SuppressionRules:
    if path.suffix.lower() == ".json":
        payload = json.loads(path.read_text(encoding="utf-8"))
        if isinstance(payload, list):
            any_phrases = _suppression_values_from_json(payload, "any", path)
            return SuppressionRules(any=any_phrases)
        if not isinstance(payload, dict):
            raise ValueError(f"{path.name} should be a JSON object or list of strings")
        return SuppressionRules(
            start=_suppression_values_from_json(payload.get("start"), "start", path),
            end=_suppression_values_from_json(payload.get("end"), "end", path),
            any=_suppression_values_from_json(payload.get("any"), "any", path),
        )
    start_phrases: list[str] = []
    end_phrases: list[str] = []
    any_phrases: list[str] = []
    for line_number, raw_line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        label = "any"
        value = line
        if ":" in line:
            maybe_label, maybe_value = (part.strip() for part in line.split(":", 1))
            if maybe_label.lower() in {"start", "end", "any"}:
                label = maybe_label.lower()
                value = maybe_value
        normalized_value = normalized_text(value)
        if not normalized_value:
            raise ValueError(f"{path.name}:{line_number} needs a phrase after the optional start:/end:/any: label")
        if label == "start":
            start_phrases.append(normalized_value)
        elif label == "end":
            end_phrases.append(normalized_value)
        else:
            any_phrases.append(normalized_value)
    return SuppressionRules(start=tuple(start_phrases), end=tuple(end_phrases), any=tuple(any_phrases))


def merge_glossary_replacement_sources(
    sources: list[tuple[tuple[tuple[str, ...], tuple[str, ...]], ...]],
) -> tuple[dict[tuple[str, ...], tuple[str, ...]], tuple[int, ...]]:
    replacements = dict(BUILT_IN_GLOSSARY_REPLACEMENTS)
    for source_items in sources:
        for alias, replacement in source_items:
            replacements[alias] = replacement
    return replacements, tuple(sorted({len(alias) for alias in replacements}, reverse=True))


def merge_suppression_rule_sources(sources: list[SuppressionRules]) -> SuppressionRules:
    def unique_phrases(groups: list[tuple[str, ...]]) -> tuple[str, ...]:
        ordered: list[str] = []
        seen: set[str] = set()
        for group in groups:
            for phrase in group:
                normalized = normalized_phrase_key(phrase)
                if not normalized or normalized in seen:
                    continue
                ordered.append(phrase)
                seen.add(normalized)
        return tuple(ordered)

    return SuppressionRules(
        start=unique_phrases([rules.start for rules in sources]),
        end=unique_phrases([rules.end for rules in sources]),
        any=unique_phrases([rules.any for rules in sources]),
    )


def load_effective_glossary(
    media_path: Path, explicit_paths: list[Path]
) -> tuple[dict[tuple[str, ...], tuple[str, ...]], tuple[int, ...], tuple[Path, ...]]:
    source_paths: list[Path] = []
    source_items: list[tuple[tuple[tuple[str, ...], tuple[str, ...]], ...]] = []
    for path in discover_project_config_files(media_path, GLOSSARY_PROJECT_FILENAMES):
        try:
            items = load_glossary_replacement_items(path)
        except Exception as exc:
            warn_once(f"glossary-project-{path}", f"Ignoring glossary file {path}: {exc}")
            continue
        source_paths.append(path)
        source_items.append(items)
    for path in explicit_paths:
        resolved = path.expanduser().resolve()
        items = load_glossary_replacement_items(resolved)
        source_paths.append(resolved)
        source_items.append(items)
    replacements, lengths = merge_glossary_replacement_sources(source_items)
    return replacements, lengths, tuple(source_paths)


def load_effective_suppression_rules(media_path: Path, explicit_paths: list[Path]) -> tuple[SuppressionRules, tuple[Path, ...]]:
    source_paths: list[Path] = []
    source_rules: list[SuppressionRules] = []
    for path in discover_project_config_files(media_path, SUPPRESSION_PROJECT_FILENAMES):
        try:
            rules = load_suppression_rules(path)
        except Exception as exc:
            warn_once(f"suppression-project-{path}", f"Ignoring suppression file {path}: {exc}")
            continue
        source_paths.append(path)
        source_rules.append(rules)
    for path in explicit_paths:
        resolved = path.expanduser().resolve()
        rules = load_suppression_rules(resolved)
        source_paths.append(resolved)
        source_rules.append(rules)
    return merge_suppression_rule_sources(source_rules), tuple(source_paths)


def find_bible_book_match(tokens: list[BibleToken], index: int) -> tuple[str, int] | None:
    for length in BIBLE_BOOK_ALIAS_LENGTHS:
        if index + length > len(tokens):
            continue
        alias = tuple(bible_alias_token(token) for token in tokens[index:index + length])
        canonical = BIBLE_BOOK_ALIAS_LOOKUP.get(alias)
        if canonical:
            return canonical, length
    return None


def is_valid_bible_reference(book: str, chapter: int, verse: int, verse_end: int | None = None) -> bool:
    chapter_limit = BIBLE_BOOK_CHAPTER_COUNTS.get(book)
    if chapter_limit is None or chapter < 1 or chapter > chapter_limit:
        return False
    if verse < 1 or verse > BIBLE_MAX_VERSE_NUMBER:
        return False
    if verse_end is not None and (verse_end < verse or verse_end > BIBLE_MAX_VERSE_NUMBER):
        return False
    return True


def parse_bible_verse_range(text: str) -> tuple[int, int | None] | None:
    match = BIBLE_VERSE_RANGE_RE.fullmatch(text)
    if not match:
        return None
    verse = int(match.group(1))
    verse_end = int(match.group(2)) if match.group(2) else None
    return verse, verse_end


def parse_bible_range_suffix(
    tokens: list[BibleToken],
    index: int,
    book: str,
    chapter: int,
    verse_start: int,
) -> tuple[int, int | None]:
    if index >= len(tokens):
        return 0, None
    token = tokens[index].core.lower()
    inline_match = BIBLE_INLINE_VERSE_END_RE.fullmatch(tokens[index].core)
    if inline_match:
        verse_end = int(inline_match.group(1))
        if verse_end >= verse_start and is_valid_bible_reference(book, chapter, verse_start, verse_end):
            return 1, verse_end
        return 0, None
    if tokens[index].core.isdigit():
        verse_end = int(tokens[index].core)
        if verse_end >= verse_start and is_valid_bible_reference(book, chapter, verse_start, verse_end):
            return 1, verse_end
    if token in BIBLE_RANGE_WORDS and index + 1 < len(tokens) and tokens[index + 1].core.isdigit():
        verse_end = int(tokens[index + 1].core)
        if verse_end >= verse_start and is_valid_bible_reference(book, chapter, verse_start, verse_end):
            return 2, verse_end
    return 0, None


def choose_glued_bible_reference(book: str, digits: str) -> tuple[int, int] | None:
    if not BIBLE_GLUE_DIGITS_RE.fullmatch(digits) or len(digits) < 3:
        return None
    candidates: list[tuple[int, int]] = []
    for verse_digits in (1, 2, 3):
        if len(digits) <= verse_digits:
            continue
        chapter = int(digits[:-verse_digits])
        verse = int(digits[-verse_digits:])
        if is_valid_bible_reference(book, chapter, verse):
            candidates.append((chapter, verse))
    unique_candidates = list(dict.fromkeys(candidates))
    return unique_candidates[0] if len(unique_candidates) == 1 else None


def make_bible_reference_token(
    source_tokens: list[BibleToken],
    start_index: int,
    end_index: int,
    normalized_reference: str,
) -> BibleToken:
    first = source_tokens[start_index]
    last = source_tokens[end_index - 1]
    return BibleToken(
        first.leading,
        normalized_reference,
        last.trailing,
        start=first.start,
        end=last.end,
    )


def make_replacement_tokens(
    source_tokens: list[BibleToken],
    start_index: int,
    end_index: int,
    replacement_cores: tuple[str, ...],
) -> list[BibleToken]:
    source_slice = source_tokens[start_index:end_index]
    if not source_slice:
        return []
    if len(source_slice) == len(replacement_cores):
        replaced: list[BibleToken] = []
        for source, replacement_core in zip(source_slice, replacement_cores):
            replaced.append(
                BibleToken(
                    source.leading,
                    replacement_core,
                    source.trailing,
                    start=source.start,
                    end=source.end,
                )
            )
        return replaced
    first = source_slice[0]
    last = source_slice[-1]
    total_start = first.start
    total_end = last.end
    replaced = []
    for index, replacement_core in enumerate(replacement_cores):
        replacement_start = None
        replacement_end = None
        if total_start is not None and total_end is not None:
            replacement_start = total_start + ((total_end - total_start) * index / len(replacement_cores))
            replacement_end = total_start + ((total_end - total_start) * (index + 1) / len(replacement_cores))
        replaced.append(
            BibleToken(
                first.leading if index == 0 else "",
                replacement_core,
                last.trailing if index == len(replacement_cores) - 1 else "",
                start=replacement_start,
                end=replacement_end,
            )
        )
    return replaced


def find_glossary_match(
    tokens: list[BibleToken],
    index: int,
    replacements: dict[tuple[str, ...], tuple[str, ...]],
    alias_lengths: tuple[int, ...],
) -> tuple[tuple[str, ...], int] | None:
    for length in alias_lengths:
        if index + length > len(tokens):
            continue
        alias = tuple(glossary_token_core(token) for token in tokens[index:index + length])
        replacement = replacements.get(alias)
        if replacement:
            return replacement, length
    return None


def normalize_glossary_tokens(
    tokens: list[BibleToken],
    *,
    replacements: dict[tuple[str, ...], tuple[str, ...]],
    alias_lengths: tuple[int, ...],
) -> list[BibleToken]:
    normalized: list[BibleToken] = []
    index = 0
    while index < len(tokens):
        match = find_glossary_match(tokens, index, replacements, alias_lengths)
        if not match:
            normalized.append(tokens[index])
            index += 1
            continue
        replacement_cores, consumed = match
        normalized.extend(make_replacement_tokens(tokens, index, index + consumed, replacement_cores))
        index += consumed
    return normalized


def bible_book_display_core(token_core: str, *, lowercase_small_word: bool) -> str:
    if token_core.isdigit():
        return token_core
    lowered = normalized_lookup_text(token_core)
    if lowercase_small_word and lowered in {"of", "the"}:
        return lowered
    return token_core[:1].upper() + token_core[1:].lower()


def capitalized_bible_book_tokens(tokens: list[BibleToken], start_index: int, length: int) -> list[BibleToken]:
    capitalized: list[BibleToken] = []
    source_slice = tokens[start_index:start_index + length]
    for offset, token in enumerate(source_slice):
        capitalized.append(
            BibleToken(
                token.leading,
                bible_book_display_core(token.core, lowercase_small_word=offset > 0),
                token.trailing,
                start=token.start,
                end=token.end,
            )
        )
    return capitalized


def parse_bible_reference_after_book(tokens: list[BibleToken], index: int, book: str) -> tuple[int, BibleToken] | None:
    if index >= len(tokens):
        return None
    first = tokens[index]
    combined_match = BIBLE_COMBINED_REFERENCE_RE.fullmatch(first.core)
    if combined_match:
        chapter = int(combined_match.group(1))
        verse = int(combined_match.group(2))
        verse_end = int(combined_match.group(3)) if combined_match.group(3) else None
        if is_valid_bible_reference(book, chapter, verse, verse_end):
            extra_consumed = 0
            if verse_end is None:
                extra_consumed, ranged_verse_end = parse_bible_range_suffix(tokens, index + 1, book, chapter, verse)
                if ranged_verse_end is not None:
                    verse_end = ranged_verse_end
            reference = f"{chapter}:{verse}"
            if verse_end is not None:
                reference += f"-{verse_end}"
            return 1 + extra_consumed, make_bible_reference_token(tokens, index, index + 1 + extra_consumed, reference)
    if index + 1 >= len(tokens):
        glued = choose_glued_bible_reference(book, first.core)
        if glued is not None:
            chapter, verse = glued
            extra_consumed, verse_end = parse_bible_range_suffix(tokens, index + 1, book, chapter, verse)
            reference = f"{chapter}:{verse}"
            if verse_end is not None:
                reference += f"-{verse_end}"
            return 1 + extra_consumed, make_bible_reference_token(tokens, index, index + 1 + extra_consumed, reference)
        return None
    second = tokens[index + 1]
    if first.core.isdigit():
        verse_range = parse_bible_verse_range(second.core)
        if verse_range is not None:
            chapter = int(first.core)
            verse, verse_end = verse_range
            if is_valid_bible_reference(book, chapter, verse, verse_end):
                extra_consumed = 0
                if verse_end is None:
                    extra_consumed, ranged_verse_end = parse_bible_range_suffix(tokens, index + 2, book, chapter, verse)
                    if ranged_verse_end is not None:
                        verse_end = ranged_verse_end
                reference = f"{chapter}:{verse}"
                if verse_end is not None:
                    reference += f"-{verse_end}"
                return 2 + extra_consumed, make_bible_reference_token(tokens, index, index + 2 + extra_consumed, reference)
        if second.core.lower() not in BIBLE_CHAPTER_WORDS and second.core.lower() not in BIBLE_VERSE_WORDS:
            glued = choose_glued_bible_reference(book, first.core)
            if glued is not None:
                chapter, verse = glued
                extra_consumed, verse_end = parse_bible_range_suffix(tokens, index + 1, book, chapter, verse)
                reference = f"{chapter}:{verse}"
                if verse_end is not None:
                    reference += f"-{verse_end}"
                return 1 + extra_consumed, make_bible_reference_token(tokens, index, index + 1 + extra_consumed, reference)
    partial_match = BIBLE_PARTIAL_REFERENCE_PREFIX_RE.fullmatch(first.core)
    if partial_match:
        verse_range = parse_bible_verse_range(second.core)
        if verse_range is not None:
            chapter = int(partial_match.group(1))
            verse, verse_end = verse_range
            if is_valid_bible_reference(book, chapter, verse, verse_end):
                extra_consumed = 0
                if verse_end is None:
                    extra_consumed, ranged_verse_end = parse_bible_range_suffix(tokens, index + 2, book, chapter, verse)
                    if ranged_verse_end is not None:
                        verse_end = ranged_verse_end
                reference = f"{chapter}:{verse}"
                if verse_end is not None:
                    reference += f"-{verse_end}"
                return 2 + extra_consumed, make_bible_reference_token(tokens, index, index + 2 + extra_consumed, reference)
    return None


def parse_bible_reference_phrase_after_book(tokens: list[BibleToken], index: int, book: str) -> tuple[int, BibleToken] | None:
    if index >= len(tokens):
        return None
    cursor = index
    chapter: int | None = None
    chapter_keyword_used = False
    if tokens[cursor].core.lower() in BIBLE_CHAPTER_WORDS:
        chapter_keyword_used = True
        cursor += 1
        if cursor >= len(tokens) or not tokens[cursor].core.isdigit():
            return None
    if chapter_keyword_used:
        chapter = int(tokens[cursor].core)
        cursor += 1
        if cursor >= len(tokens) or tokens[cursor].core.lower() not in BIBLE_VERSE_WORDS:
            return None
        cursor += 1
    else:
        if not tokens[cursor].core.isdigit():
            if (
                BIBLE_BOOK_CHAPTER_COUNTS.get(book) == 1
                and tokens[cursor].core.lower() in BIBLE_VERSE_WORDS
            ):
                chapter = 1
                cursor += 1
            else:
                return None
        else:
            chapter = int(tokens[cursor].core)
            cursor += 1
            if cursor >= len(tokens) or tokens[cursor].core.lower() not in BIBLE_VERSE_WORDS:
                return None
            cursor += 1
    if chapter is None or cursor >= len(tokens):
        return None
    verse_range = parse_bible_verse_range(tokens[cursor].core)
    if verse_range is None:
        return None
    verse, verse_end = verse_range
    if not is_valid_bible_reference(book, chapter, verse, verse_end):
        return None
    extra_consumed = 0
    if verse_end is None:
        extra_consumed, ranged_verse_end = parse_bible_range_suffix(tokens, cursor + 1, book, chapter, verse)
        if ranged_verse_end is not None:
            verse_end = ranged_verse_end
    reference = f"{chapter}:{verse}"
    if verse_end is not None:
        reference += f"-{verse_end}"
    return cursor - index + 1 + extra_consumed, make_bible_reference_token(tokens, index, cursor + 1 + extra_consumed, reference)


def normalize_bible_reference_tokens(tokens: list[BibleToken], *, normalize_phrases: bool = False) -> list[BibleToken]:
    normalized: list[BibleToken] = []
    index = 0
    while index < len(tokens):
        book_match = find_bible_book_match(tokens, index)
        if not book_match:
            normalized.append(tokens[index])
            index += 1
            continue
        book, book_length = book_match
        reference_match = parse_bible_reference_after_book(tokens, index + book_length, book)
        if reference_match is None and normalize_phrases:
            reference_match = parse_bible_reference_phrase_after_book(tokens, index + book_length, book)
        if reference_match:
            consumed, normalized_reference = reference_match
            normalized.extend(capitalized_bible_book_tokens(tokens, index, book_length))
            normalized.append(normalized_reference)
            index += book_length + consumed
        else:
            normalized.extend(tokens[index:index + book_length])
            index += book_length
    return normalized


def postprocess_text_tokens(
    tokens: list[BibleToken],
    *,
    normalize_bible_references: bool,
    normalize_bible_reference_phrases: bool,
    glossary_replacements: dict[tuple[str, ...], tuple[str, ...]],
    glossary_lengths: tuple[int, ...],
) -> list[BibleToken]:
    normalized_tokens = collapse_repeated_word_tokens(tokens)
    if normalize_bible_references:
        normalized_tokens = normalize_bible_reference_tokens(
            normalized_tokens,
            normalize_phrases=normalize_bible_reference_phrases,
        )
    return normalize_glossary_tokens(
        normalized_tokens,
        replacements=glossary_replacements,
        alias_lengths=glossary_lengths,
    )


def postprocess_segments(
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
    *,
    normalize_bible_references: bool,
    normalize_bible_reference_phrases: bool,
    glossary_replacements: dict[tuple[str, ...], tuple[str, ...]],
    glossary_lengths: tuple[int, ...],
) -> list[dict[str, float | str | list[dict[str, float | str]]]]:
    normalized_segments: list[dict[str, float | str | list[dict[str, float | str]]]] = []
    for segment in segments:
        words = segment.get("words", []) or []
        if words:
            normalized_tokens = postprocess_text_tokens(
                build_bible_tokens_from_words(words),
                normalize_bible_references=normalize_bible_references,
                normalize_bible_reference_phrases=normalize_bible_reference_phrases,
                glossary_replacements=glossary_replacements,
                glossary_lengths=glossary_lengths,
            )
            normalized_segments.append(
                {
                    **segment,
                    "words": bible_tokens_to_words(normalized_tokens),
                    "text": bible_tokens_to_text(normalized_tokens),
                }
            )
            continue
        text = normalized_text(str(segment.get("text", "")))
        normalized_tokens = postprocess_text_tokens(
            build_bible_tokens_from_text(text),
            normalize_bible_references=normalize_bible_references,
            normalize_bible_reference_phrases=normalize_bible_reference_phrases,
            glossary_replacements=glossary_replacements,
            glossary_lengths=glossary_lengths,
        )
        normalized_segments.append({**segment, "text": bible_tokens_to_text(normalized_tokens)})
    return normalized_segments


def segment_text_key(segment: dict[str, float | str | list[dict[str, float | str]]]) -> str:
    return normalized_phrase_key(str(segment.get("text", "")))


def time_range_overlaps_speech(start: float, end: float, speech_intervals: list[tuple[float, float]] | None, *, margin: float = 0.0) -> bool:
    if not speech_intervals:
        return False
    adjusted_start = start - margin
    adjusted_end = end + margin
    for speech_start, speech_end in speech_intervals:
        if speech_end <= adjusted_start:
            continue
        if speech_start >= adjusted_end:
            break
        return True
    return False


def prune_segments_to_speech(
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
    speech_intervals: list[tuple[float, float]] | None,
) -> tuple[list[dict[str, float | str | list[dict[str, float | str]]]], SpeechPruneStats]:
    stats = SpeechPruneStats()
    if not speech_intervals:
        return segments, stats
    pruned_segments: list[dict[str, float | str | list[dict[str, float | str]]]] = []
    for segment in segments:
        words = segment.get("words", []) or []
        if not words:
            pruned_segments.append(segment)
            continue
        keep_flags = [
            time_range_overlaps_speech(
                float(word["start"]),
                float(word["end"]),
                speech_intervals,
                margin=SUBTITLE_SPEECH_PRUNE_MARGIN_SECONDS,
            )
            for word in words
        ]
        if not any(keep_flags):
            stats.dropped_segments += 1
            stats.dropped_words += len(words)
            continue
        first_keep = next(index for index, keep in enumerate(keep_flags) if keep)
        last_keep = len(keep_flags) - 1 - next(index for index, keep in enumerate(reversed(keep_flags)) if keep)
        kept_words = words[first_keep:last_keep + 1]
        dropped_word_count = len(words) - len(kept_words)
        if dropped_word_count:
            stats.trimmed_segments += 1
            stats.dropped_words += dropped_word_count
        normalized_tokens = build_bible_tokens_from_words(kept_words)
        pruned_segments.append(
            {
                **segment,
                "start": float(kept_words[0]["start"]),
                "end": float(kept_words[-1]["end"]),
                "words": kept_words,
                "text": bible_tokens_to_text(normalized_tokens),
            }
        )
    return pruned_segments, stats


def apply_suppression_rules_to_segments(
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
    rules: SuppressionRules,
) -> tuple[list[dict[str, float | str | list[dict[str, float | str]]]], SuppressionStats]:
    stats = SuppressionStats()
    if not segments:
        return segments, stats
    start_keys = {normalized_phrase_key(phrase) for phrase in rules.start}
    end_keys = {normalized_phrase_key(phrase) for phrase in rules.end}
    any_keys = {normalized_phrase_key(phrase) for phrase in rules.any}
    filtered = list(segments)
    while filtered and segment_text_key(filtered[0]) in start_keys:
        filtered.pop(0)
        stats.leading_segments += 1
    while filtered and segment_text_key(filtered[-1]) in end_keys:
        filtered.pop()
        stats.trailing_segments += 1
    if any_keys:
        kept: list[dict[str, float | str | list[dict[str, float | str]]]] = []
        for segment in filtered:
            if segment_text_key(segment) in any_keys:
                stats.anywhere_segments += 1
                continue
            kept.append(segment)
        filtered = kept
    return filtered, stats


def count_spoken_bible_reference_phrase_candidates(
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
) -> int:
    count = 0
    for segment in segments:
        words = segment.get("words", []) or []
        tokens = build_bible_tokens_from_words(words) if words else build_bible_tokens_from_text(str(segment.get("text", "")))
        index = 0
        while index < len(tokens):
            book_match = find_bible_book_match(tokens, index)
            if not book_match:
                index += 1
                continue
            book, book_length = book_match
            phrase_match = parse_bible_reference_phrase_after_book(tokens, index + book_length, book)
            if phrase_match:
                count += 1
                index += book_length + phrase_match[0]
                continue
            index += book_length
    return count


def count_text_only_outside_speech_segments(
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
    speech_intervals: list[tuple[float, float]] | None,
) -> int:
    if not speech_intervals:
        return 0
    count = 0
    for segment in segments:
        if segment.get("words"):
            continue
        if not time_range_overlaps_speech(float(segment["start"]), float(segment["end"]), speech_intervals):
            count += 1
    return count


def segments_to_plain_text(segments: list[dict[str, float | str | list[dict[str, float | str]]]]) -> str:
    return " ".join(
        normalized_text(str(segment.get("text", "")))
        for segment in segments
        if normalized_text(str(segment.get("text", "")))
    )


def discover_files(target: Path, recursive: bool) -> list[Path]:
    if target.is_file():
        return [target]
    if not target.is_dir():
        return []
    iterator = target.rglob("*") if recursive else target.iterdir()
    return sorted(path for path in iterator if path.is_file() and path.suffix.lower() in MEDIA_EXTENSIONS)


def discover_target_files(targets: list[Path], recursive: bool) -> list[Path]:
    files: list[Path] = []
    seen: set[Path] = set()
    for target in targets:
        for path in discover_files(target.expanduser(), recursive):
            try:
                key = path.resolve()
            except OSError:
                key = path.expanduser().absolute()
            if key in seen:
                continue
            seen.add(key)
            files.append(path)
    return files


def load_env_targets(env: dict[str, str]) -> list[Path]:
    encoded_targets = env.get("WHISPER_TARGETS", "")
    if encoded_targets:
        try:
            values = json.loads(encoded_targets)
        except json.JSONDecodeError:
            values = []
        if isinstance(values, list):
            return [Path(str(value)).expanduser() for value in values if str(value).strip()]
    legacy_target = env.get("WHISPER_TARGET", "")
    return [Path(legacy_target).expanduser()] if legacy_target else []


def load_env_paths(env: dict[str, str], key: str) -> list[Path]:
    encoded_value = env.get(key, "")
    if not encoded_value:
        return []
    try:
        values = json.loads(encoded_value)
    except json.JSONDecodeError:
        return []
    if not isinstance(values, list):
        return []
    return [Path(str(value)).expanduser() for value in values if str(value).strip()]


def resolve_subtitle_style_profile(name: str) -> SubtitleStyleProfile:
    return SUBTITLE_STYLE_PRESETS.get(name, SUBTITLE_STYLE_PRESETS["balanced"])


def probe_duration_seconds(media_path: Path) -> float | None:
    try:
        proc = subprocess.run(
            ["ffprobe", "-v", "error", "-show_entries", "format=duration", "-of", "default=noprint_wrappers=1:nokey=1", str(media_path)],
            check=True,
            capture_output=True,
            text=True,
        )
        value = proc.stdout.strip()
        duration = float(value) if value else None
        return duration if duration and duration > 0 else None
    except Exception:
        return None


def probe_subtitle_stream_count(media_path: Path) -> int:
    try:
        proc = subprocess.run(
            ["ffprobe", "-v", "error", "-select_streams", "s", "-show_entries", "stream=index", "-of", "csv=p=0", str(media_path)],
            check=True,
            capture_output=True,
            text=True,
        )
        return sum(1 for line in proc.stdout.splitlines() if line.strip())
    except Exception:
        return 0


def probe_audio_stream_language(media_path: Path) -> str | None:
    try:
        proc = subprocess.run(
            ["ffprobe", "-v", "error", "-select_streams", "a", "-show_entries", "stream_tags=language", "-of", "csv=p=0", str(media_path)],
            check=True,
            capture_output=True,
            text=True,
        )
        for line in proc.stdout.splitlines():
            language = line.strip().lower()
            if language and language != "und":
                return language
    except Exception:
        return None
    return None


def subtitle_track_metadata(language: str) -> tuple[str, str]:
    token = (language or "").strip().lower().replace("_", "-")
    if not token or token == "auto":
        return "und", "Subtitles"
    base = token.split("-", 1)[0]
    canonical = LANGUAGE_ALIASES.get(token) or LANGUAGE_ALIASES.get(base)
    if not canonical:
        canonical = token if token in LANGUAGE_LABELS else base
    if canonical in LANGUAGE_LABELS:
        iso3, title = LANGUAGE_LABELS[canonical]
        return iso3, title
    for code, (iso3, title) in LANGUAGE_LABELS.items():
        if token == iso3 or base == iso3 or token == title.lower():
            return iso3, title
    pretty = language.strip()
    return "und", pretty[:1].upper() + pretty[1:] if pretty else "Subtitles"


def resolve_subtitle_language(media_path: Path, requested_language: str, detected_language: str | None = None) -> str:
    if requested_language != "auto":
        return requested_language
    if detected_language:
        return detected_language
    return probe_audio_stream_language(media_path) or "auto"


class EstimatedProgressReporter:
    def __init__(self, media_path: Path, backend: str, *, inline: bool, show_media_name: bool, enabled: bool = True) -> None:
        self.media_path = media_path
        self.backend = backend
        self.enabled = enabled
        self.inline = enabled and inline and sys.stderr.isatty()
        self.show_media_name = show_media_name
        self.duration = probe_duration_seconds(media_path) if enabled else None
        self.last_percent = -1
        self.last_reported_at = 0.0
        self.eta_started_at: float | None = None
        self.eta_started_media_end: float | None = None
        self.unknown_duration_noted = False
        self.inline_rendered = False
        self.last_render_width = 0
        if not self.enabled:
            return
        if self.duration is None:
            self.note_unknown_duration()
        else:
            suffix = f" for {media_path.name}" if self.show_media_name else ""
            print(f"⏱ Media length: {format_elapsed_summary(self.duration)}{suffix}", file=sys.stderr)

    def clear_inline(self) -> None:
        if not self.enabled:
            return
        if not self.inline_rendered:
            return
        print(f"\r{' ' * self.last_render_width}\r", end="", file=sys.stderr, flush=True)
        self.inline_rendered = False
        self.last_render_width = 0

    def note_unknown_duration(self) -> None:
        if not self.enabled:
            return
        if self.unknown_duration_noted:
            return
        self.clear_inline()
        self.unknown_duration_noted = True
        suffix = f" for {self.media_path.name}" if self.show_media_name else ""
        print(f"⏱ Media length unavailable{suffix}; estimated % progress and ETA unavailable.", file=sys.stderr)

    def render_message(self, message: str) -> None:
        if self.inline:
            width = terminal_display_width(message)
            padding = max(0, self.last_render_width - width)
            self.last_render_width = width
            self.inline_rendered = True
            print(f"\r{message}{' ' * padding}", end="", file=sys.stderr, flush=True)
            return
        print(message, file=sys.stderr)

    def estimate_eta_seconds(self, current_end: float, now: float) -> float | None:
        if self.duration is None:
            return None
        if self.eta_started_at is None or self.eta_started_media_end is None:
            self.eta_started_at = now
            self.eta_started_media_end = current_end
            return None
        elapsed = now - self.eta_started_at
        processed_media = max(0.0, current_end - self.eta_started_media_end)
        min_media_for_eta = min(60.0, max(15.0, self.duration * 0.03))
        if elapsed < 5.0 or processed_media < min_media_for_eta:
            return None
        rate = processed_media / elapsed
        if rate <= 0:
            return None
        remaining_media = max(0.0, self.duration - current_end)
        return remaining_media / rate

    def report(self, current_end: float) -> None:
        if not self.enabled:
            return
        if self.duration is None:
            return
        now = time.monotonic()
        percent = int(min(100, max(0, round((current_end / self.duration) * 100))))
        if percent <= self.last_percent:
            return
        if percent < 100 and now - self.last_reported_at < 1.0:
            return
        self.last_percent = percent
        self.last_reported_at = now
        if self.show_media_name:
            message = f"⏳ {self.media_path.name} [{self.backend}] {percent}%"
        else:
            message = f"⏳ {percent}%"
        eta_seconds = self.estimate_eta_seconds(current_end, now)
        if eta_seconds is not None and percent < 100:
            message += f" | ETA {format_elapsed_summary(eta_seconds)}"
        self.render_message(message)

    def finish(self) -> None:
        if not self.enabled:
            return
        if self.duration is None:
            return
        if self.last_percent < 100:
            self.last_percent = 100
            self.clear_inline()

    def before_stage_message(self) -> None:
        if not self.enabled:
            return
        if not self.inline_rendered:
            return
        if self.inline:
            print(file=sys.stderr, flush=True)
        else:
            self.clear_inline()
        self.inline_rendered = False
        self.last_render_width = 0


def subtitle_filter_arg(path: Path) -> str:
    escaped = str(path.resolve()).replace("\\", "\\\\").replace(":", "\\:").replace(",", "\\,").replace("'", "\\'")
    return f"ass={escaped}" if path.suffix.lower() == ".ass" else f"subtitles={escaped}"


def burn_subtitles(video_path: Path, subtitle_path: Path, output_path: Path, *, video_codec: str) -> None:
    command = ["ffmpeg", "-y", "-i", str(video_path), "-vf", subtitle_filter_arg(subtitle_path)]
    if video_codec != "auto":
        command.extend(["-c:v", video_codec])
    command.extend(["-c:a", "copy", str(output_path)])
    result = run_command_with_spinner(
        command,
        description=f"Burning subtitles into {video_path.name}",
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    if result.returncode != 0:
        raise subprocess.CalledProcessError(result.returncode, result.args)


def embedded_subtitle_plan(video_path: Path, subtitle_path: Path, output_root: Path) -> tuple[Path, str]:
    video_suffix = video_path.suffix.lower()
    subtitle_suffix = subtitle_path.suffix.lower()
    subtitle_codec = "ass" if subtitle_suffix == ".ass" else "srt"
    output_suffix = ".mkv"
    if video_suffix in {".mp4", ".mov"} and subtitle_codec == "srt":
        output_suffix = video_path.suffix
        subtitle_codec = "mov_text"
    elif video_suffix == ".mkv":
        output_suffix = video_path.suffix
    output_path = output_root / f"{video_path.stem}_embedded{output_suffix}"
    return output_path, subtitle_codec


def embed_subtitles(video_path: Path, subtitle_path: Path, output_path: Path, *, subtitle_codec: str, subtitle_language: str) -> None:
    subtitle_stream_index = probe_subtitle_stream_count(video_path)
    track_language, track_title = subtitle_track_metadata(subtitle_language)
    result = run_command_with_spinner(
        [
            "ffmpeg",
            "-y",
            "-i",
            str(video_path),
            "-i",
            str(subtitle_path),
            "-map",
            "0",
            "-map",
            "1",
            "-c",
            "copy",
            "-c:s",
            subtitle_codec,
            f"-metadata:s:s:{subtitle_stream_index}",
            f"language={track_language}",
            f"-metadata:s:s:{subtitle_stream_index}",
            f"title={track_title}",
            f"-metadata:s:s:{subtitle_stream_index}",
            f"handler_name={track_title}",
            str(output_path),
        ],
        description=f"Embedding subtitles into {video_path.name}",
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    if result.returncode != 0:
        raise subprocess.CalledProcessError(result.returncode, result.args)


def embed_subtitles_in_place(video_path: Path, subtitle_path: Path, *, subtitle_codec: str, subtitle_language: str) -> None:
    temp_handle = tempfile.NamedTemporaryFile(
        prefix=f".{video_path.stem}.embedtmp-",
        suffix=video_path.suffix,
        dir=video_path.parent,
        delete=False,
    )
    temp_path = Path(temp_handle.name)
    temp_handle.close()
    try:
        embed_subtitles(video_path, subtitle_path, temp_path, subtitle_codec=subtitle_codec, subtitle_language=subtitle_language)
        os.replace(temp_path, video_path)
    finally:
        if temp_path.exists():
            temp_path.unlink()


def resolve_embed_subtitle_path(media_path: Path, embed_file_value: str) -> Path:
    if embed_file_value:
        candidate = Path(embed_file_value).expanduser().resolve()
        if not candidate.exists() or not candidate.is_file():
            raise FileNotFoundError(f"Subtitle file not found: {candidate}")
        if candidate.suffix.lower() not in {".srt", ".ass"}:
            raise ValueError(f"Subtitle file must be .srt or .ass: {candidate}")
        return candidate
    candidates = [media_path.with_suffix(ext) for ext in (".srt", ".ass") if media_path.with_suffix(ext).exists()]
    if not candidates:
        raise FileNotFoundError(f"No matching .srt or .ass found for {media_path.name}")
    if len(candidates) > 1:
        names = ", ".join(path.name for path in candidates)
        raise ValueError(f"Found multiple matching subtitle files for {media_path.name}: {names}. Use --embed-file=/path/to/file.")
    return candidates[0]


def apply_subtitle_outputs(
    media_path: Path,
    subtitle_path: Path,
    output_root: Path,
    env: dict[str, str],
    *,
    compact_status: bool,
    subtitle_language: str,
    show_messages: bool = True,
) -> None:
    embed_requested = env["WHISPER_EMBED"] == "1"
    in_place = env["WHISPER_IN_PLACE"] == "1"
    if embed_requested and media_path.suffix.lower() in VIDEO_EXTENSIONS:
        embedded_path, subtitle_codec = embedded_subtitle_plan(media_path, subtitle_path, output_root)
        if in_place:
            if embedded_path.suffix.lower() != media_path.suffix.lower():
                raise ValueError(
                    f"--in-place is not available for {media_path.suffix} with {subtitle_path.suffix} subtitles; use MKV/SRT or omit --in-place."
                )
            embed_subtitles_in_place(media_path, subtitle_path, subtitle_codec=subtitle_codec, subtitle_language=subtitle_language)
            if show_messages:
                if compact_status:
                    print("📦 Embedded subtitle track in place.", file=sys.stderr)
                else:
                    print(f"📦 Embedded subtitle track in place: {media_path.name}", file=sys.stderr)
        else:
            embed_subtitles(media_path, subtitle_path, embedded_path, subtitle_codec=subtitle_codec, subtitle_language=subtitle_language)
            if show_messages:
                if compact_status:
                    print("📦 Embedded subtitle track.", file=sys.stderr)
                else:
                    print(f"📦 Embedded subtitle track: {media_path.name}", file=sys.stderr)
    if env["WHISPER_BURN"] == "1" and media_path.suffix.lower() in VIDEO_EXTENSIONS:
        burn_subtitles(
            media_path,
            subtitle_path,
            output_root / f"{media_path.stem}_subbed.mp4",
            video_codec=env["WHISPER_BURN_VCODEC"],
        )
        if show_messages:
            if compact_status:
                print("🎞 Wrote burned-in video.", file=sys.stderr)
            else:
                print(f"🎞 Wrote burned-in video: {media_path.name}", file=sys.stderr)


def write_ass(
    path: Path,
    segments,
    font_name: str,
    karaoke: bool,
    *,
    speech_intervals: list[tuple[float, float]] | None = None,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
) -> None:
    with path.open("w", encoding="utf-8") as handle:
        handle.write("[Script Info]\nScriptType: v4.00+\nPlayResX: 1920\nPlayResY: 1080\n\n")
        handle.write("[V4+ Styles]\n")
        handle.write("Format: Name,Fontname,Fontsize,PrimaryColour,SecondaryColour,OutlineColour,BackColour,Bold,Italic,Underline,StrikeOut,ScaleX,ScaleY,Spacing,Angle,BorderStyle,Outline,Shadow,Alignment,MarginL,MarginR,MarginV,Encoding\n")
        handle.write(f"Style: Default,{font_name},30,&H00FFFFFF,&H0000FFFF,&H00101010,&H64000000,0,0,0,0,100,100,0,0,1,2,0,2,40,40,40,1\n\n")
        handle.write("[Events]\nFormat: Layer,Start,End,Style,Name,MarginL,MarginR,MarginV,Effect,Text\n")
        for segment in segments:
            for start, end, line_groups in iter_segment_subtitle_cues(segment, speech_intervals=speech_intervals, style=style):
                has_word_timings = bool(line_groups and isinstance(line_groups[0][0], dict))
                if karaoke and has_word_timings:
                    rendered_lines = []
                    for line in line_groups:
                        chunks = []
                        for word in line:
                            duration = max(1, int(round((float(word["end"]) - float(word["start"])) * 100)))
                            chunks.append(f"{{\\k{duration}}}{subtitle_item_text(word)}")
                        rendered_lines.append(" ".join(chunks))
                    text = r"\N".join(rendered_lines)
                else:
                    text = r"\N".join(
                        " ".join(subtitle_item_text(item) for item in line).strip() for line in line_groups if line
                    )
                if text:
                    handle.write(f"Dialogue: 0,{format_ass_time(start)},{format_ass_time(end)},Default,,0,0,0,,{text}\n")


def write_srt(
    path: Path,
    segments,
    *,
    speech_intervals: list[tuple[float, float]] | None = None,
    style: SubtitleStyleProfile = SUBTITLE_STYLE_PRESETS["balanced"],
) -> None:
    index = 1
    with path.open("w", encoding="utf-8") as handle:
        for segment in segments:
            for start, end, line_groups in iter_segment_subtitle_cues(segment, speech_intervals=speech_intervals, style=style):
                lines = [" ".join(subtitle_item_text(item) for item in line).strip() for line in line_groups if line]
                if not lines:
                    continue
                handle.write(f"{index}\n{format_srt_time(start)} --> {format_srt_time(end)}\n")
                for line in lines:
                    handle.write(f"{line}\n")
                handle.write("\n")
                index += 1


def write_txt(path: Path, text: str) -> None:
    with path.open("w", encoding="utf-8") as handle:
        handle.write(text.rstrip())
        handle.write("\n")


def parse_srt_timecode(value: str) -> float:
    hours_text, minutes_text, seconds_text = value.replace(",", ".").split(":")
    seconds_value = float(seconds_text)
    return int(hours_text) * 3600 + int(minutes_text) * 60 + seconds_value


def parse_ass_timecode(value: str) -> float:
    hours_text, minutes_text, seconds_text = value.split(":")
    return int(hours_text) * 3600 + int(minutes_text) * 60 + float(seconds_text)


def strip_subtitle_inline_markup(text: str) -> str:
    text = text.replace(r"\N", " ").replace(r"\n", " ").replace(r"\h", " ")
    text = re.sub(r"\{[^{}]*\}", "", text)
    text = re.sub(r"<[^>]+>", "", text)
    return normalized_text(text)


def transcript_should_break_paragraph(
    current_parts: list[str],
    current_length: int,
    previous_end: float | None,
    chunk: TranscriptChunk,
    *,
    paragraphs: bool,
) -> bool:
    if not paragraphs or not current_parts:
        return False
    gap = None if previous_end is None else max(0.0, chunk.start - previous_end)
    return bool(
        (gap is not None and gap >= TRANSCRIPT_PARAGRAPH_GAP_SECONDS)
        or (
            current_length >= TRANSCRIPT_PARAGRAPH_SOFT_MAX_CHARS
            and TRANSCRIPT_SENTENCE_END_RE.search(current_parts[-1])
        )
    )


def transcript_text_from_chunks(chunks: list[TranscriptChunk], *, paragraphs: bool, speaker_labels: bool = False) -> str:
    if not chunks:
        return ""
    if not paragraphs and not speaker_labels:
        return normalized_text(" ".join(chunk.text for chunk in chunks if chunk.text))
    paragraph_texts: list[str] = []
    current_parts: list[str] = []
    current_length = 0
    previous_end: float | None = None
    current_speaker = ""

    def flush_current() -> None:
        nonlocal current_parts, current_length, current_speaker
        if not current_parts:
            return
        text = normalized_text(" ".join(current_parts))
        if text:
            if speaker_labels and current_speaker:
                paragraph_texts.append(f"{current_speaker}: {text}")
            else:
                paragraph_texts.append(text)
        current_parts = []
        current_length = 0

    for chunk in chunks:
        text = normalized_text(chunk.text)
        if not text:
            continue
        speaker = normalized_text(chunk.speaker)
        speaker_changed = bool(speaker_labels and current_parts and speaker != current_speaker)
        should_break = speaker_changed or transcript_should_break_paragraph(
            current_parts,
            current_length,
            previous_end,
            chunk,
            paragraphs=paragraphs,
        )
        if should_break:
            flush_current()
        if speaker_labels and not current_parts:
            current_speaker = speaker
        current_parts.append(text)
        current_length += len(text) + 1
        previous_end = chunk.end
    flush_current()
    return "\n\n".join(paragraph for paragraph in paragraph_texts if paragraph)


def transcript_chunks_from_segments(
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
) -> list[TranscriptChunk]:
    chunks: list[TranscriptChunk] = []
    for segment in segments:
        text = normalized_text(str(segment.get("text", "")))
        if not text:
            continue
        chunks.append(
            TranscriptChunk(
                float(segment.get("start", 0.0)),
                float(segment.get("end", 0.0)),
                text,
                normalized_text(str(segment.get("speaker", ""))),
            )
        )
    return chunks


def transcript_chunks_from_srt(text: str) -> list[TranscriptChunk]:
    chunks: list[TranscriptChunk] = []
    skip_note = False
    current_start: float | None = None
    current_end: float | None = None
    current_lines: list[str] = []

    def flush_current() -> None:
        nonlocal current_start, current_end, current_lines
        if current_start is not None and current_end is not None and current_lines:
            chunk_text = normalized_text(" ".join(current_lines))
            if chunk_text:
                chunks.append(TranscriptChunk(current_start, current_end, chunk_text))
        current_start = None
        current_end = None
        current_lines = []

    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line:
            flush_current()
            skip_note = False
            continue
        if skip_note:
            continue
        if line.isdigit() or "-->" in line:
            if "-->" in line:
                match = SRT_TIMESTAMP_RE.search(line)
                if match:
                    current_start = parse_srt_timecode(match.group("start"))
                    current_end = parse_srt_timecode(match.group("end"))
            continue
        if line.startswith("NOTE"):
            skip_note = True
            continue
        cleaned = strip_subtitle_inline_markup(line)
        if cleaned:
            current_lines.append(cleaned)
    flush_current()
    return chunks


def transcript_chunks_from_ass(text: str) -> list[TranscriptChunk]:
    chunks: list[TranscriptChunk] = []
    for raw_line in text.splitlines():
        if not raw_line.startswith("Dialogue:"):
            continue
        _prefix, _separator, payload = raw_line.partition(":")
        parts = payload.lstrip().split(",", 9)
        if len(parts) < 10:
            continue
        cleaned = strip_subtitle_inline_markup(parts[9])
        if cleaned:
            chunks.append(TranscriptChunk(parse_ass_timecode(parts[1]), parse_ass_timecode(parts[2]), cleaned))
    return chunks


def transcript_text_from_srt(text: str, *, paragraphs: bool = False) -> str:
    return transcript_text_from_chunks(transcript_chunks_from_srt(text), paragraphs=paragraphs)


def transcript_text_from_ass(text: str, *, paragraphs: bool = False) -> str:
    return transcript_text_from_chunks(transcript_chunks_from_ass(text), paragraphs=paragraphs)


def transcript_text_from_subtitle_path(path: Path, *, paragraphs: bool = False) -> str:
    text = path.read_text(encoding="utf-8-sig")
    if path.suffix.lower() == ".ass":
        return transcript_text_from_ass(text, paragraphs=paragraphs)
    return transcript_text_from_srt(text, paragraphs=paragraphs)


def write_transcript_from_subtitle(subtitle_path: Path, text_path: Path, *, paragraphs: bool = False) -> None:
    write_txt(text_path, transcript_text_from_subtitle_path(subtitle_path, paragraphs=paragraphs))


def output_root_for_media(media_path: Path, env: dict[str, str]) -> Path:
    return Path(env.get("WHISPER_OUTDIR", "")).expanduser() if env.get("WHISPER_OUTDIR", "") else media_path.parent


def existing_transcript_source_subtitle_path(media_path: Path, output_root: Path, preferred_suffix: str) -> Path | None:
    preferred = output_root / f"{media_path.stem}{preferred_suffix}"
    if preferred.exists() and preferred.is_file():
        return preferred
    for suffix in (".srt", ".ass"):
        candidate = output_root / f"{media_path.stem}{suffix}"
        if candidate.exists() and candidate.is_file():
            return candidate
    return None


def legacy_mlx_text_output_requested(env: dict[str, str], backend: str) -> bool:
    return (
        backend == "mlx"
        and env.get("WHISPER_MLX_OUTPUT_FORMAT", "auto") == "text"
        and env.get("WHISPER_ASS", "0") != "1"
        and env.get("WHISPER_BURN", "0") != "1"
        and env.get("WHISPER_EMBED", "0") != "1"
    )


def should_write_transcript(env: dict[str, str], backend: str) -> bool:
    return (
        env.get("WHISPER_TRANSCRIPT", "0") == "1"
        or env.get("WHISPER_TRANSCRIPT_ONLY", "0") == "1"
        or env.get("WHISPER_SPEAKER_LABELS", "0") == "1"
        or legacy_mlx_text_output_requested(env, backend)
    )


def should_write_text_output(env: dict[str, str], backend: str) -> bool:
    return env.get("WHISPER_TRANSCRIPT_ONLY", "0") == "1" or legacy_mlx_text_output_requested(env, backend)


def transcription_output_plan(media_path: Path, env: dict[str, str], backend: str) -> dict[str, object]:
    output_root = output_root_for_media(media_path, env)
    output_txt = should_write_text_output(env, backend)
    transcript_requested = should_write_transcript(env, backend)
    speaker_labels_requested = env.get("WHISPER_SPEAKER_LABELS", "0") == "1"
    actions: list[str] = ["transcribe"]
    expected_outputs: list[Path] = []
    subtitle_path: Path | None = None
    text_path: Path | None = None
    transcript_source_subtitle_path: Path | None = None
    embedded_path: Path | None = None
    embedded_codec: str | None = None
    burn_path: Path | None = None
    postprocess_actions = False
    in_place_action = False
    if transcript_requested:
        text_path = output_root / f"{media_path.stem}.txt"
        if not speaker_labels_requested:
            transcript_source_subtitle_path = existing_transcript_source_subtitle_path(
                media_path,
                output_root,
                ".ass" if env.get("WHISPER_ASS", "0") == "1" else ".srt",
            )
        expected_outputs.append(text_path)
        actions.append("write-transcript")
        if speaker_labels_requested:
            actions.append("label-speakers")
    if output_txt:
        actions.append("transcript-only")
    else:
        subtitle_path = output_root / f"{media_path.stem}.{'ass' if env.get('WHISPER_ASS', '0') == '1' else 'srt'}"
        expected_outputs.append(subtitle_path)
        actions.append("write-ass" if env.get("WHISPER_ASS", "0") == "1" else "write-srt")
        if env.get("WHISPER_EMBED", "0") == "1" and media_path.suffix.lower() in VIDEO_EXTENSIONS:
            embedded_path, embedded_codec = embedded_subtitle_plan(media_path, subtitle_path, output_root)
            postprocess_actions = True
            if env.get("WHISPER_IN_PLACE", "0") == "1":
                in_place_action = True
                actions.append("embed-in-place")
            else:
                expected_outputs.append(embedded_path)
                actions.append("embed")
        if env.get("WHISPER_BURN", "0") == "1" and media_path.suffix.lower() in VIDEO_EXTENSIONS:
            burn_path = output_root / f"{media_path.stem}_subbed.mp4"
            expected_outputs.append(burn_path)
            postprocess_actions = True
            actions.append("burn")
    return {
        "media_path": media_path,
        "mode": "transcribe",
        "backend": backend,
        "output_root": output_root,
        "actions": tuple(actions),
        "expected_outputs": tuple(expected_outputs),
        "subtitle_path": subtitle_path,
        "text_path": text_path,
        "transcript_source_subtitle_path": transcript_source_subtitle_path,
        "embedded_path": embedded_path,
        "embedded_codec": embedded_codec,
        "burn_path": burn_path,
        "postprocess_actions": postprocess_actions,
        "in_place_action": in_place_action,
    }


def embed_file_output_plan(media_path: Path, env: dict[str, str], subtitle_path: Path | None = None) -> dict[str, object]:
    output_root = output_root_for_media(media_path, env)
    subtitle_path = subtitle_path or resolve_embed_subtitle_path(media_path, env.get("WHISPER_EMBED_FILE", ""))
    actions: list[str] = ["embed-existing-subtitle"]
    expected_outputs: list[Path] = []
    embedded_path: Path | None = None
    embedded_codec: str | None = None
    burn_path: Path | None = None
    in_place_action = False
    if media_path.suffix.lower() in VIDEO_EXTENSIONS:
        if env.get("WHISPER_EMBED", "0") == "1":
            embedded_path, embedded_codec = embedded_subtitle_plan(media_path, subtitle_path, output_root)
            if env.get("WHISPER_IN_PLACE", "0") == "1":
                in_place_action = True
                actions.append("embed-in-place")
            else:
                expected_outputs.append(embedded_path)
                actions.append("embed")
        if env.get("WHISPER_BURN", "0") == "1":
            burn_path = output_root / f"{media_path.stem}_subbed.mp4"
            expected_outputs.append(burn_path)
            actions.append("burn")
    return {
        "media_path": media_path,
        "mode": "embed-file",
        "output_root": output_root,
        "actions": tuple(actions),
        "expected_outputs": tuple(expected_outputs),
        "subtitle_path": subtitle_path,
        "text_path": None,
        "embedded_path": embedded_path,
        "embedded_codec": embedded_codec,
        "burn_path": burn_path,
        "postprocess_actions": bool(embedded_path or burn_path or in_place_action),
        "in_place_action": in_place_action,
    }


def output_plan_complete(plan: dict[str, object]) -> bool:
    if plan.get("in_place_action"):
        return False
    expected_outputs = tuple(path for path in plan.get("expected_outputs", ()) if isinstance(path, Path))
    return bool(expected_outputs) and all(path.exists() for path in expected_outputs)


def output_plan_resume_from_subtitle(plan: dict[str, object]) -> bool:
    subtitle_path = plan.get("subtitle_path")
    return (
        isinstance(subtitle_path, Path)
        and subtitle_path.exists()
        and bool(plan.get("postprocess_actions"))
        and not output_plan_complete(plan)
    )


def output_plan_can_derive_transcript_from_subtitle(plan: dict[str, object]) -> bool:
    text_path = plan.get("text_path")
    source_path = plan.get("transcript_source_subtitle_path")
    return (
        isinstance(text_path, Path)
        and not text_path.exists()
        and isinstance(source_path, Path)
        and source_path.exists()
    )


def output_plan_status(plan: dict[str, object], *, force: bool) -> str:
    if force:
        return "will run because --force is set"
    if output_plan_complete(plan):
        return "will skip because expected outputs already exist"
    if output_plan_can_derive_transcript_from_subtitle(plan):
        return "will write transcript from existing subtitles"
    if plan.get("mode") == "transcribe" and output_plan_resume_from_subtitle(plan):
        return "will reuse existing subtitles and finish requested video outputs"
    if plan.get("mode") == "embed-file":
        return "will embed existing subtitles"
    return "will transcribe"


def write_transcript_output(
    media_path: Path,
    output_root: Path,
    segments: list[dict[str, float | str | list[dict[str, float | str]]]],
    backend: str,
    *,
    speech_trim_enabled: bool,
    suppression_sources: tuple[Path, ...],
    compact_status: bool,
    show_stage_messages: bool,
    paragraphs: bool = False,
    speaker_labels: bool = False,
    mlx_result: dict | None = None,
) -> Path:
    text_path = output_root / f"{media_path.stem}.txt"
    plain_text = transcript_text_from_chunks(
        transcript_chunks_from_segments(segments),
        paragraphs=paragraphs,
        speaker_labels=speaker_labels,
    )
    if not plain_text and backend == "mlx" and not speech_trim_enabled and not suppression_sources and mlx_result:
        plain_text = normalized_text(str(mlx_result.get("text", "")))
    write_txt(text_path, plain_text)
    if show_stage_messages:
        print("📝 Wrote transcript." if compact_status else f"📝 Wrote transcript: {media_path.name}", file=sys.stderr)
    return text_path


def output_plan_to_jsonable(plan: dict[str, object], *, force: bool) -> dict[str, object]:
    encoded = dict(plan)
    encoded["status"] = output_plan_status(plan, force=force)
    encoded["complete"] = output_plan_complete(plan)
    encoded["resume_from_subtitle"] = output_plan_resume_from_subtitle(plan)
    encoded["derive_transcript_from_subtitle"] = output_plan_can_derive_transcript_from_subtitle(plan)
    return json_safe(encoded)


