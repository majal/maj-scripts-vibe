################################################################################
# Main

DEFAULT_DIR="$HOME/dig/faster-whisper"
WORK_DIR="$DEFAULT_DIR"

UPDATE=0
HELP=0
LANG="en"
MODEL="small"
OUTDIR=""
JOBS=1
BURN=0
STYLE="default"
FONT="default"
KARAOKE=0
ASS=0
TARGET=""

CMD_NAME="$(basename "$0")"

# === PARSE ARGS ===
for arg in "$@"; do
  case $arg in
    -h|--help) HELP=1 ;;
    --update) UPDATE=1 ;;
    --lang=*) LANG="${arg#*=}" ;;
    --dir=*) WORK_DIR="${arg#*=}" ;;
    --model=*) MODEL="${arg#*=}" ;;
    --outdir=*) OUTDIR="${arg#*=}" ;;
    --jobs=*) JOBS="${arg#*=}" ;;
    --burn) BURN=1 ;;
    --style=*) STYLE="${arg#*=}" ;;
    --font=*) FONT="${arg#*=}" ;;
    --karaoke) KARAOKE=1 ;;
    --ass) ASS=1 ;;
    *) TARGET="$arg" ;;
  esac
done

# === HELP ===
if [ $HELP -eq 1 ]; then
cat << EOF
$CMD_NAME — GPU subtitle + transcription CLI

USAGE:
  $CMD_NAME <file_or_folder> [OPTIONS]

CORE:
  --lang=en|auto
  --model=tiny|base|small|medium|large
  --jobs=N

OUTPUT:
  --outdir=PATH
  --ass
  --burn

STYLE:
  --style=pretty
  --font=mpv
  --karaoke

SYSTEM:
  --dir=PATH
  --update

EXAMPLES:
  $CMD_NAME video.mp4
  $CMD_NAME ./videos --jobs=2
  $CMD_NAME video.mp4 --ass --burn --karaoke

EOF
exit 0
fi

VENV_PATH="$WORK_DIR/venv"
PYTHON="$VENV_PATH/bin/python"

if [ ! -f "$PYTHON" ]; then
  echo "❌ venv not found: $VENV_PATH"
  exit 1
fi

source "$VENV_PATH/bin/activate"

# === UPDATE ===
if [ $UPDATE -eq 1 ]; then
  $PYTHON -m pip install --upgrade pip faster-whisper ctranslate2 tqdm
  [ -z "$TARGET" ] && exit 0
fi

[ -z "$TARGET" ] && echo "Run --help" && exit 1

# === PYTHON ===
$PYTHON - << EOF
import os, sys, subprocess, re, time
from faster_whisper import WhisperModel
from tqdm import tqdm
from concurrent.futures import ThreadPoolExecutor, as_completed

LANG="$LANG"
MODEL="$MODEL"
OUTDIR="$OUTDIR"
JOBS=int("$JOBS")
BURN=int("$BURN")
STYLE="$STYLE"
FONT="$FONT"
KARAOKE=int("$KARAOKE")
ASS=int("$ASS")
TARGET="$TARGET"

# --- simple sentence splitter (no nltk) ---
def split_sentences(text):
    return re.split(r'(?<=[.!?]) +', text)

def split_lines(text):
    w = text.split()
    if len(w) <= 8:
        return [text]
    mid = len(w) // 2
    return [" ".join(w[:mid]), " ".join(w[mid:])]

def format_time(t):
    return f"{int(t//3600):02}:{int((t%3600)//60):02}:{int(t%60):02},{int((t%1)*1000):03}"

def get_files(p):
    if os.path.isfile(p):
        return [p]
    return [
        os.path.join(p, f)
        for f in os.listdir(p)
        if f.lower().endswith((".mp4",".mkv",".avi",".mp3",".wav",".m4a",".flac"))
    ]

def burn(video, sub, out):
    vf = f"ass={sub}" if sub.endswith(".ass") else f"subtitles={sub}"
    subprocess.run(
        ["ffmpeg","-y","-i",video,"-vf",vf,"-c:a","copy",out],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL
    )

def write_ass(path, segs):
    font = "DejaVu Sans" if FONT == "mpv" else "Arial"
    with open(path, "w") as f:
        f.write("[Script Info]\\nScriptType: v4.00+\\n\\n")
        f.write("[V4+ Styles]\\n")
        f.write("Format: Name,Fontname,Fontsize,PrimaryColour,OutlineColour,BorderStyle,Outline,Shadow,Alignment,MarginL,MarginR,MarginV\\n")
        f.write(f"Style: Default,{font},28,&H00FFFFFF,&H00000000,1,2,1,2,20,20,40\\n\\n")
        f.write("[Events]\\nFormat: Layer,Start,End,Style,Text\\n")

        for seg in segs:
            if not hasattr(seg, "words") or not seg.words:
                continue

            words = seg.words
            line = ""

            for w in words:
                d = int((w.end - w.start) * 100)
                if KARAOKE:
                    tag = f"\\\\k{d}"
                    line += f"{{{tag}}}{w.word.strip()} "
                else:
                    line += w.word + " "

            start = format_time(words[0].start).replace(",", ".")
            end = format_time(words[-1].end).replace(",", ".")

            f.write(f"Dialogue: 0,{start},{end},Default,{line.strip()}\\n")

# --- main ---
files = get_files(TARGET)
if not files:
    print("❌ No files found")
    sys.exit(1)

if OUTDIR:
    os.makedirs(OUTDIR, exist_ok=True)

print("🚀 Loading model...")
model = WhisperModel(MODEL, device="cuda", compute_type="int8_float16")

def process(file):
    start_time = time.time()

    segs, _ = model.transcribe(
        file,
        language=None if LANG == "auto" else LANG,
        vad_filter=True,
        word_timestamps=True
    )

    segs = list(segs)

    base = os.path.splitext(os.path.basename(file))[0]
    out_base = OUTDIR if OUTDIR else os.path.dirname(file)

    bar = tqdm(total=len(segs), desc=f"🧠 {base}", leave=False)

    if ASS:
        out = os.path.join(out_base, base + ".ass")
        write_ass(out, segs)
        bar.update(len(segs))
    else:
        out = os.path.join(out_base, base + ".srt")
        i = 1
        with open(out, "w") as f:
            for seg in segs:
                sents = split_sentences(seg.text.strip())
                dur = (seg.end - seg.start) / max(len(sents), 1)

                for j, s in enumerate(sents):
                    start = seg.start + j * dur
                    end = start + dur

                    f.write(f"{i}\\n{format_time(start)} --> {format_time(end)}\\n")
                    for line in split_lines(s.strip()):
                        f.write(line + "\\n")
                    f.write("\\n")
                    i += 1

                bar.update(1)

    bar.close()

    if BURN and file.lower().endswith((".mp4",".mkv",".avi")):
        vid = os.path.join(out_base, base + "_subbed.mp4")
        burn(file, out, vid)

    elapsed = time.time() - start_time
    return f"{base} ({elapsed:.1f}s)"

# --- progress ---
with tqdm(total=len(files), desc="📦 Files") as pbar:
    if JOBS > 1:
        with ThreadPoolExecutor(max_workers=JOBS) as ex:
            futures = [ex.submit(process, f) for f in files]
            for fut in as_completed(futures):
                tqdm.write(f"✅ {fut.result()}")
                pbar.update(1)
    else:
        for f in files:
            res = process(f)
            tqdm.write(f"✅ {res}")
            pbar.update(1)

print("🎉 Done")
EOF
