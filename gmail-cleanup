        ]
    )


def render_index_stats(stats: dict[str, object]) -> str:
    lines = [
        "Mode: index-stats",
        f"Index DB: {stats['index_db']}",
        f"Indexed messages: {stats['message_count']}",
        f"Raw message bytes: {human_size(int(stats['raw_size_bytes']))}",
        f"Compressed payload bytes: {human_size(int(stats['compressed_size_bytes']))}",
    ]
    for query in stats["queries"]:
        lines.append(f"- {query['message_count']} message(s): {query['query']}")
    return "\n".join(lines)


def message_sender_domain(message: EmailMessage) -> str:
    address = parseaddr(header_value(message, "From"))[1].strip().lower()
    if "@" not in address:
        return "unknown"
    return address.rsplit("@", 1)[1]


def message_year(message: EmailMessage) -> int | None:
    try:
        return parsedate_to_datetime(header_value(message, "Date")).year
    except (TypeError, ValueError, IndexError, OverflowError):
        return None


def is_analyzable_attachment_part(part: EmailMessage) -> bool:
    if part.is_multipart():
        return False
    disposition = (part.get_content_disposition() or "").lower()
    if part.get_filename() or disposition in {"attachment", "inline"}:
        return True
    if part.get("Content-ID") and part.get_content_maintype().lower() in {"image", "video"}:
        return True
    return False


def counter_items(counter: Counter, *, top: int, include_bytes: Counter | None = None) -> list[dict[str, object]]:
    rows: list[dict[str, object]] = []
    for key, count in counter.most_common(top):
        row: dict[str, object] = {"key": key, "count": count}
        if include_bytes is not None:
            size = int(include_bytes[key])
            row["bytes"] = size
            row["human"] = human_size(size)
        rows.append(row)
    return rows


def top_bytes_items(counter: Counter, *, top: int) -> list[dict[str, object]]:
    return [
        {
            "key": key,
            "bytes": int(size),
            "human": human_size(int(size)),
        }
        for key, size in counter.most_common(top)
    ]


def indexed_cleanup_suggestions(query: str | None) -> list[dict[str, str]]:
    base_query = query or "has:attachment -in:trash -in:spam"
    base = f"gmail-cleanup report --query {json.dumps(base_query)} --max-results 50000 --use-index"
    return [
        {
            "name": "large-media",
            "command": f"{base} --types image,video --min-message-bytes 1000000",
        },
        {
            "name": "office",
            "command": f"{base} --types office",
        },
        {
            "name": "archive",
            "command": f"{base} --types archive",
        },
        {
            "name": "audio",
            "command": f"{base} --types audio",
        },
        {
            "name": "older-than-2018-media",
            "command": f"{base} --types image,video --before-year 2018",
        },
    ]


def run_index_analyze(index_db: Path, *, query: str | None = None, max_results: int | None = None, top: int = 20) -> dict[str, object]:
    if max_results is not None and max_results < 1:
        raise ValueError("--max-results must be 1 or greater")
    if top < 1:
        raise ValueError("--top must be 1 or greater")
    gmail_index = GmailIndex(index_db)
    try:
        records = gmail_index.message_records(query=query, max_results=max_results)
    finally:
        gmail_index.close()
    if query is not None and not records:
        raise ValueError(f"No cached messages found for query: {query}")

    category_parts: Counter = Counter()
    category_bytes: Counter = Counter()
    category_messages: dict[str, set[str]] = defaultdict(set)
    disposition_counts: Counter = Counter()
    duplicate_payloads: dict[str, list[dict[str, object]]] = defaultdict(list)
    extension_counts: Counter = Counter()
    extension_bytes: Counter = Counter()
    mime_counts: Counter = Counter()
    mime_bytes: Counter = Counter()
    sender_counts: Counter = Counter()
    sender_bytes: Counter = Counter()
    year_counts: Counter = Counter()
    year_bytes: Counter = Counter()
    largest_messages: list[dict[str, object]] = []
    attachment_parts = 0
    attachment_bytes = 0

    for record in records:
        message = parse_email_message(record.raw_bytes)
        domain = message_sender_domain(message)
        year = message_year(message)
        if year is not None:
            year_counts[str(year)] += 1
        sender_counts[domain] += 1
        message_attachment_bytes = 0
        message_parts = 0
        biggest_part: dict[str, object] | None = None
        for part in message.walk():
            if not is_analyzable_attachment_part(part):
                continue
            payload = part.get_payload(decode=True) or b""
            size = len(payload)
            filename = derive_attachment_filename(part, message_parts + 1)
            mime_type = infer_attachment_mime_type(part)
            extension = attachment_extension(filename) or "(none)"
            categories = attachment_categories_for_part(part)
            if "media" in categories and size >= LARGE_MEDIA_MIN_PART_BYTES:
                categories.add("large-media")
            attachment_parts += 1
            attachment_bytes += size
            message_parts += 1
            message_attachment_bytes += size
            disposition = (part.get_content_disposition() or "(none)").lower()
            disposition_counts[disposition] += 1
            extension_counts[extension] += 1
            extension_bytes[extension] += size
            mime_counts[mime_type] += 1
            mime_bytes[mime_type] += size
            for category in categories:
                category_parts[category] += 1
                category_bytes[category] += size
                category_messages[category].add(record.message_id)
            if payload:
                duplicate_payloads[hashlib.sha256(payload).hexdigest()].append(
                    {
                        "message_id": record.message_id,
                        "filename": filename,
                        "mime_type": mime_type,
                        "size_bytes": size,
                        "sender_domain": domain,
                    }
                )
            if biggest_part is None or size > int(biggest_part["size_bytes"]):
                biggest_part = {
                    "filename": filename,
                    "mime_type": mime_type,
                    "size_bytes": size,
                    "human": human_size(size),
                }
        sender_bytes[domain] += message_attachment_bytes
        if year is not None:
            year_bytes[str(year)] += message_attachment_bytes
        if message_parts:
            largest_messages.append(
                {
                    "attachment_bytes": message_attachment_bytes,
                    "attachment_human": human_size(message_attachment_bytes),
                    "biggest_part": biggest_part,
                    "message_id": record.message_id,
                    "sender_domain": domain,
                    "subject": header_value(message, "Subject"),
                }
            )

    duplicate_groups = [items for items in duplicate_payloads.values() if len(items) > 1]
    duplicate_groups.sort(key=lambda items: (len(items) - 1) * int(items[0]["size_bytes"]), reverse=True)
    duplicate_reclaimable = sum((len(items) - 1) * int(items[0]["size_bytes"]) for items in duplicate_groups)
    categories = [
        {
            "bytes": int(category_bytes[name]),
            "human": human_size(int(category_bytes[name])),
            "messages": len(category_messages[name]),
            "name": name,
            "parts": int(category_parts[name]),
        }
        for name in sorted(category_parts, key=lambda item: (-category_bytes[item], item))
    ]
    return {
        "attachment_bytes": attachment_bytes,
        "attachment_human": human_size(attachment_bytes),
        "attachment_parts": attachment_parts,
        "categories": categories,
        "dispositions": counter_items(disposition_counts, top=top),
        "duplicates": {
            "groups": len(duplicate_groups),
            "instances": sum(len(items) for items in duplicate_groups),
            "reclaimable_bytes": duplicate_reclaimable,
            "reclaimable_human": human_size(duplicate_reclaimable),
            "top_groups": [
                {
                    "each_bytes": int(items[0]["size_bytes"]),
                    "each_human": human_size(int(items[0]["size_bytes"])),
                    "filename": items[0]["filename"],
                    "instances": len(items),
                    "mime_type": items[0]["mime_type"],
                    "reclaimable_bytes": (len(items) - 1) * int(items[0]["size_bytes"]),
                    "reclaimable_human": human_size((len(items) - 1) * int(items[0]["size_bytes"])),
                    "sample_sender_domains": sorted({str(item["sender_domain"]) for item in items})[:5],
                }
                for items in duplicate_groups[:top]
            ],
        },
        "extensions_by_bytes": top_bytes_items(extension_bytes, top=top),
        "extensions_by_count": counter_items(extension_counts, top=top, include_bytes=extension_bytes),
        "index_db": str(index_db),
        "largest_messages": sorted(largest_messages, key=lambda item: int(item["attachment_bytes"]), reverse=True)[:top],
        "messages_analyzed": len(records),
        "mimes_by_bytes": top_bytes_items(mime_bytes, top=top),
        "mimes_by_count": counter_items(mime_counts, top=top, include_bytes=mime_bytes),
        "mode": "index-analyze",
        "query": query,
        "sender_domains_by_bytes": top_bytes_items(sender_bytes, top=top),
        "sender_domains_by_count": counter_items(sender_counts, top=top, include_bytes=sender_bytes),
        "suggested_reports": indexed_cleanup_suggestions(query),
        "years": [
            {
                "bytes": int(year_bytes[year]),
                "count": int(year_counts[year]),
                "human": human_size(int(year_bytes[year])),
                "year": year,
            }
            for year in sorted(year_counts)
        ],
    }


def render_index_analyze(summary: dict[str, object]) -> str:
    lines = [
        f"Mode: {summary['mode']}",
        f"Index DB: {summary['index_db']}",
        f"Query: {summary['query'] or '(all indexed messages)'}",
        f"Messages analyzed: {summary['messages_analyzed']}",
        f"Attachment parts: {summary['attachment_parts']}",
        f"Attachment bytes: {summary['attachment_human']}",
        "Selectors by bytes:",
    ]
    for category in summary["categories"]:
        lines.append(
            f"- {category['name']}: {category['messages']} message(s), "
            f"{category['parts']} part(s), {category['human']}"
        )
    duplicates = summary["duplicates"]
    lines.extend(
        [
            "Duplicates:",
            f"- groups: {duplicates['groups']}",
            f"- instances: {duplicates['instances']}",
            f"- reclaimable estimate: {duplicates['reclaimable_human']}",
            "Top extensions by bytes:",
        ]
    )
    for item in summary["extensions_by_bytes"]:
        lines.append(f"- {item['key']}: {item['human']}")
    lines.append("Suggested report commands:")
    for suggestion in summary["suggested_reports"]:
        lines.append(f"- {suggestion['name']}: {suggestion['command']}")
    return "\n".join(lines)


def run_report(
    client,
    query: str,
    max_results: int,
    settings: ExtractionSettings,
    *,
    request_profile: str = "moderate",
    backup_dir: Path | None = None,
    gmail_link_account: str | None = None,
) -> dict[str, object]:
    if max_results < 1:
        raise ValueError("--max-results must be 1 or greater")
    message_ids = client.list_message_ids(query, max_results)
    profile_config = REQUEST_PROFILE_CONFIG[request_profile]
    records = client.get_message_raw_many(
        message_ids,
        batch_size=int(profile_config["batch_size"]),
        max_inflight=int(profile_config["max_inflight"]),
    )
    items: list[dict[str, object]] = []
    counts = {"actionable": 0, "ignored_sidecar": 0, "false_positive": 0, "skipped": 0}
    completed_records = completed_manifest_records_by_original_id(backup_dir) if backup_dir is not None else {}
    exported_records = exported_manifest_records_by_original_id(backup_dir) if backup_dir is not None else {}
    manifest_counts = {"pending": 0, "exported_pending_gmail_sync": 0, "completed": 0}
    pending_backup_candidates = 0
    exported_pending_gmail_sync = 0
    remaining_gmail_sync_candidates = 0
    for record in records:
        plan = plan_message(record, settings)
        message = parse_email_message(record.raw_bytes)
        if plan.skip_reason:
            category = "skipped"
        elif plan.media_parts:
            category = "actionable"
        elif message_has_only_ignored_sidecars(message):
            category = "ignored_sidecar"
        else:
            category = "false_positive"
        completed_record = completed_records.get(plan.message_id)
        exported_record = exported_records.get(plan.message_id)
        if completed_record is not None:
            migration_status = "completed"
        elif exported_record is not None:
            migration_status = "exported_pending_gmail_sync"
        else:
            migration_status = "pending"
        if backup_dir is not None:
            manifest_counts[migration_status] += 1
            if category == "actionable":
                if migration_status == "pending":
                    pending_backup_candidates += 1
                elif migration_status == "exported_pending_gmail_sync":
                    exported_pending_gmail_sync += 1
                if migration_status != "completed":
                    remaining_gmail_sync_candidates += 1
        counts[category] += 1
        item = {
            "category": category,
            "date_header": plan.date_header,
            "filenames": message_filename_records(message),
            "label_ids": list(plan.label_ids),
            "media_parts": [part for part in plan_to_dict(plan)["media_parts"]],
            "message_id": plan.message_id,
            "sender": plan.sender,
            "skip_reason": plan.skip_reason,
            "subject": plan.subject,
            "thread_id": plan.thread_id,
        }
        if backup_dir is not None:
            item["migration_status"] = migration_status
            if completed_record is not None:
                item["completed_at"] = completed_record.get("applied_at")
                item["new_message_id"] = completed_record.get("new_message_id")
            elif exported_record is not None:
                item["exported_at"] = exported_record.get("exported_at")
                item["exported_attachment_count"] = len(exported_record.get("attachments", []))
        if gmail_link_account is not None:
            item["gmail_url"] = gmail_thread_url(plan.thread_id, gmail_link_account)
        items.append(item)
    report = {
        "counts": counts,
        "items": items,
        "matched_messages": len(message_ids),
        "mode": "report",
        "query": query,
        "request_profile": request_profile,
    }
    if backup_dir is not None:
        report["local_manifest"] = {
            "backup_dir": str(backup_dir),
            "counts": manifest_counts,
            "pending_backup_candidates": pending_backup_candidates,
            "exported_pending_gmail_sync": exported_pending_gmail_sync,
            "remaining_gmail_sync_candidates": remaining_gmail_sync_candidates,
        }
    return report


def render_report(report: dict[str, object]) -> str:
    counts = report["counts"]
    lines = [
        f"Mode: {report['mode']}",
        f"Query: {report['query']}",
        f"Matched Gmail messages: {report['matched_messages']}",
        f"Actionable: {counts['actionable']}",
        f"Ignored sidecars: {counts['ignored_sidecar']}",
        f"False positives: {counts['false_positive']}",
        f"Skipped: {counts['skipped']}",
    ]
    local_manifest = report.get("local_manifest")
    if local_manifest:
        manifest_counts = local_manifest["counts"]
        lines.extend(
            [
                f"Local manifest: {local_manifest['backup_dir']}",
                f"Completed locally/Gmail synced: {manifest_counts['completed']}",
                f"Exported locally, Gmail sync pending: {manifest_counts['exported_pending_gmail_sync']}",
                f"Pending local backup: {manifest_counts['pending']}",
                f"Remaining Gmail sync candidates: {local_manifest['remaining_gmail_sync_candidates']}",
            ]
        )
    for item in report["items"]:
        migration_status = item.get("migration_status")
        status_suffix = f" [{migration_status}]" if migration_status else ""
        lines.append(
            f"- {item['category']}{status_suffix}: {item['message_id']} {item['subject'] or '(no subject)'} "
            f"from {item['sender'] or '(unknown sender)'}"
        )
        if item.get("skip_reason"):
            lines.append(f"    reason: {item['skip_reason']}")
        if item.get("gmail_url"):
            lines.append(f"    link: {item['gmail_url']}")
        filenames = item.get("filenames") or []
        for filename in filenames:
            if item["category"] == "skipped" and filename.get("ignored_sidecar"):
                continue
            prefix = "ignored sidecar" if filename.get("ignored_sidecar") else "file"
            lines.append(f"    {prefix}: {filename['filename']} ({filename['content_type']})")
    return "\n".join(lines)


def doctor_row(name: str, status: str, detail: str) -> dict[str, str]:
    return {"name": name, "status": status, "detail": detail}


def token_scope_set(token_path: Path) -> set[str]:
    payload = json.loads(token_path.read_text(encoding="utf-8"))
    raw_scopes = payload.get("scopes") or payload.get("scope") or ()
    if isinstance(raw_scopes, str):
        return set(raw_scopes.split())
    if isinstance(raw_scopes, list):
        return {str(scope) for scope in raw_scopes}
    return set()


def tool_status(name: str, purpose: str, *, required: bool = False) -> dict[str, str]:
    found = shutil.which(name)
    if found:
        return doctor_row(name, "ok", f"{purpose}: {found}")
    return doctor_row(name, "fail" if required else "warn", f"{purpose}: not found on PATH")


def python_module_status(module_name: str) -> dict[str, str]:
    try:
        found = importlib.util.find_spec(module_name)
    except ModuleNotFoundError:
        found = None
    if found is not None:
        return doctor_row(module_name, "ok", "importable")
    return doctor_row(module_name, "fail", "not importable")


def run_doctor(args: argparse.Namespace) -> dict[str, object]:
    rows: list[dict[str, str]] = []
    config_path = resolve_config_path(args.config)
    try:
        config = load_config(config_path)
    except ValueError as exc:
        config = {}
        rows.append(doctor_row("config", "fail", str(exc)))
    else:
        rows.append(
            doctor_row(
                "config",
                "ok" if config_path.exists() else "warn",
                str(config_path) if config_path.exists() else f"not found; defaults/env will be used ({config_path})",
            )
        )

    try:
        backup_dir = resolve_backup_dir(args.backup_dir, config, config_path).expanduser()
    except ValueError as exc:
        rows.append(doctor_row("backup_dir", "fail", str(exc)))
    else:
        status = "ok" if backup_dir.exists() and os.access(backup_dir, os.W_OK) else "warn"
        detail = str(backup_dir) if backup_dir.exists() else f"does not exist yet: {backup_dir}"
        rows.append(doctor_row("backup_dir", status, detail))

    try:
        credentials_path = resolve_credentials_path(args.credentials, config, config_path)
    except ValueError as exc:
        rows.append(doctor_row("credentials", "fail", str(exc)))
    else:
        rows.append(doctor_row("credentials", "ok", str(credentials_path)))

    token_path = resolve_token_cache_path(args.token_cache, config, config_path)
    if token_path.exists():
        try:
            scopes = token_scope_set(token_path)
        except (OSError, json.JSONDecodeError) as exc:
            rows.append(doctor_row("token_cache", "fail", f"cannot read {token_path}: {exc}"))
        else:
            missing = [scope for scope in APPLY_SCOPES if scope not in scopes]
            status = "ok" if not missing else "warn"
            detail = str(token_path) if not missing else f"{token_path}; missing apply scope(s): {', '.join(missing)}"
            rows.append(doctor_row("token_cache", status, detail))
    else:
        rows.append(doctor_row("token_cache", "warn", f"not found yet: {token_path}"))

    gmail_user = resolve_gmail_user(args.gmail_user, config, config_path)
    rows.append(doctor_row("gmail_user", "ok", gmail_user))

    index_db = resolve_index_db_path(getattr(args, "index_db", None), config, config_path)
    rows.append(
        doctor_row(
            "index_db",
            "ok" if index_db.exists() else "warn",
            str(index_db) if index_db.exists() else f"not found yet: {index_db}",
        )
    )

    for module_name in ("googleapiclient.discovery", "google_auth_oauthlib.flow", "google.auth.transport.requests"):
        rows.append(python_module_status(module_name))

    rows.extend(
        [
            tool_status("exiftool", "metadata marker embedding", required=True),
            tool_status("ffmpeg", "video metadata fallback and media conversion"),
            tool_status("ffprobe", "video inspection"),
            tool_status("pdfinfo", "PDF page inspection"),
            tool_status("pdfimages", "direct PDF image extraction"),
            tool_status("pdftocairo", "PDF page rendering"),
            tool_status("pdftotext", "native PDF text extraction"),
            tool_status("ocrmypdf", "PDF OCR sidecar text"),
            tool_status("tesseract", "fallback OCR"),
            tool_status("john", "external PDF password candidate testing"),
            tool_status("pdf2john", "John PDF hash extraction"),
            tool_status("pdfcrack", "fallback PDF password candidate testing"),
            tool_status("qpdf", "PDF password verification/decryption"),
        ]
    )

    os_name = detect_os()
    if os_name == "linux":
        trash_root = Path.home() / ".local" / "share" / "Trash"
        rows.append(doctor_row("trash", "ok", f"freedesktop/XDG Trash path: {trash_root}"))
    elif os_name == "macos":
        rows.append(tool_status("osascript", "macOS Trash integration", required=True))
    elif os_name == "windows":
        rows.append(tool_status("powershell", "Windows Recycle Bin integration", required=True))
    else:
        rows.append(doctor_row("trash", "warn", f"unknown OS for Trash integration: {os_name}"))

    status_order = {"ok": 0, "warn": 1, "fail": 2}
    worst = max(rows, key=lambda row: status_order.get(row["status"], 0))["status"] if rows else "ok"
    return {
        "mode": "doctor",
        "overall_status": worst,
        "checks": rows,
    }


def render_doctor(report: dict[str, object]) -> str:
    lines = [f"Mode: {report['mode']}", f"Overall: {report['overall_status']}"]
    for row in report["checks"]:
        lines.append(f"{row['status'].upper():4} {row['name']}: {row['detail']}")
    return "\n".join(lines)


def inspect_matching_messages(
    client,
    message_ids: list[str],
    settings: ExtractionSettings,
    reporter: ProgressReporter,
    request_profile: str,
    state: InspectionState,
    *,
    plan_queue: queue.Queue[PlannedMessage | object] | None = None,
    apply_queue_context: tuple[Path, str, int] | None = None,
) -> None:
    current_profile = request_profile
    cursor = 0
    batch_index = 0
    try:
        while cursor < len(message_ids):
            profile_config = REQUEST_PROFILE_CONFIG[current_profile]
            message_span = profile_config["batch_size"] * profile_config["max_inflight"]
            chunk_ids = message_ids[cursor : cursor + message_span]
            batch_index += 1
            reporter.log_event(
                2,
                f"Fetching inspection batch {batch_index} with profile {current_profile} ({len(chunk_ids)} message(s))",
                "inspection_batch_started",
                batch_index=batch_index,
                request_profile=current_profile,
                batch_size=profile_config["batch_size"],
                max_inflight=profile_config["max_inflight"],
                message_count=len(chunk_ids),
            )
            attempt = 0
            while True:
                try:
                    records = client.get_message_raw_many(
                        chunk_ids,
                        batch_size=profile_config["batch_size"],
                        max_inflight=profile_config["max_inflight"],
                    )
                    break
                except (GmailRateLimitError, GmailTransientReadError) as exc:
                    sleep_seconds = min(30.0, (2 ** min(attempt, 5)) + random.random())
                    downgraded = downgrade_request_profile(current_profile) if isinstance(exc, GmailRateLimitError) else current_profile
                    event_name = "request_profile_downgraded" if downgraded != current_profile else "inspection_batch_retry"
                    reason = "Rate limited" if isinstance(exc, GmailRateLimitError) else "Transient Gmail read failure"
                    reporter.log_event(
                        1,
                        f"{reason} during inspection [{exc}]; sleeping {sleep_seconds:.1f}s"
                        + (f" and switching {current_profile} -> {downgraded}" if downgraded != current_profile else ""),
                        event_name,
                        from_profile=current_profile,
                        to_profile=downgraded,
                        sleep_seconds=round(sleep_seconds, 3),
                        batch_index=batch_index,
                    )
                    time.sleep(sleep_seconds)
                    current_profile = downgraded
                    profile_config = REQUEST_PROFILE_CONFIG[current_profile]
                    message_span = profile_config["batch_size"] * profile_config["max_inflight"]
                    chunk_ids = message_ids[cursor : cursor + message_span]
                    attempt += 1
            reporter.event(
                "inspection_batch_completed",
                batch_index=batch_index,
                request_profile=current_profile,
                records=len(records),
            )
            for offset, record in enumerate(records, start=1):
                absolute_index = cursor + offset
                if absolute_index == 1 or absolute_index % 25 == 0 or absolute_index == len(message_ids):
                    reporter.log(1, f"Inspecting search match {absolute_index}/{len(message_ids)}: {record.message_id}")
                reporter.log(3, f"Inspecting {absolute_index}/{len(message_ids)}: {record.message_id}")
                plan = plan_message(record, settings)
                if plan.skip_reason:
                    state.skipped.append(plan)
                    reporter.log_event(
                        2,
                        f"Skipped {format_message_label(plan)} [{plan.skip_reason}]",
                        "message_skipped",
                        message_id=plan.message_id,
                        reason=plan.skip_reason,
                    )
                elif plan.media_parts:
                    state.planned.append(plan)
                    reporter.log_event(
                        2,
                        f"Selected {format_message_label(plan)} with {len(plan.media_parts)} attachment part(s)",
                        "message_selected",
                        message_id=plan.message_id,
                        media_parts=len(plan.media_parts),
                    )
                    if plan_queue is not None:
                        if apply_queue_context is not None:
                            backup_dir, query, max_results = apply_queue_context
                            append_apply_queue_record(backup_dir, query, max_results, settings, plan)
                        plan_queue.put(plan)
            cursor += len(records)
        selected_parts = sum(len(plan.media_parts) for plan in state.planned)
        selected_bytes = sum(part.size_bytes for plan in state.planned for part in plan.media_parts)
        reporter.log_event(
            1,
            f"Planned {len(state.planned)} candidate message(s), {selected_parts} attachment part(s), {human_size(selected_bytes)} total",
            "inspection_completed",
            candidate_messages=len(state.planned),
            candidate_media_parts=selected_parts,
            candidate_bytes=selected_bytes,
        )
        if plan_queue is not None and apply_queue_context is not None:
            backup_dir, query, max_results = apply_queue_context
            append_apply_queue_completed_record(backup_dir, query, max_results, settings, len(state.planned))
    except BaseException as exc:
        state.error = exc
        reporter.log_event(
            1,
            f"Inspection failed: {exc}",
            "inspection_failed",
            error=str(exc),
        )
    finally:
        if plan_queue is not None:
            plan_queue.put(PLAN_QUEUE_SENTINEL)


def run_extract_media(
    client,
    query: str,
    backup_dir: Path,
    max_results: int,
    apply_mode: bool,
    settings: ExtractionSettings,
    verbose: int = 0,
    request_profile: str = "aggressive",
    progress_format: str = "text",
    *,
    assume_yes: bool = False,
    resume: bool = True,
    audit_label_settings: AuditLabelSettings | None = None,
    export_only: bool = False,
) -> dict[str, object]:
    if max_results < 1:
        raise ValueError("--max-results must be 1 or greater")
    if apply_mode and export_only:
        raise ValueError("--apply and --export-only cannot be used together")
    reporter = ProgressReporter(verbose=verbose, progress_format=progress_format)
    run_mode = "apply" if apply_mode else "export-only" if export_only else "dry-run"
    reporter.log_event(
        1,
        f"Preparing Gmail search with query {query!r} (max_results={max_results})",
        "run_started",
        query=query,
        max_results=max_results,
        mode=run_mode,
        request_profile=request_profile,
    )
    inspection_state = InspectionState()
    applied: list[dict[str, object]] = []
    exported: list[dict[str, object]] = []
    resumed_applied: list[dict[str, object]] = []
    resumed_exported: list[dict[str, object]] = []
    runtime_skipped: list[PlannedMessage] = []
    completed_records: dict[str, dict[str, object]] = {}
    exported_records: dict[str, dict[str, object]] = {}
    queued_resume_ids: list[str] = []
    if apply_mode or export_only:
        backup_dir.mkdir(parents=True, exist_ok=True)
    if apply_mode:
        completed_records = completed_manifest_records_by_original_id(backup_dir) if resume else {}
        queued_resume_ids = queued_message_ids_for_resume(backup_dir, query, max_results, settings, completed_records) if resume else []
    if export_only:
        exported_records = exported_manifest_records_by_original_id(backup_dir) if resume else {}
    audit_labels = resolve_audit_labels(client, audit_label_settings, apply_mode=apply_mode)
    if queued_resume_ids:
        message_ids = queued_resume_ids
        reporter.log_event(
            1,
            f"Loaded {len(message_ids)} pending message(s) from the persisted apply queue",
            "apply_queue_loaded",
            query=query,
            pending_messages=len(message_ids),
        )
    else:
        reporter.log_event(
            1,
            f"Searching Gmail with query {query!r} (max_results={max_results})",
            "gmail_search_started",
            query=query,
            max_results=max_results,
        )
        message_ids = client.list_message_ids(query, max_results)
        reporter.log_event(
            1,
            f"Gmail matched {len(message_ids)} message(s) for query {query!r}",
            "gmail_match_count",
            query=query,
            matched_messages=len(message_ids),
        )
    if apply_mode or export_only:
        plan_queue: queue.Queue[PlannedMessage | object] = queue.Queue(maxsize=APPLY_PLAN_QUEUE_DEPTH)
        apply_queue_context = (backup_dir, query, max_results) if apply_mode else None
        inspection_thread = threading.Thread(
            target=inspect_matching_messages,
            args=(client, message_ids, settings, reporter, request_profile, inspection_state),
            kwargs={"plan_queue": plan_queue, "apply_queue_context": apply_queue_context},
            daemon=True,
        )
        inspection_thread.start()
        while True:
            queued_item = plan_queue.get()
            if queued_item is PLAN_QUEUE_SENTINEL:
                break
            plan = queued_item
            if export_only:
                completed_record = exported_records.get(plan.message_id)
                if completed_record is not None:
                    resumed_exported.append(completed_record)
                    reporter.log_event(
                        1,
                        f"Already exported {plan.message_id}; skipping from manifest resume state",
                        "export_resume_skipped",
                        message_id=plan.message_id,
                    )
                    continue
                index = len(exported) + len(runtime_skipped) + len(resumed_exported) + 1
                total_hint = max(index, len(inspection_state.planned))
                reporter.log_event(
                    1,
                    f"Exporting {index}/{total_hint} {plan.message_id} with {len(plan.media_parts)} attachment part(s)",
                    "export_started",
                    index=index,
                    total=total_hint,
                    message_id=plan.message_id,
                    total_known=not inspection_thread.is_alive(),
                )
                try:
                    exported_record = export_message_plan(
                        plan,
                        backup_dir,
                        query,
                        settings,
                        verbose=verbose,
                        assume_yes=assume_yes,
                    )
                except SkippableMessageError as exc:
                    skipped_plan = replace(plan, skip_reason=str(exc))
                    runtime_skipped.append(skipped_plan)
                    reporter.log_event(
                        1,
                        f"Skipped {plan.message_id} [{exc}]",
                        "export_skipped",
                        message_id=plan.message_id,
                        reason=str(exc),
                    )
                    continue
                exported.append(exported_record)
                reporter.log_event(
                    1,
                    f"Exported {index}/{total_hint} {plan.message_id}",
                    "export_completed",
                    index=index,
                    total=total_hint,
                    message_id=plan.message_id,
                )
                continue
            completed_record = completed_records.get(plan.message_id)
            if completed_record is not None:
                resumed_applied.append(completed_record)
                reporter.log_event(
                    1,
                    f"Already applied {plan.message_id}; skipping from manifest resume state",
                    "apply_resume_skipped",
                    message_id=plan.message_id,
                    new_message_id=completed_record.get("new_message_id"),
                )
                continue
            index = len(applied) + len(runtime_skipped) + len(resumed_applied) + 1
            total_hint = max(index, len(inspection_state.planned))
            reporter.log_event(
                1,
                f"Applying {index}/{total_hint} {plan.message_id} with {len(plan.media_parts)} attachment part(s)",
                "apply_started",
                index=index,
                total=total_hint,
                message_id=plan.message_id,
                total_known=not inspection_thread.is_alive(),
            )
            try:
                applied_record = execute_message_plan(
                    client,
                    plan,
                    backup_dir,
                    query,
                    settings,
                    verbose=verbose,
                    assume_yes=assume_yes,
                    audit_labels=audit_labels,
                )
            except SkippableMessageError as exc:
                skipped_plan = replace(plan, skip_reason=str(exc))
                runtime_skipped.append(skipped_plan)
                if "password-protected or encrypted PDF" in str(exc):
                    append_password_review_record(backup_dir, plan, query, str(exc))
                reporter.log_event(
                    1,
                    f"Skipped {plan.message_id} [{exc}]",
                    "apply_skipped",
                    message_id=plan.message_id,
                    reason=str(exc),
                )
                continue
            applied.append(applied_record)
            reporter.log_event(
                1,
                f"Applied {index}/{total_hint} {plan.message_id} -> {applied_record['new_message_id']}",
                "apply_completed",
                index=index,
                total=total_hint,
                message_id=plan.message_id,
                new_message_id=applied_record["new_message_id"],
            )
        inspection_thread.join()
    else:
        inspect_matching_messages(client, message_ids, settings, reporter, request_profile, inspection_state)
    if inspection_state.error is not None:
        raise inspection_state.error
    planned = inspection_state.planned
    skipped = list(inspection_state.skipped)
    if runtime_skipped:
        skipped.extend(runtime_skipped)
        skipped_ids = {plan.message_id for plan in runtime_skipped}
        planned = [plan for plan in planned if plan.message_id not in skipped_ids]
    if apply_mode and skipped:
        apply_review_label_to_skipped(client, skipped, audit_labels, verbose=verbose)
    summary = summarize_run(query, backup_dir, message_ids, planned, skipped, applied if apply_mode else [], apply_mode)
    if export_only:
        summary["mode"] = "export-only"
    summary["exported"] = exported
    summary["resumed_exported"] = resumed_exported
    summary["resumed_applied"] = resumed_applied
    summary["audit_labels"] = {
        "processed": audit_labels.processed_name,
        "review": audit_labels.review_name,
    }
    reporter.event(
        "run_completed",
        applied=len(applied),
        exported=len(exported),
        resumed=len(resumed_applied),
        resumed_exported=len(resumed_exported),
        skipped=len(skipped),
        candidate_messages=summary["candidate_messages"],
        matched_messages=summary["matched_messages"],
    )
    return summary


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.command is None:
        parser.print_help()
        return 1
    if args.command == "index" and args.index_command is None:
        return die("Missing index subcommand. Use `gmail-cleanup index build`, `gmail-cleanup index stats`, or `gmail-cleanup index analyze`.")
    if args.command == "doctor":
        try:
            report = run_doctor(args)
        except ValueError as exc:
            return die(str(exc))
        if args.json:
            print(json.dumps(report, indent=2, sort_keys=True))
        else:
            print(render_doctor(report))
        return 0
    try:
        apply_preset_defaults(args)
        config_path = resolve_config_path(args.config)
        config = load_config(config_path)
        if args.command == "index" and args.index_command == "stats":
            index_db = resolve_index_db_path(args.index_db, config, config_path)
            gmail_index = GmailIndex(index_db)
            try:
                summary = gmail_index.stats()
                summary["mode"] = "index-stats"
            finally:
                gmail_index.close()
        elif args.command == "index" and args.index_command == "analyze":
            index_db = resolve_index_db_path(args.index_db, config, config_path)
            summary = run_index_analyze(
                index_db,
                query=args.query.strip() if args.query else None,
                max_results=args.max_results,
                top=args.top,
            )
        elif args.command == "index" and args.index_command == "build":
            query = resolve_query(args.query)
            credentials_path = resolve_credentials_path(args.credentials, config, config_path)
            token_cache_path = resolve_token_cache_path(args.token_cache, config, config_path)
            gmail_user = resolve_gmail_user(args.gmail_user, config, config_path)
            max_results = resolve_max_results(args.max_results, config, config_path)
            request_profile = resolve_request_profile(args.request_profile, config, config_path)
            quota_units_per_second = resolve_quota_units_per_second(
                args.quota_units_per_second,
                config,
                config_path,
                request_profile,
            )
            index_db = resolve_index_db_path(args.index_db, config, config_path)
            progress_format = resolve_progress_format(args.progress_format, config, config_path)
            client = build_gmail_client(
                credentials_path,
                token_cache_path,
                APPLY_SCOPES,
                gmail_user,
                assume_yes=args.yes,
                quota_units_per_second=quota_units_per_second,
            )
            summary = run_index_build(
                client,
                query,
                max_results,
                index_db,
                request_profile=request_profile,
                progress_format=progress_format,
                verbose=args.verbose,
            )
        elif args.command == "report":
            query = resolve_query(args.query)
            max_results = resolve_max_results(args.max_results, config, config_path)
            settings = build_extraction_settings(args, config, config_path)
            request_profile = resolve_request_profile(args.request_profile, config, config_path)
            if args.offline and not args.use_index:
                raise ValueError("--offline requires --use-index")
            if args.offline:
                client = IndexOnlyGmailClient(GmailIndex(resolve_index_db_path(args.index_db, config, config_path)))
            else:
                credentials_path = resolve_credentials_path(args.credentials, config, config_path)
                token_cache_path = resolve_token_cache_path(args.token_cache, config, config_path)
                gmail_user = resolve_gmail_user(args.gmail_user, config, config_path)
                quota_units_per_second = resolve_quota_units_per_second(
                    args.quota_units_per_second,
                    config,
                    config_path,
                    request_profile,
                )
                client = build_gmail_client(
                    credentials_path,
                    token_cache_path,
                    APPLY_SCOPES,
                    gmail_user,
                    quota_units_per_second=quota_units_per_second,
                )
                if args.use_index:
                    client = IndexedGmailClient(client, GmailIndex(resolve_index_db_path(args.index_db, config, config_path)))
            backup_dir = None
            if args.backup_dir is not None or os.environ.get(DEFAULT_BACKUP_DIR_ENV) or "backup_dir" in config:
                backup_dir = resolve_backup_dir(args.backup_dir, config, config_path).expanduser()
            gmail_link_account = resolve_gmail_web_account(args.gmail_web_account, config, config_path) if args.gmail_links else None
            summary = run_report(
                client,
                query,
                max_results,
                settings,
                request_profile=request_profile,
                backup_dir=backup_dir,
                gmail_link_account=gmail_link_account,
            )
        elif args.command == "extract-media":
            query = resolve_query(args.query)
            index_only_export = bool(args.use_index and args.export_only)
            credentials_path = None if index_only_export else resolve_credentials_path(args.credentials, config, config_path)
            token_cache_path = None if index_only_export else resolve_token_cache_path(args.token_cache, config, config_path)
            gmail_user = None if index_only_export else resolve_gmail_user(args.gmail_user, config, config_path)
            max_results = resolve_max_results(args.max_results, config, config_path)
            settings = build_extraction_settings(args, config, config_path)
            request_profile = resolve_request_profile(args.request_profile, config, config_path)
            quota_units_per_second = resolve_quota_units_per_second(
                args.quota_units_per_second,
                config,
                config_path,
                request_profile,
            )
            backup_dir = resolve_backup_dir(args.backup_dir, config, config_path).expanduser()
            progress_format = resolve_progress_format(args.progress_format, config, config_path)
            audit_label_settings = resolve_audit_label_settings(args, config, config_path)
            if args.apply and args.export_only:
                raise ValueError("--apply and --export-only cannot be used together")
            if args.use_index and args.export_only:
                client = IndexOnlyGmailClient(GmailIndex(resolve_index_db_path(args.index_db, config, config_path)))
            else:
                client = build_gmail_client(
                    credentials_path,
                    token_cache_path,
                    APPLY_SCOPES,
                    gmail_user or "me",
                    assume_yes=args.yes,
                    quota_units_per_second=quota_units_per_second,
                )
                if args.use_index:
                    client = IndexedGmailClient(client, GmailIndex(resolve_index_db_path(args.index_db, config, config_path)))
            summary = run_extract_media(
                client,
                query,
                backup_dir,
                max_results,
                args.apply,
                settings,
                verbose=args.verbose,
                request_profile=request_profile,
                progress_format=progress_format,
                assume_yes=args.yes,
                resume=not args.no_resume,
                audit_label_settings=audit_label_settings,
                export_only=args.export_only,
            )
        else:
            parser.print_help()
            return 1
        summary["config_path"] = str(config_path) if config_path.exists() else None
    except (RuntimeError, ValueError) as exc:
        return die(str(exc))
    if args.json:
        print(json.dumps(summary, indent=2, sort_keys=True))
    elif args.command == "index" and args.index_command == "build":
        print(render_index_build(summary))
    elif args.command == "index" and args.index_command == "stats":
        print(render_index_stats(summary))
    elif args.command == "index" and args.index_command == "analyze":
        print(render_index_analyze(summary))
    elif args.command == "report":
        print(render_report(summary))
    else:
        print(render_summary(summary))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
