def apply_queue_has_completed_marker(
    backup_dir: Path,
    query: str,
    max_results: int,
    settings: ExtractionSettings,
) -> bool:
    expected_settings = settings_checkpoint_payload(settings)
    for record in read_jsonl_records(apply_queue_path(backup_dir)):
        if (
            record.get("version") == APPLY_QUEUE_VERSION
            and record.get("record_type") == "inspection_completed"
            and record.get("query") == query
            and record.get("max_results") == max_results
            and record.get("settings") == expected_settings
        ):
            return True
    return False


def load_apply_queue_records(
    backup_dir: Path,
    query: str,
    max_results: int,
    settings: ExtractionSettings,
) -> list[dict[str, object]]:
    if not apply_queue_has_completed_marker(backup_dir, query, max_results, settings):
        return []
    expected_settings = settings_checkpoint_payload(settings)
    records: list[dict[str, object]] = []
    seen: set[str] = set()
    for record in read_jsonl_records(apply_queue_path(backup_dir)):
        message_id = record.get("message_id")
        if (
            record.get("version") != APPLY_QUEUE_VERSION
            or record.get("record_type", "candidate") != "candidate"
            or record.get("query") != query
            or record.get("max_results") != max_results
            or record.get("settings") != expected_settings
            or not isinstance(message_id, str)
            or message_id in seen
        ):
            continue
        seen.add(message_id)
        records.append(record)
    return records


def queued_message_ids_for_resume(
    backup_dir: Path,
    query: str,
    max_results: int,
    settings: ExtractionSettings,
    completed_records: dict[str, dict[str, object]],
) -> list[str]:
    queued_ids = [
        str(record["message_id"])
        for record in load_apply_queue_records(backup_dir, query, max_results, settings)
        if record.get("message_id") not in completed_records
    ]
    return queued_ids


def append_password_review_record(backup_dir: Path, plan: PlannedMessage, query: str, reason: str) -> None:
    attempted_recipes: list[str] = []
    match = re.search(r"\[attempted recipes: (?P<recipes>[^\]]+)\]", reason)
    if match:
        attempted_recipes = [item.strip() for item in match.group("recipes").split(",") if item.strip()]
    record = {
        "action": "manual_review",
        "attachment_filenames": [part.filename for part in plan.media_parts if part.mime_type == PDF_MIME_TYPE],
        "attempted_recipes": attempted_recipes,
        "date_header": plan.date_header,
        "message_id": plan.message_id,
        "query": query,
        "reason": reason,
        "sender": plan.sender,
        "subject": plan.subject,
        "thread_id": plan.thread_id,
    }
    review_path = backup_dir / "passworded-pdfs.jsonl"
    if review_path.exists():
        try:
            for line in review_path.read_text(encoding="utf-8").splitlines():
                if not line.strip():
                    continue
                existing = json.loads(line)
                if (
                    existing.get("message_id") == record["message_id"]
                    and existing.get("attachment_filenames") == record["attachment_filenames"]
                    and existing.get("query") == record["query"]
                    and existing.get("reason") == record["reason"]
                ):
                    return
        except (OSError, json.JSONDecodeError):
            pass
    append_manifest_record(review_path, record)


def find_existing_cleanup_replacement(client, plan: PlannedMessage) -> str | None:
    lookup = getattr(client, "find_cleanup_replacement_message_id", None)
    if lookup is None:
        return None
    return lookup(plan.thread_id, plan.message_id)


def execute_message_plan(
    client,
    plan: PlannedMessage,
    backup_dir: Path,
    query: str,
    settings: ExtractionSettings,
    verbose: int = 0,
    *,
    assume_yes: bool = False,
    audit_labels: ResolvedAuditLabels | None = None,
) -> dict[str, object]:
    extracted_at = datetime.now(timezone.utc)
    operation_id = f"{extracted_at.strftime('%Y%m%dT%H%M%SZ')}-{plan.message_id}"
    backup_folder_name = plan.message_id
    had_existing_backup_folder = (backup_dir / backup_folder_name).exists()
    log_progress(verbose, 2, f"Rewriting {format_message_label(plan)}")
    _, buffered = rewrite_message_for_backup(plan, extracted_at, backup_folder_name, operation_id, settings=settings)
    _, written, pdf_text_blocks = write_backup_files(
        backup_dir,
        plan,
        plan.message_id,
        buffered,
        settings,
        verbose=verbose,
        assume_yes=assume_yes,
    )
    log_progress(
        verbose,
        2,
        f"Wrote {len(written)} backup file(s) for {plan.message_id} into {backup_folder_name}/",
    )
    embed_marker_metadata(written, plan, operation_id, extracted_at, verbose=verbose, assume_yes=assume_yes)
    trash_written_attachments_marked_for_trash(written, verbose=verbose, assume_yes=assume_yes)
    rewritten_raw, _ = rewrite_message_for_backup(
        plan,
        extracted_at,
        backup_folder_name,
        operation_id,
        settings=settings,
        written_attachments=written,
        pdf_text_blocks=pdf_text_blocks,
    )
    new_message_id = find_existing_cleanup_replacement(client, plan) if had_existing_backup_folder else None
    if new_message_id is None:
        new_message_id = client.insert_message(
            plan.thread_id,
            plan.label_ids,
            rewritten_raw,
            original_message_id=plan.message_id,
        )
    else:
        log_progress(verbose, 2, f"Found existing cleanup copy {new_message_id} for original {plan.message_id}")
    if audit_labels is not None and audit_labels.processed_id is not None:
        client.modify_message_labels(new_message_id, (audit_labels.processed_id,))
        log_progress(verbose, 2, f"Applied processed label {audit_labels.processed_name!r} to cleaned copy {new_message_id}")
    client.trash_message(plan.message_id)
    log_progress(verbose, 2, f"Inserted {new_message_id} and trashed original {plan.message_id}")
    manifest_record = {
        "action": "extract_media",
        "applied_at": extracted_at.astimezone(timezone.utc).isoformat(timespec="seconds"),
        "attachments": [written_attachment_to_dict(item) for item in written],
        "backup_dir": str(backup_dir),
        "gmail_labels": {
            "processed": audit_labels.processed_name if audit_labels is not None else None,
        },
        "metadata_embedded": all(written_attachment_metadata_embedded(item) for item in written),
        "message_backup_folder": backup_folder_name,
        "new_message_id": new_message_id,
        "operation_id": operation_id,
        "original_message_id": plan.message_id,
        "query": query,
        "sender": plan.sender,
        "subject": plan.subject,
        "thread_id": plan.thread_id,
    }
    return append_completed_manifest_record(backup_dir, manifest_record)


def export_message_plan(
    plan: PlannedMessage,
    backup_dir: Path,
    query: str,
    settings: ExtractionSettings,
    verbose: int = 0,
    *,
    assume_yes: bool = False,
) -> dict[str, object]:
    exported_at = datetime.now(timezone.utc)
    operation_id = f"{exported_at.strftime('%Y%m%dT%H%M%SZ')}-{plan.message_id}-export"
    backup_folder_name = plan.message_id
    message = parse_email_message(plan.raw_bytes)
    buffered = collect_buffered_media(message, plan)
    _, written, pdf_text_blocks = write_backup_files(
        backup_dir,
        plan,
        backup_folder_name,
        buffered,
        settings,
        verbose=verbose,
        assume_yes=assume_yes,
    )
    del pdf_text_blocks
    log_progress(
        verbose,
        2,
        f"Exported {len(written)} backup file(s) for {plan.message_id} into {backup_folder_name}/",
    )
    embed_marker_metadata(written, plan, operation_id, exported_at, verbose=verbose, assume_yes=assume_yes)
    trash_written_attachments_marked_for_trash(written, verbose=verbose, assume_yes=assume_yes)
    manifest_record = {
        "action": "export_attachments",
        "attachments": [written_attachment_to_dict(item) for item in written],
        "backup_dir": str(backup_dir),
        "gmail_modified": False,
        "message_backup_folder": backup_folder_name,
        "operation_id": operation_id,
        "original_message_id": plan.message_id,
