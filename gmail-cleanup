def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog=Path(sys.argv[0]).name,
        description=(
            "Back up selected Gmail attachments to a local folder, rewrite the message "
            "without those attachments, and keep the email in place by inserting a modified copy."
        ),
    )
    subparsers = parser.add_subparsers(dest="command")

    extract = subparsers.add_parser(
        "extract-media",
        help="Back up selected attachments to a local folder and remove them from the email copy kept in Gmail.",
    )
    extract.add_argument(
        "--preset",
        choices=VALID_PRESETS,
        default=None,
        help="Apply a named cleanup option set such as large-media, office-docs, archives, audio-archive, old-media, or pdf-archive.",
    )
    extract.add_argument("--query", default=None, help="Gmail search query used to find candidate messages.")
    extract.add_argument(
        "--backup-dir",
        type=Path,
        help=(
            "Local directory where extracted media files and the manifest are written. "
            f"Defaults to ${DEFAULT_BACKUP_DIR_ENV} or {DEFAULT_CONFIG_PATH}."
        ),
    )
    extract.add_argument(
        "--max-results",
        type=int,
        default=None,
        help="Maximum number of Gmail search matches to inspect (default: 50; values above 500 are paginated).",
    )
    extract.add_argument(
        "--config",
        type=Path,
        help=(
            "Path to a local TOML config file. "
            f"Defaults to ${DEFAULT_CONFIG_ENV} or {DEFAULT_CONFIG_PATH}."
        ),
    )
    extract.add_argument(
        "--credentials",
        type=Path,
        help=(
            "Path to the Google desktop OAuth client secret JSON. "
            f"Defaults to ${DEFAULT_CREDENTIALS_ENV} or the config file."
        ),
    )
    extract.add_argument(
        "--token-cache",
        type=Path,
        help=(
            "Path to the cached OAuth token JSON. "
            f"Defaults to ${DEFAULT_TOKEN_ENV}, the config file, or {DEFAULT_TOKEN_PATH}."
        ),
    )
    extract.add_argument(
        "--gmail-user",
        default=None,
        help=(
            "Gmail user ID to call the API with. "
            f"Defaults to ${DEFAULT_GMAIL_USER_ENV}, the config file, or me."
        ),
    )
    extract.add_argument(
        "--index-db",
        type=Path,
        help=(
            "Path to the local SQLite Gmail index. "
            f"Defaults to ${DEFAULT_INDEX_DB_ENV}, the config file, or {DEFAULT_INDEX_DB_PATH}."
        ),
    )
    extract.add_argument(
        "--use-index",
        action="store_true",
        help="Use the local Gmail index as a read-through cache for message IDs and raw MIME bytes.",
    )
    extract.add_argument(
        "--apply",
        action="store_true",
        help=(
            "Actually write backup files, insert modified Gmail copies, and move originals to Trash. "
            "Without this flag the command performs a dry run."
        ),
    )
    extract.add_argument(
        "--export-only",
        action="store_true",
        help="Write selected backup files and manifest records, but leave Gmail unchanged.",
    )
    extract.add_argument(
        "--types",
        default=None,
        help=(
            "Comma-separated attachment selectors to extract. "
            f"Supported values: {', '.join(VALID_ATTACHMENT_TYPES)}. "
            "Default: image,video."
        ),
    )
    extract.add_argument(
        "--before-year",
        type=int,
        default=None,
        help="Only select attachments from messages whose Date header is before this year.",
    )
    extract.add_argument(
        "--min-message-bytes",
        type=int,
        default=None,
        help="Only select messages whose selected attachments total at least this many bytes.",
    )
    extract.add_argument(
        "--min-part-bytes",
        type=int,
        default=None,
        help="Only select attachment parts at least this many bytes.",
    )
    extract.add_argument(
        "--pdf-mode",
        choices=VALID_PDF_MODES,
        default=None,
        help=(
            "How PDFs are handled when pdf is included in --types: "
            "auto (prefer direct page-image extraction for scanned PDFs, otherwise render pages), "
            "render-pages, extract-images, or backup."
        ),
    )
    extract.add_argument(
        "--pdf-original",
        choices=VALID_PDF_ORIGINAL_RETENTION,
        default=None,
        help=(
            "What to do with the original local PDF after derived outputs are created: "
            "keep, trash, or discard. Ignored when --pdf-mode=backup."
        ),
    )
    extract.add_argument(
        "--pdf-password-mode",
        choices=VALID_PDF_PASSWORD_MODES,
        default=None,
        help=(
            "How password-protected PDFs are handled: "
            "skip leaves the email unchanged and records it for manual review; "
            "infer tries bounded password guesses from the email content first; "
            "low-hanging adds weak bank/card-style patterns such as last4, last6, and ddmmmyyyy."
        ),
