def resolve_audit_labels(client, settings: AuditLabelSettings | None, *, apply_mode: bool) -> ResolvedAuditLabels:
    if not apply_mode or settings is None:
        return ResolvedAuditLabels()
    processed_id = client.get_or_create_label(settings.processed) if settings.processed else None
    review_id = client.get_or_create_label(settings.review) if settings.review else None
    return ResolvedAuditLabels(
        processed_name=settings.processed,
        processed_id=processed_id,
        review_name=settings.review,
        review_id=review_id,
    )


def apply_review_label_to_skipped(client, skipped: list[PlannedMessage], labels: ResolvedAuditLabels, verbose: int = 0) -> None:
    if labels.review_id is None:
        return
    seen: set[str] = set()
    for plan in skipped:
        if plan.message_id in seen:
            continue
        seen.add(plan.message_id)
        client.modify_message_labels(plan.message_id, (labels.review_id,))
        log_progress(verbose, 2, f"Applied review label {labels.review_name!r} to skipped original {plan.message_id}")


